# LiteSpeed/Apache optimization for static site
# Safe defaults: browser caching, optional WebP, and no-cache for form handler.

# Turn on the rewrite engine (required for WebP routing below)
<IfModule mod_rewrite.c>
  RewriteEngine On
</IfModule>

# Never cache the form handler
<FilesMatch "send_email\.php$">
  <IfModule mod_expires.c>
    ExpiresActive Off
  </IfModule>
  <IfModule mod_headers.c>
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
  </IfModule>
</FilesMatch>

# Browser caching for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  # Default fallback
  ExpiresDefault "access plus 1 hour"
  # HTML short TTL so edits show up quickly
  ExpiresByType text/html "access plus 10 minutes"
  # CSS/JS/images/fonts longer TTLs
  ExpiresByType text/css "access plus 30 days"
  ExpiresByType application/javascript "access plus 30 days"
  ExpiresByType text/javascript "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/gif "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType font/woff2 "access plus 30 days"
  ExpiresByType font/woff "access plus 30 days"
  ExpiresByType application/font-woff2 "access plus 30 days"
</IfModule>

# Helpful MIME types
AddType image/webp .webp
AddType font/woff2 .woff2

# Optional: Serve WebP when available and supported by the browser
# (Place .webp alongside the original .jpg/.png with the same basename)
<IfModule mod_rewrite.c>
  # If browser supports WebP and a .webp alternative exists, serve it
  RewriteCond %{HTTP_ACCEPT} image/webp
  RewriteCond %{REQUEST_FILENAME} \.(jpe?g|png)$ [NC]
  RewriteCond %{REQUEST_FILENAME}.webp -f
  RewriteRule ^(.+)\.(jpe?g|png)$ $1.webp [T=image/webp,E=accept:1]
</IfModule>
<IfModule mod_headers.c>
  # Ensure caches vary by Accept header when rewriting to WebP
  Header append Vary Accept env=REDIRECT_accept

  # Light security hardening
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Strong cache headers for static assets (browser caching)
<IfModule mod_headers.c>
  <FilesMatch "\.(?:css|js)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  <FilesMatch "\.(?:jpe?g|png|gif|svg|webp)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  <FilesMatch "\.(?:woff2?|ttf)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
</IfModule>

# LiteSpeed page cache (LSCache) for static HTML pages
# Enable if LSCache is active on the server
<IfModule LITESPEED>
  CacheLookup public on
  <IfModule mod_rewrite.c>
    RewriteEngine On
    # Cache only GET/HEAD, avoid PHP handler, allow manual bypass via ?nocache=1
    RewriteCond %{REQUEST_METHOD} ^GET|HEAD$ [NC]
    RewriteCond %{REQUEST_URI} !/send_email\.php$
    RewriteCond %{QUERY_STRING} !(^|&)nocache=1(&|$)
    RewriteRule .* - [E=cache-control:max-age=3600,public]
  </IfModule>
</IfModule>

# Misc hardening
Options -Indexes
