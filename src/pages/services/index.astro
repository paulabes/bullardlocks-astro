---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTASection from '../../components/CTASection.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Locksmith Services — Bullard Locks",
    "description": "Professional auto locksmith, emergency locksmith and safe engineer services across North & Central London and UK-wide.",
    "url": "https://bullardlocks.com/services",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "Service",
          "name": "Auto Locksmith",
          "url": "https://bullardlocks.com/services/auto-locksmith",
          "description": "Mobile auto locksmith — car key replacement, programming and vehicle lockout across North & Central London."
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "Service",
          "name": "Emergency Locksmith",
          "url": "https://bullardlocks.com/services/emergency-locksmith",
          "description": "24/7 emergency locksmith North London — rapid 20–40 min response, no call-out fee."
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@type": "Service",
          "name": "Safe Engineer",
          "url": "https://bullardlocks.com/services/safe-engineer",
          "description": "Professional safe engineer UK-wide by appointment — safe opening, installation and repair."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://bullardlocks.com/"},
      {"@type": "ListItem", "position": 2, "name": "Services", "item": "https://bullardlocks.com/services"}
    ]
  }
];
---

<BaseLayout
  title="Auto Locksmith & Emergency Locksmith Services London | Bullard Locks"
  description="Auto locksmith, emergency locksmith & safe engineer — North & Central London. Mobile, 24/7, no call-out fee. 30+ years experience. Call William: 07809 887 883."
  canonicalUrl="https://bullardlocks.com/services"
  schema={schema}
>
  <PageHero
    title="Locksmith Services"
    accent="London"
    lead="Comprehensive locksmith services for homes, businesses, and vehicles. From emergency lockouts to safe engineering, I provide expert solutions with over 30 years of experience."
    image="/images/william-bullard-trusted-london-locksmith.jpg"
    imageAlt="Professional Locksmith Services North London Emergency Auto Safe Engineer"
    breadcrumbs={[
      { label: "Home", href: "/" },
      { label: "Services" }
    ]}
    featurePills={[
      { icon: "fa-clock", text: "24/7 Emergency" },
      { icon: "fa-car", text: "Auto Locksmith" },
      { icon: "fa-shield-alt", text: "Safe Engineer" }
    ]}
  />

  <!-- Services Grid -->
  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Our Services</h2>
        <p class="section-subtitle">
          Expert security solutions tailored to your needs, delivered with professionalism and care.
        </p>
      </div>

      <div class="services-grid">
        <ServiceCard
          number="01"
          icon="fa-clock"
          title="Emergency Locksmith"
          description="24/7 rapid response for lockouts, break-ins, and urgent lock changes across North London. No call-out fee with typical arrival within 20-40 minutes."
          href="/services/emergency-locksmith"
        />
        <ServiceCard
          number="02"
          icon="fa-car"
          title="Auto Locksmith"
          description="Mobile car key replacement, programming, and vehicle lockout services for all makes and models across North and Central London."
          href="/services/auto-locksmith"
        />
        <ServiceCard
          number="03"
          icon="fa-shield-alt"
          title="Safe Engineer"
          description="Professional safe opening, installation, and repair services for homes and businesses. Available UK-wide by appointment."
          href="/services/safe-engineer"
        />
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="content-section bg-dark">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Why Choose Bullard Locks?</h2>
        <p class="section-subtitle">
          Trusted by the Met Police and thousands of customers across London.
        </p>
      </div>

      <div class="services-icon-grid">
        <div class="service-icon-card">
          <div class="icon-circle">
            <i class="fas fa-certificate"></i>
          </div>
          <h3>30+ Years Experience</h3>
          <p>
            Decades of expertise handling every type of lock, key, and security situation imaginable.
          </p>
        </div>

        <div class="service-icon-card">
          <div class="icon-circle">
            <i class="fas fa-pound-sign"></i>
          </div>
          <h3>No Call-Out Fee</h3>
          <p>
            Transparent pricing with no hidden charges. You only pay for the work completed.
          </p>
        </div>

        <div class="service-icon-card">
          <div class="icon-circle">
            <i class="fas fa-user-shield"></i>
          </div>
          <h3>DBS Checked</h3>
          <p>
            Fully vetted and DBS checked for your peace of mind and security.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Need a Locksmith?"
    subtitle="Available 24/7 | No call-out fee | 30+ years experience"
  />
</BaseLayout>
