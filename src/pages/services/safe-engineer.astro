---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoogleReviews from '../../components/GoogleReviews.astro';
import CTASection from '../../components/CTASection.astro';

const heroImage = '/images/hero-safe-engineer.webp';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Safe Engineer UK-Wide',
    provider: {
      '@type': 'LocksmithBusiness',
      name: 'Bullard Locks',
      telephone: '07809887883',
      url: 'https://bullardlocks.com',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '67 Weston Park',
        addressLocality: 'Crouch End',
        addressRegion: 'London',
        postalCode: 'N8 9TA',
        addressCountry: 'GB',
      },
    },
    areaServed: [
      {'@type': 'Country', 'name': 'United Kingdom'},
      {'@type': 'City', 'name': 'Haringey', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
      {'@type': 'City', 'name': 'Barnet', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
      {'@type': 'City', 'name': 'Camden', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
      {'@type': 'City', 'name': 'Islington', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
      {'@type': 'City', 'name': 'Hackney', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
      {'@type': 'City', 'name': 'Enfield', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
      {'@type': 'City', 'name': 'Westminster', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
      {'@type': 'City', 'name': 'City of London', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
      {'@type': 'City', 'name': 'Kensington and Chelsea', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
      {'@type': 'City', 'name': 'Hammersmith and Fulham', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
    ],
    serviceType: ['Safe Opening', 'Safe Cracking', 'Safe Installation', 'Safe Repair', 'Combination Change', 'Safe Engineer'],
    description: 'Professional safe engineer (safe cracker) UK-wide by appointment. Non-destructive safe opening, installation, combination changes & repair. All brands. 30+ years experience. Call 07809 887 883.',
    url: 'https://bullardlocks.com/services/safe-engineer',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What safe brands do you work with?',
        acceptedAnswer: { '@type': 'Answer', text: 'All major manufacturers including Chubb, Phoenix, Dudley, Yale, Burton, SentrySafe, Honeywell, Securikey, De Raat, and many more. Call to confirm your specific safe.' },
      },
      {
        '@type': 'Question',
        name: 'How much does safe opening cost?',
        acceptedAnswer: { '@type': 'Answer', text: 'Cost depends on the safe type, locking mechanism, and method required to open it. William provides a clear, written quote before any work begins — no hidden fees.' },
      },
      {
        '@type': 'Question',
        name: 'How long does safe opening take?',
        acceptedAnswer: { '@type': 'Answer', text: 'Non-destructive opening typically takes 30 minutes to a few hours depending on the safe. More complex or older safes may require more time. A realistic estimate is given at the time of quoting.' },
      },
      {
        '@type': 'Question',
        name: 'Can you come to my home or business anywhere in the UK?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Safe engineering is available UK-wide by appointment. Priority response is given to North London, but William regularly travels nationally for this specialist work.' },
      },
      {
        '@type': 'Question',
        name: 'What is the difference between a combination safe and a key safe?',
        acceptedAnswer: { '@type': 'Answer', text: 'A combination safe opens via a dial or electronic keypad code. A key safe requires a physical key. Some safes use both. William handles opening, repair, and combination/key changes for both types.' },
      },
      {
        '@type': 'Question',
        name: 'Do you handle commercial and high-security safes?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. William has experience with commercial-grade safes, deposit safes, fire-rated safes, floor and wall safes, and gun cabinets. All work is carried out discreetly and professionally.' },
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bullardlocks.com/' },
      { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://bullardlocks.com/services' },
      { '@type': 'ListItem', position: 3, name: 'Safe Engineer', item: 'https://bullardlocks.com/services/safe-engineer' },
    ],
  },
];
---

