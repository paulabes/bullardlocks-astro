---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoogleReviews from '../../components/GoogleReviews.astro';
import CTASection from '../../components/CTASection.astro';

const heroImage = '/images/hero-emergency-locksmith.webp';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Emergency Locksmith North London',
    provider: {
      '@type': ['LocalBusiness', 'LocksmithBusiness'],
      name: 'Bullard Locks',
      telephone: '+447809887883',
      url: 'https://www.bullardlocks.com',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '67 Weston Park',
        addressLocality: 'Crouch End',
        addressRegion: 'London',
        postalCode: 'N8 9TA',
        addressCountry: 'GB',
      },
    },
    areaServed: [
      {'@type': 'City', 'name': 'Camden', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
      {'@type': 'City', 'name': 'Islington', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
      {'@type': 'City', 'name': 'Haringey', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
      {'@type': 'City', 'name': 'Barnet', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
      {'@type': 'City', 'name': 'Enfield', 'containedInPlace': {'@type': 'City', 'name': 'London'}},
      {'@type': 'City', 'name': 'Hackney', 'containedInPlace': {'@type': 'City', 'name': 'London'}}
    ],
    serviceType: ['Emergency Lockout', 'Break-in Repair', 'Lock Replacement', 'Key Extraction', 'Emergency Lock Change'],
    description: '24/7 emergency locksmith North London - rapid 20–40 min response for lockouts, break-in repair and urgent lock changes. No call-out fee. Call Bullard Locks: 07809 887 883.',
    url: 'https://www.bullardlocks.com/services/emergency-locksmith',
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      bestRating: '5',
      worstRating: '1',
      ratingCount: '23',
      reviewCount: '23',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How much does an emergency locksmith call-out cost in North London?',
        acceptedAnswer: { '@type': 'Answer', text: 'Bullard Locks does not charge a call-out fee for any emergency locksmith work in North London, regardless of the time of day. Many locksmith services advertise low headline rates then add surcharges for evenings, weekends, or bank holidays. With Bullard Locks, William provides a single fixed-price quote before any work begins - that is the only amount you pay. There are no hidden charges, no invoice surprises, and no additional fees for unsociable hours. This transparent pricing policy applies to all emergency work including lockouts, break-in repairs, and urgent lock changes across all North London boroughs.' },
      },
      {
        '@type': 'Question',
        name: 'How quickly can you reach me?',
        acceptedAnswer: { '@type': 'Answer', text: 'Bullard Locks typically arrives within 20 to 40 minutes across North London for emergency calls. William operates from a fully equipped mobile workshop based in Crouch End N8, which places him among the closest professional locksmiths to most of Haringey, Islington, Camden, Barnet, Hackney, and Enfield. When you call 07809 887 883, you speak directly to William - not a call centre - and he gives you an accurate arrival estimate based on your exact location and current traffic conditions. For addresses in the immediate Crouch End area, response times can be as fast as 15 minutes.' },
      },
      {
        '@type': 'Question',
        name: 'Will you damage my door or lock to get me back in?',
        acceptedAnswer: { '@type': 'Answer', text: 'Non-destructive entry is always the first approach used by Bullard Locks. William is a specialist in non-destructive lock opening techniques developed over 30 years of practice, and in the vast majority of lockout situations he gains entry without any damage to the door, frame, lock, or paintwork. This skill is one of the reasons William holds Metropolitan Police and British Gas approved contractor status - both organisations require non-destructive entry as a condition of their contracts. If a lock does need to be drilled as a last resort, William discusses this with you first and fits a new British Standard replacement on the same visit.' },
      },
      {
        '@type': 'Question',
        name: 'Do you work 24/7?',
        acceptedAnswer: { '@type': 'Answer', text: 'The Bullard Locks emergency locksmith service operates 24 hours a day, 7 days a week, 365 days a year - including Christmas Day, New Year, and all bank holidays. This is a genuine around-the-clock service staffed by William personally, not an answering machine that redirects to a daytime callback or a national call centre that dispatches an unknown subcontractor. When you call 07809 887 883 at 3am on a Sunday, William answers the phone, provides a quote, and attends your location. The same experienced, Met Police approved locksmith handles every job regardless of when you call.' },
      },
      {
        '@type': 'Question',
        name: 'Can you help businesses as well as homes?',
        acceptedAnswer: { '@type': 'Answer', text: 'Bullard Locks regularly attends commercial premises across North London for emergency locksmith work. This includes shops, offices, restaurants, residential blocks, surgeries, and warehouses. Common commercial jobs include emergency access after lockouts, break-in board-up and repair, urgent lock changes for staff security, and master key system issues. William carries a range of commercial-grade locks and cylinders in his mobile workshop, so most commercial lock replacements are completed on the first visit. As a Metropolitan Police approved contractor, William is trusted to work on premises where security and evidence preservation are critical.' },
      },
      {
        '@type': 'Question',
        name: 'What should I do if my property has been broken into?',
        acceptedAnswer: { '@type': 'Answer', text: 'If your property has been broken into, call the police first on 999 (if intruders may still be present) or 101 (to report after the event). Do not touch or move anything until police have attended, as this preserves forensic evidence. Once the police have finished, call Bullard Locks on 07809 887 883. William can attend urgently to board up any damaged entry points, repair or replace compromised locks, and fit new British Standard BS3621 locks that satisfy home insurance requirements. Securing the property quickly is important to prevent repeat intrusions. William carries boarding materials and replacement locks as standard stock in his mobile workshop.' },
      },
    ],
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['.faq-answer'],
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.bullardlocks.com/' },
      { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://www.bullardlocks.com/services' },
      { '@type': 'ListItem', position: 3, name: 'Emergency Locksmith', item: 'https://www.bullardlocks.com/services/emergency-locksmith' },
    ],
  },
];
---

<BaseLayout
  title="Emergency Locksmith North London - 24/7 | Bullard Locks"
  description="Emergency locksmith near me - 24/7, 20-40 min response across North London. Lockouts, break-in repair, urgent lock changes. Met Police approved. No call-out fee."
  canonicalUrl="https://www.bullardlocks.com/services/emergency-locksmith"
  ogImage="https://www.bullardlocks.com/images/hero-emergency-locksmith.webp"
  schema={schema}
  preloadImage={heroImage}
>

  <!-- HERO -->
  <section class="loc-hero bg-dark">
    <div class="loc-hero-bg" style={`background-image: url('${heroImage}')`} aria-hidden="true"></div>
    <div class="loc-hero-overlay" aria-hidden="true"></div>
