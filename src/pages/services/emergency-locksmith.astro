      <div class="nearby-grid">
        <a href="/locations/haringey/emergency-locksmith" class="nearby-card">
          <div class="nearby-card-content">
            <h3 class="nearby-name">Haringey</h3>
            <p class="nearby-postcodes">N4, N8, N15, N17, N22</p>
            <p class="nearby-time"><i class="fas fa-clock"></i> 20–35 min</p>
          </div>
          <i class="fas fa-arrow-right nearby-arrow"></i>
        </a>
        <a href="/locations/barnet/emergency-locksmith" class="nearby-card">
          <div class="nearby-card-content">
            <h3 class="nearby-name">Barnet</h3>
            <p class="nearby-postcodes">EN5, N12, N20, NW4</p>
            <p class="nearby-time"><i class="fas fa-clock"></i> 25–40 min</p>
          </div>
          <i class="fas fa-arrow-right nearby-arrow"></i>
        </a>
        <a href="/locations/camden/emergency-locksmith" class="nearby-card">
          <div class="nearby-card-content">
            <h3 class="nearby-name">Camden</h3>
            <p class="nearby-postcodes">NW1, NW3, NW5, N1</p>
            <p class="nearby-time"><i class="fas fa-clock"></i> 20–35 min</p>
          </div>
          <i class="fas fa-arrow-right nearby-arrow"></i>
        </a>
        <a href="/locations/islington/emergency-locksmith" class="nearby-card">
          <div class="nearby-card-content">
            <h3 class="nearby-name">Islington</h3>
            <p class="nearby-postcodes">N1, N5, N7, EC1</p>
            <p class="nearby-time"><i class="fas fa-clock"></i> 20–35 min</p>
          </div>
          <i class="fas fa-arrow-right nearby-arrow"></i>
        </a>
        <a href="/locations/hackney/emergency-locksmith" class="nearby-card">
          <div class="nearby-card-content">
            <h3 class="nearby-name">Hackney</h3>
            <p class="nearby-postcodes">E5, E8, E9, N16</p>
            <p class="nearby-time"><i class="fas fa-clock"></i> 25–40 min</p>
          </div>
          <i class="fas fa-arrow-right nearby-arrow"></i>
        </a>
        <a href="/locations/enfield/emergency-locksmith" class="nearby-card">
          <div class="nearby-card-content">
            <h3 class="nearby-name">Enfield</h3>
            <p class="nearby-postcodes">EN1, EN2, EN3, N9</p>
            <p class="nearby-time"><i class="fas fa-clock"></i> 30–45 min</p>
          </div>
          <i class="fas fa-arrow-right nearby-arrow"></i>
        </a>
        <a href="/locations" class="nearby-card nearby-all">
