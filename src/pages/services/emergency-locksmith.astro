        <span class="feature-pill"><i class="fas fa-check"></i> Fixed price upfront</span>
        <span class="feature-pill"><i class="fas fa-check"></i> Non-destructive entry first</span>
        <span class="feature-pill"><i class="fas fa-check"></i> 24/7 availability</span>
        <span class="feature-pill"><i class="fas fa-check"></i> Residential & commercial</span>
        <span class="feature-pill"><i class="fas fa-check"></i> British Standard locks</span>
        <span class="feature-pill"><i class="fas fa-check"></i> Met Police approved</span>
        <span class="feature-pill"><i class="fas fa-check"></i> DBS checked</span>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="content-section bg-dark">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">How We Work</h2>
        <p class="section-subtitle">Three simple steps to get the problem sorted - fast.</p>
