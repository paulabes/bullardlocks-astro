---
import BaseLayout from '../layouts/BaseLayout.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import CTASection from '../components/CTASection.astro';
import ServiceCards from '../components/ServiceCards.astro';

const heroImage = '/images/william-bullard-trusted-london-locksmith.webp';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': ['WebPage', 'AboutPage'],
    name: 'About William Bullard - Bullard Locks',
    description: 'William Bullard is an independent North London locksmith with over 30 years of experience. Met Police approved, British Gas emergency contractor, DBS checked.',
    url: 'https://www.bullardlocks.com/about',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'William Bullard',
    jobTitle: 'Auto Locksmith & Safe Engineer',
    description: 'William Bullard is an independent auto locksmith and safe engineer based in Crouch End N8, North London. 30+ years experience. Metropolitan Police approved contractor and British Gas emergency access contractor.',
    worksFor: { '@type': ['LocalBusiness', 'LocksmithBusiness'], name: 'Bullard Locks', url: 'https://www.bullardlocks.com' },
    knowsAbout: ['Auto Locksmith', 'Car Key Replacement', 'Emergency Locksmith', 'Safe Engineer', 'Non-Destructive Entry'],
    address: {
      '@type': 'PostalAddress',
      streetAddress: '67 Weston Park',
      addressLocality: 'Crouch End',
      addressRegion: 'London',
      postalCode: 'N8 9TA',
      addressCountry: 'GB',
    },
    telephone: '+447809887883',
    url: 'https://www.bullardlocks.com/about',
    sameAs: [
      'https://www.bullardlocks.com',
      'https://g.page/bullardlocks',
      'https://www.linkedin.com/company/bullardlocks',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.bullardlocks.com/' },
      { '@type': 'ListItem', position: 2, name: 'About', item: 'https://www.bullardlocks.com/about' },
    ],
  },
];
---

<BaseLayout
  title="About William Bullard - Locksmith Crouch End N8 | Bullard Locks"
  description="William Bullard - auto locksmith & safe engineer, Crouch End N8. 30+ years, Met Police approved, British Gas contractor, DBS checked. Call 07809 887 883."
  canonicalUrl="https://www.bullardlocks.com/about"
  schema={schema}
  preloadImage={heroImage}
>

  <!-- HERO -->
  <section class="loc-hero bg-dark">
    <div class="loc-hero-bg" style={`background-image: url('${heroImage}')`} aria-hidden="true"></div>
    <div class="loc-hero-overlay" aria-hidden="true"></div>
    <div class="container-custom loc-hero-content">

      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span>About</span>
      </nav>

      <div class="loc-hero-grid">
        <div class="loc-hero-left">

          <h1 class="loc-hero-title">
            <span class="loc-hero-service">William Bullard</span>
            <span class="loc-hero-location">Independent London Locksmith</span>
          </h1>

          <p class="loc-hero-postcodes">
            <i class="fas fa-map-marker-alt"></i>
            Based in Crouch End N8 · Serving North London &amp; Beyond
          </p>

          <p class="loc-hero-lead">
            Over 30 years as North London's most trusted independent locksmith. Met Police approved, British Gas emergency contractor, and DBS checked. Where there's a Will, there's a way.
          </p>

          <div class="loc-hero-ctas">
            <a href="tel:07809887883" class="btn-hero-primary">
              <i class="fas fa-phone"></i> 07809 887 883
            </a>
            <a href="https://wa.me/447809887883" class="btn-hero-whatsapp" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> WhatsApp
            </a>
          </div>

          <div class="loc-trust-bar">
            <div class="loc-trust-item">
              <i class="fas fa-star"></i>
              <span>5.0 Google</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-shield-alt"></i>
              <span>Met Police Approved</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-award"></i>
              <span>30+ Years Experience</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-tag"></i>
              <span>No Call-Out Fee</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-check"></i>
              <span>Fully Insured</span>
            </div>
          </div>
        </div>

        <!-- Sticky contact panel -->
        <div class="loc-hero-panel">
          <div class="conv-panel">
            <div class="conv-panel-header">
              <i class="fas fa-phone"></i>
              <div>
                <p class="conv-panel-label">Call William now</p>
                <a href="tel:07809887883" class="conv-panel-number">07809 887 883</a>
              </div>
            </div>
            <p class="conv-panel-note">Or request a callback:</p>
            <form id="callback-form" class="conv-form">
              <input type="text" name="name" placeholder="Your name" class="conv-input" required />
              <input type="tel" name="phone" placeholder="Your phone number" class="conv-input" required />
              <input type="hidden" name="service" value="general" />
              <input type="hidden" name="form_type" value="callback" />
              <input type="hidden" name="message" value="Callback request from About page" />
              <button type="submit" class="conv-submit">
                <i class="fas fa-phone"></i> Request Callback
              </button>
              <div class="conv-form-status" style="display:none;"></div>
            </form>
            <a href="https://wa.me/447809887883" class="conv-whatsapp" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> Message on WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE STORY -->
  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="story-grid">
        <div class="story-image-wrap">
          <img
            src="/images/why-choose-bullard-locks.webp"
            alt="William Bullard - North London locksmith with 30 years experience"
            class="story-image"
            width="900"
            height="600"
            loading="lazy"
          />
        </div>
        <div class="story-content">
          <h2 class="section-title" style="text-align:left; margin-bottom: 20px;">My Story...</h2>

          <p class="story-text">
            I started my career as a locksmith over three decades ago, learning the trade from master craftsmen who taught me that security is about more than just locks and keys - it's about trust, reliability, and peace of mind.
          </p>

          <p class="story-text">
            Based in <strong>Crouch End, North London</strong>, I've spent 30 years getting to know the streets, properties, and people of this area. From the Victorian terraces of <a href="/locations/islington">Islington</a> to the mansion flats of <a href="/locations/camden">Hampstead</a>, I've seen - and solved - every kind of lock problem you can imagine.
          </p>

          <p class="story-text">
            What sets me apart from larger operations is simple: when you call Bullard Locks, you get me. Not a call centre, not a franchise operative - William Bullard, in person, at your door. Whether it's <a href="/services/auto-locksmith">car key replacement</a>, an <a href="/services/emergency-locksmith">emergency lockout</a>, or <a href="/services/safe-engineer">safe engineering</a>, I carry out all the work myself - consistent standards and someone who stands behind every job.
          </p>

          <p class="story-text">
            My work has been trusted by the <strong>Metropolitan Police</strong>, by <strong>British Gas</strong> as an approved emergency access contractor, and by thousands of homeowners and businesses across North London.
          </p>

          <blockquote class="story-quote">
            <i class="fas fa-quote-left"></i>
            Where there's a Will, there's a way!
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE WILLIAM -->
  <section class="content-section bg-light">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Why Choose <span class="text-accent">William</span></h2>
        <p class="section-subtitle">What makes working with an independent locksmith different.</p>
      </div>

      <div class="credentials-grid">
        <div class="cred-card">
          <div class="cred-icon"><i class="fas fa-user"></i></div>
          <h3 class="cred-title">One Person, Every Job</h3>
          <p class="cred-desc">No call centres, no subcontractors. When you book Bullard Locks, William turns up in person - consistent quality on every job.</p>
        </div>
        <div class="cred-card">
          <div class="cred-icon"><i class="fas fa-tag"></i></div>
          <h3 class="cred-title">Honest, Fixed Pricing</h3>
          <p class="cred-desc">You get a firm quote before any work starts. No call-out fee, no hidden charges, no surprises. The price agreed is the price you pay.</p>
        </div>
        <div class="cred-card">
          <div class="cred-icon"><i class="fas fa-lock-open"></i></div>
          <h3 class="cred-title">Non-Destructive Entry</h3>
          <p class="cred-desc">30 years of technique means gaining entry without damage in the vast majority of cases - saving you the cost of replacement locks and doors.</p>
        </div>
        <div class="cred-card">
          <div class="cred-icon"><i class="fas fa-map-marker-alt"></i></div>
          <h3 class="cred-title">Truly Local</h3>
          <p class="cred-desc">Based in Crouch End N8 for over three decades. William knows the streets, the properties and the community - not a national franchise.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUSTED PARTNERSHIPS -->
  <section class="content-section bg-dark">
    <div class="container-custom">
      <div class="section-header">
        <div class="bg-section-badge">
          <i class="fas fa-handshake"></i>
          <span>Trusted Partnerships</span>
        </div>
        <h2 class="section-title" style="color:white;">Approved by the Met Police &amp; British Gas</h2>
        <p class="section-subtitle" style="color:rgba(255,255,255,0.7);">William is one of a small number of locksmiths in London approved by both organisations - a reflection of three decades of trust, integrity and skill.</p>
      </div>

      <div class="tp-columns">
        <div class="tp-col">
          <div class="tp-col-icon"><i class="fas fa-shield-alt"></i></div>
          <h3 class="tp-col-title">Metropolitan Police</h3>
          <p class="bg-section-text">
            As a Metropolitan Police approved contractor, William is called upon for lock-related work where security, evidence preservation and discretion are critical. The Met's vetting process is rigorous - covering criminal record checks, professional references, insurance verification and ongoing performance review.
          </p>
        </div>
        <div class="tp-col">
          <div class="tp-col-icon tp-col-icon-gas"><i class="fas fa-fire"></i></div>
          <h3 class="tp-col-title">British Gas</h3>
          <p class="bg-section-text">
            As an emergency access contractor for British Gas for over 20 years, William gains entry to properties when engineers need urgent access - for gas leaks, meter readings, or safety inspections. Every entry is non-destructive, and every property is re-secured before he leaves.
          </p>
        </div>
      </div>

      <div class="tp-features-row">
        <div class="bg-aside-card">
          <div class="bg-aside-icon"><i class="fas fa-shield-alt"></i></div>
          <h3>Met Police Approved</h3>
          <p>Vetted to the highest standards</p>
        </div>
        <div class="bg-aside-card">
          <div class="bg-aside-icon bg-aside-icon-gas"><i class="fas fa-fire"></i></div>
          <h3>British Gas Emergency Contractor</h3>
          <p>Emergency contractor for 20+ years</p>
        </div>
        <div class="bg-aside-card">
          <div class="bg-aside-icon"><i class="fas fa-lock-open"></i></div>
          <h3>Non-Destructive Entry</h3>
          <p>No damage to your property</p>
        </div>
        <div class="bg-aside-card">
          <div class="bg-aside-icon"><i class="fas fa-user-check"></i></div>
          <h3>Fully Vetted &amp; Insured</h3>
          <p>DBS checked and security cleared</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Services Offered</h2>
        <p class="section-subtitle">Three specialist services - all provided personally by William Bullard.</p>
      </div>

      <ServiceCards />
    </div>
  </section>

  <GoogleReviews bg="light" />

  <CTASection
    title="Work with North London's Most Trusted Locksmith"
    subtitle="30+ years experience | Met Police approved | No call-out fee | 24/7 emergency availability"
  />

</BaseLayout>

<style>
  /* HERO */
  .loc-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding-top: var(--header-height);
    overflow: hidden;
  }

  .loc-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center top;
    filter: brightness(0.2) saturate(0.7);
  }

  .loc-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(14, 74, 77, 0.85) 0%, rgba(0, 0, 0, 0.65) 100%);
  }

  .loc-hero-content {
    position: relative;
    z-index: 1;
    padding-top: 60px;
    padding-bottom: 80px;
  }

  .loc-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .loc-breadcrumb a { color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s; }
  .loc-breadcrumb a:hover { color: white; }
  .loc-breadcrumb span:last-child { color: var(--color-accent); font-weight: 500; }

  .loc-hero-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 60px;
    align-items: start;
  }

  .loc-hero-badges { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px; }

  .loc-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
    background: rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.9);
    border: 1px solid rgba(255,255,255,0.2);
  }

  .loc-badge-accent { background: rgba(31, 174, 155, 0.25); color: #7fe8d8; border-color: rgba(31, 174, 155, 0.4); }

  .loc-hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 16px;
    display: flex;
    flex-direction: column;
  }

  .loc-hero-service { color: var(--color-accent); }
  .loc-hero-location { color: white; }

  .loc-hero-postcodes { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.65); font-size: 0.9rem; margin: 0 0 16px; }
  .loc-hero-postcodes i { color: var(--color-accent); }

  .loc-hero-lead { color: rgba(255,255,255,0.8); font-size: 1.1rem; line-height: 1.6; margin: 0 0 32px; max-width: 560px; }

  .loc-hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }

  .btn-hero-primary {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 16px 28px; background: var(--color-accent); color: white;
    border-radius: 100px; font-weight: 700; font-size: 1.05rem;
    text-decoration: none; transition: all 0.2s ease;
    box-shadow: 0 4px 20px rgba(31, 174, 155, 0.4);
  }

  .btn-hero-primary:hover { background: var(--color-accent-hover); transform: translateY(-2px); box-shadow: 0 8px 30px rgba(31, 174, 155, 0.5); }

  .btn-hero-whatsapp {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 16px 28px; background: #25D366; color: white;
    border: none; border-radius: 100px;
    font-weight: 600; font-size: 1rem; text-decoration: none;
    box-shadow: 0 4px 16px rgba(37,211,102,0.35); transition: all 0.2s ease;
  }
  .btn-hero-whatsapp:hover { background: #1DA851; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(37,211,102,0.45); }

  .loc-trust-bar { display: flex; gap: 0; flex-wrap: wrap; }
  .loc-trust-item { display: flex; align-items: center; gap: 8px; padding: 0 16px; font-size: 0.85rem; color: rgba(255,255,255,0.7); font-weight: 500; }
  .loc-trust-item:first-child { padding-left: 0; }
  .loc-trust-item + .loc-trust-item { border-left: 1px solid rgba(255,255,255,0.28); }
  .loc-trust-item i { color: var(--color-accent); font-size: 0.9rem; }

  /* Conversion Panel */
  .conv-panel { background: white; border-radius: 20px; padding: 28px; box-shadow: 0 20px 60px rgba(0,0,0,0.25); position: sticky; top: 100px; }

  .conv-panel-header { display: flex; align-items: center; gap: 16px; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid rgba(0,0,0,0.07); }

  .conv-panel-header > i { width: 44px; height: 44px; background: rgba(31, 174, 155, 0.1); color: var(--color-accent); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }

  .conv-panel-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); margin: 0; font-weight: 600; }
  .conv-panel-number { font-size: 1.4rem; font-weight: 800; color: var(--color-text-main); text-decoration: none; display: block; line-height: 1; margin-top: 2px; }
  .conv-panel-number:hover { color: var(--color-accent); }
  .conv-panel-note { font-size: 0.875rem; color: var(--color-text-muted); margin: 0 0 16px; }

  .conv-form { display: flex; flex-direction: column; gap: 12px; }

  .conv-input { width: 100%; padding: 12px 16px; border: 1.5px solid rgba(0,0,0,0.1); border-radius: 100px; font-size: 0.95rem; font-family: var(--font-body); transition: border-color 0.2s; background: var(--color-bg-light); }
  .conv-input:focus { outline: none; border-color: var(--color-accent); background: white; }

  .conv-submit { width: 100%; padding: 14px; background: var(--color-accent); color: white; border: none; border-radius: 100px; font-size: 0.95rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background 0.2s; font-family: var(--font-body); }
  .conv-submit:hover { background: var(--color-accent-hover); }

  .conv-form-status { font-size: 0.875rem; padding: 10px 12px; border-radius: 8px; }
  .conv-form-status.success { background: rgba(31,174,155,0.1); color: #0e6b5e; }
  .conv-form-status.error { background: rgba(220,38,38,0.05); color: #dc2626; }

  .conv-whatsapp { display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 12px; padding: 12px; background: #25d366; color: white; border-radius: 100px; font-weight: 600; font-size: 0.9rem; text-decoration: none; transition: background 0.2s; }
  .conv-whatsapp:hover { background: #1db954; }

  /* Story section */
  .story-grid {
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: 60px;
    align-items: start;
  }

  .story-image-wrap {
    border-radius: 20px;
    overflow: hidden;
    position: sticky;
    top: 100px;
  }

  .story-image {
    width: 100%;
    height: 500px;
    object-fit: cover;
    display: block;
  }

  .story-text {
    color: var(--color-text-muted);
    line-height: 1.75;
    font-size: 1rem;
    margin: 0 0 18px;
  }

  .story-text a {
    color: var(--color-accent);
    text-decoration: none;
    transition: text-decoration-color 0.2s;
  }
  .story-text a:hover { text-decoration: underline; }

  .story-quote {
    margin: 32px 0 0;
    padding: 20px 24px;
    background: rgba(31, 174, 155, 0.06);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 12px 12px 0;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text-main);
    font-style: italic;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .story-quote i { color: var(--color-accent); font-size: 1.3rem; flex-shrink: 0; }

  /* Credentials */
  .credentials-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .cred-card {
    background: white;
    border-radius: 16px;
    padding: 28px 24px;
    border: 1px solid rgba(0,0,0,0.06);
    text-align: center;
    transition: all 0.2s ease;
  }

  .cred-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); border-color: var(--color-accent); }

  .cred-icon {
    width: 56px; height: 56px;
    background: rgba(31, 174, 155, 0.1);
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    color: var(--color-accent);
    font-size: 1.4rem;
    margin: 0 auto 18px;
  }

  .cred-title { font-size: 1rem; font-weight: 700; margin: 0 0 10px; color: var(--color-text-main); }
  .cred-desc { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.6; margin: 0; }

  /* Trusted Partnerships */
  .bg-section-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #7fe8d8;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .tp-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }

  .tp-col-icon {
    width: 52px; height: 52px;
    background: rgba(29, 78, 216, 0.2);
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    color: #93c5fd;
    font-size: 1.3rem;
    margin-bottom: 20px;
  }

  .tp-col-icon-gas {
    background: rgba(0, 114, 206, 0.2);
    color: #7dd3fc;
  }

  .tp-col-title {
    font-size: 1.2rem;
    font-weight: 800;
    color: white;
    margin: 0 0 14px;
  }

  .bg-section-text {
    color: rgba(255,255,255,0.75);
    line-height: 1.75;
    font-size: 0.975rem;
    margin: 0;
  }

  .tp-features-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .bg-aside-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 20px;
    text-align: center;
  }

  .bg-aside-icon {
    width: 44px; height: 44px;
    background: rgba(31, 174, 155, 0.2);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    color: var(--color-accent);
    font-size: 1.1rem;
    margin: 0 auto 12px;
  }

  .bg-aside-icon-gas {
    background: rgba(0, 114, 206, 0.2);
    color: #7dd3fc;
  }

  .bg-aside-card h3 { font-size: 0.95rem; font-weight: 800; color: white; margin: 0 0 6px; }
