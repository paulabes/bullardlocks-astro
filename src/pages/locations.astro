---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import ServiceCards from '../components/ServiceCards.astro';
import { boroughs, servicesMeta } from '../data/locations';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Auto Locksmith London - Service Locations by Borough",
    "description": "Bullard Locks covers North and Central London boroughs for auto locksmith, emergency locksmith and safe engineer services.",
    "url": "https://bullardlocks.com/locations",
    "itemListElement": boroughs.map((b, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "LocksmithBusiness",
        "name": `Bullard Locks - ${b.name}`,
        "url": `https://bullardlocks.com/locations/${b.slug}`,
        "areaServed": b.name
      }
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://bullardlocks.com/"},
      {"@type": "ListItem", "position": 2, "name": "Locations", "item": "https://bullardlocks.com/locations"}
    ]
  }
];
---

<BaseLayout
  title="Locksmith London - All Boroughs & Services | Bullard Locks"
  description="Auto locksmith near me - find your local locksmith across North and Central London. Choose your borough for local coverage, pricing and response times. No call-out fee."
  canonicalUrl="https://bullardlocks.com/locations"
  schema={schema}
  preloadImage="/images/hero-emergency-locksmith.webp"
>
  <!-- HERO -->
  <section class="loc-hero bg-dark">
    <div class="loc-hero-bg" style="background-image: url('/images/hero-emergency-locksmith.webp')" aria-hidden="true"></div>
    <div class="loc-hero-overlay" aria-hidden="true"></div>
    <div class="container-custom lh-content">
      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span>Locations</span>
      </nav>

      <div class="loc-hero-grid">
        <div class="loc-hero-left">
          <h1 class="loc-hero-title">
            <span class="loc-hero-service">Auto, Emergency & Safe Engineer</span>
            <span class="loc-hero-location">London Locksmith</span>
            <span class="loc-hero-sub">Select Your Borough</span>
          </h1>

          <p class="loc-hero-lead">
            Bullard Locks covers North and Central London for auto locksmith, emergency locksmith and safe engineer services.
            Select your borough below for local response times, coverage areas and pricing.
          </p>

          <div class="loc-hero-ctas">
            <a href="tel:07809887883" class="btn-hero-primary">
              <i class="fas fa-phone"></i> 07809 887 883
            </a>
            <a href="https://wa.me/447809887883" class="btn-hero-whatsapp" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> WhatsApp
            </a>
          </div>

          <div class="loc-trust-bar">
            <div class="loc-trust-item"><i class="fas fa-star"></i><span>5.0 Google</span></div>
            <div class="loc-trust-item"><i class="fas fa-shield-alt"></i><span>Met Police Approved</span></div>
            <div class="loc-trust-item"><i class="fas fa-award"></i><span>30+ Years Experience</span></div>
            <div class="loc-trust-item"><i class="fas fa-tag"></i><span>No Call-Out Fee</span></div>
            <div class="loc-trust-item"><i class="fas fa-check"></i><span>Fully Insured</span></div>
          </div>
        </div>

        <div class="loc-hero-panel">
          <div class="conv-panel">
            <div class="conv-panel-header">
              <i class="fas fa-phone"></i>
              <div>
                <p class="conv-panel-label">Call us now</p>
                <a href="tel:07809887883" class="conv-panel-number">07809 887 883</a>
              </div>
            </div>
            <p class="conv-panel-note">Or request a callback:</p>
            <form id="callback-form" class="conv-form">
              <input type="text" name="name" placeholder="Your name" class="conv-input" required />
              <input type="tel" name="phone" placeholder="Your phone number" class="conv-input" required />
              <input type="hidden" name="service" value="general" />
              <input type="hidden" name="form_type" value="callback" />
              <input type="hidden" name="message" value="Callback request from Locations page" />
              <button type="submit" class="conv-submit">
                <i class="fas fa-phone"></i> Request Callback
              </button>
              <div class="conv-form-status" style="display:none;"></div>
            </form>
            <a href="https://wa.me/447809887883" class="conv-whatsapp" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> Message on WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service × Borough quick links table -->
  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Service Availability</h2>
        <p class="section-subtitle">Select your location to see local response times, coverage and pricing.</p>
      </div>

      <div class="service-matrix">
        <!-- Header -->
        <div class="matrix-header">
          <div class="matrix-cell matrix-corner">Borough</div>
          {Object.values(servicesMeta).map(sm => (
            <div class="matrix-cell matrix-service-head">
              <span>{sm.name}</span>
            </div>
          ))}
        </div>

        {boroughs.map(borough => (
          <div class="matrix-row">
            <div class="matrix-cell matrix-borough-cell">
              <a href={`/locations/${borough.slug}`} class="matrix-borough-link">
                <span>{borough.name}</span>
                <span class="matrix-response">{borough.responseTime}</span>
              </a>
            </div>
            {(['auto-locksmith', 'emergency-locksmith', 'safe-engineer'] as const).map(serviceSlug => (
              <div class="matrix-cell matrix-service-cell">
                {borough.services.includes(serviceSlug) ? (
                  <a href={`/locations/${borough.slug}/${serviceSlug}`} class="matrix-available">
                    <i class="fas fa-check"></i>
                  </a>
                ) : (
                  <span class="matrix-na" title="Not available in this area">-</span>
                )}
              </div>
            ))}
          </div>
        ))}

        <div class="matrix-row">
          <div class="matrix-cell matrix-borough-cell">
            <a href="/locations/uk-wide/safe-engineer" class="matrix-borough-link">
              <span>UK-Wide</span>
              <span class="matrix-response">By appointment</span>
            </a>
          </div>
          {(['auto-locksmith', 'emergency-locksmith', 'safe-engineer'] as const).map(serviceSlug => (
            <div class="matrix-cell matrix-service-cell">
              {serviceSlug === 'safe-engineer' ? (
                <a href="/locations/uk-wide/safe-engineer" class="matrix-available">
                  <i class="fas fa-check"></i>
                </a>
              ) : (
                <span class="matrix-na" title="Not available">-</span>
              )}
            </div>
          ))}
        </div>
      </div>

      <p class="matrix-note">
        <i class="fas fa-info-circle"></i>
        Emergency locksmith is available in North London boroughs only. Auto locksmith and safe engineer cover all listed boroughs.
      </p>
    </div>
  </section>

  <!-- Services overview -->
  <section class="content-section bg-light">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Professional <span class="text-accent">Locksmith Services</span></h2>
        <p class="section-subtitle">Expert security solutions for vehicles, homes and businesses - rapid response across London.</p>
      </div>
      <ServiceCards />
    </div>
  </section>

  <CTASection
    title="Not Sure If We Cover Your Area?"
    subtitle="Call us on 07809 887 883 or WhatsApp - we'll let you know our response time for your exact location."
  />
</BaseLayout>

<style>
  /* Hero */
  .loc-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding-top: var(--header-height);
    overflow: hidden;
  }

  .loc-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: brightness(0.25) saturate(0.8);
  }

  .loc-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(14, 74, 77, 0.85) 0%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  .lh-content {
    position: relative;
    z-index: 1;
    padding-top: 60px;
    padding-bottom: 80px;
  }

  .loc-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .loc-breadcrumb a {
    color: rgba(255,255,255,0.6);
    text-decoration: none;
  }

  .loc-breadcrumb a:hover { color: white; }
  .loc-breadcrumb span:last-child { color: var(--color-accent); }

  .loc-hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 32px;
    display: flex;
    flex-direction: column;
  }

  .loc-hero-service { color: var(--color-accent); }
  .loc-hero-location { color: white; }

  .loc-hero-sub {
    font-size: clamp(1rem, 2.2vw, 1.4rem);
    font-weight: 400;
    color: rgba(255,255,255,0.6);
    font-family: var(--font-body);
    margin-top: 8px;
  }

  .loc-hero-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 60px;
    align-items: start;
  }

  .loc-hero-lead {
    color: rgba(255,255,255,0.8);
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0 0 32px;
    max-width: 560px;
  }

  .loc-hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .loc-trust-bar { display: flex; gap: 0; flex-wrap: wrap; }
  .loc-trust-item { display: flex; align-items: center; gap: 8px; padding: 0 16px; font-size: 0.85rem; color: rgba(255,255,255,0.7); font-weight: 500; }
  .loc-trust-item:first-child { padding-left: 0; }
  .loc-trust-item + .loc-trust-item { border-left: 1px solid rgba(255,255,255,0.28); }
  .loc-trust-item i { color: var(--color-accent); font-size: 0.9rem; }

  .conv-panel { background: white; border-radius: 20px; padding: 28px; box-shadow: 0 20px 60px rgba(0,0,0,0.25); position: sticky; top: 100px; }
  .conv-panel-header { display: flex; align-items: center; gap: 16px; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid rgba(0,0,0,0.07); }
  .conv-panel-header > i { width: 44px; height: 44px; background: rgba(31, 174, 155, 0.1); color: var(--color-accent); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }
  .conv-panel-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); margin: 0; font-weight: 600; }
  .conv-panel-number { font-size: 1.4rem; font-weight: 800; color: var(--color-text-main); text-decoration: none; display: block; line-height: 1; margin-top: 2px; }
  .conv-panel-number:hover { color: var(--color-accent); }
  .conv-panel-note { font-size: 0.875rem; color: var(--color-text-muted); margin: 0 0 16px; }
  .conv-form { display: flex; flex-direction: column; gap: 12px; }
  .conv-input { width: 100%; padding: 12px 16px; border: 1.5px solid rgba(0,0,0,0.1); border-radius: 100px; font-size: 0.95rem; font-family: var(--font-body); transition: border-color 0.2s; background: var(--color-bg-light); }
  .conv-input:focus { outline: none; border-color: var(--color-accent); background: white; }
  .conv-submit { width: 100%; padding: 14px; background: var(--color-accent); color: white; border: none; border-radius: 100px; font-size: 0.95rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background 0.2s; font-family: var(--font-body); }
  .conv-submit:hover { background: var(--color-accent-hover); }
  .conv-form-status { font-size: 0.875rem; padding: 10px 12px; border-radius: 8px; }
  .conv-form-status.success { background: rgba(31,174,155,0.1); color: #0e6b5e; }
  .conv-form-status.error { background: rgba(220,38,38,0.05); color: #dc2626; }
  .conv-whatsapp { display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 12px; padding: 12px; background: #25d366; color: white; border-radius: 100px; font-weight: 600; font-size: 0.9rem; text-decoration: none; transition: background 0.2s; }
  .conv-whatsapp:hover { background: #1db954; }

  .btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
    background: var(--color-accent);
    color: white;
    border-radius: 100px;
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: 0 4px 20px rgba(31, 174, 155, 0.4);
  }

  .btn-hero-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(31, 174, 155, 0.5);
  }

  .btn-hero-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
    background: #25D366;
    color: white;
    border: none;
    border-radius: 100px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(37,211,102,0.35);
    transition: all 0.2s ease;
  }

  .btn-hero-whatsapp:hover {
    background: #1DA851;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(37,211,102,0.45);
  }

  /* Matrix */
  .service-matrix {
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 16px;
  }

  .matrix-header,
  .matrix-row {
    display: grid;
    grid-template-columns: 200px repeat(3, 1fr);
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .matrix-row:last-child { border-bottom: none; }
  .matrix-row:nth-child(even) { background: var(--color-bg-light); }

  .matrix-cell {
    padding: 14px 16px;
    display: flex;
    align-items: center;
    border-right: 1px solid rgba(0,0,0,0.06);
  }

  .matrix-cell:last-child { border-right: none; }

  .matrix-corner {
    background: var(--color-bg-dark);
    color: rgba(255,255,255,0.6);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  .matrix-service-head {
    background: var(--color-bg-dark);
    justify-content: center;
    text-align: center;
  }

  .matrix-service-head span {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255,255,255,0.6);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .matrix-borough-cell {
    padding: 10px 16px;
  }

  .matrix-borough-link {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .matrix-borough-link span:first-child {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-main);
  }

  .matrix-borough-link:hover span:first-child {
    color: var(--color-accent);
  }

  .matrix-response {
    font-size: 0.75rem;
    color: var(--color-text-muted-light);
    font-weight: 400;
  }

  .matrix-service-cell {
    justify-content: center;
  }

  .matrix-available {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(31, 174, 155, 0.1);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .matrix-available:hover {
    background: var(--color-accent);
    color: white;
    transform: scale(1.1);
  }

  .matrix-na {
    color: var(--color-text-muted-light);
    font-size: 1.1rem;
  }

  .matrix-note {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: flex-start;
    gap: 8px;
    line-height: 1.5;
  }

  .matrix-note i {
    color: var(--color-accent);
    margin-top: 2px;
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 992px) {
    .loc-hero-grid { grid-template-columns: 1fr; }
    .loc-hero-panel { display: none; }
    .matrix-header,
    .matrix-row {
      grid-template-columns: 140px repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .loc-trust-bar { gap: 12px; }
    .loc-trust-item { padding: 0; border-left: none; }
  }

  @media (max-width: 768px) {
    .matrix-header,
    .matrix-row {
      grid-template-columns: 120px repeat(3, 1fr);
    }
    .matrix-cell {
      padding: 10px 10px;
    }
    .matrix-service-head span {
      font-size: 0.65rem;
      letter-spacing: 0;
    }
  }

  @media (max-width: 640px) {
    .loc-hero { min-height: auto; }
    .lh-content { padding-top: 40px; padding-bottom: 48px; }
    .loc-hero-title { font-size: clamp(1.8rem, 7vw, 2.4rem); }
    .loc-hero-lead { font-size: 0.95rem; }
    .matrix-header,
    .matrix-row {
      grid-template-columns: 100px repeat(3, 1fr);
    }
    .matrix-borough-link span:first-child { font-size: 0.8rem; }
    .matrix-response { font-size: 0.65rem; }
  }
</style>

<script>
  const callbackForm = document.getElementById('callback-form') as HTMLFormElement;
  callbackForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const status = callbackForm.querySelector('.conv-form-status') as HTMLDivElement;
    const btn = callbackForm.querySelector('.conv-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';
    try {
      const fd = new FormData(callbackForm);
      const payload: Record<string, string> = {};
      fd.forEach((v, k) => { payload[k] = v as string; });
      payload.type = payload.form_type || 'callback';
      const res = await fetch('/api/send-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (data.success) {
        status.className = 'conv-form-status success';
        status.textContent = 'Received! William will call you back shortly.';
        status.style.display = 'block';
        callbackForm.reset();
      } else {
        status.className = 'conv-form-status error';
        status.textContent = data.error || 'Something went wrong. Please call us directly.';
        status.style.display = 'block';
      }
    } catch (err) {
      console.error('Callback error:', err);
      status.className = 'conv-form-status error';
      status.textContent = 'Something went wrong. Please call us directly.';
      status.style.display = 'block';
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-phone"></i> Request Callback';
    }
  });

  const waLink = document.querySelector('.conv-whatsapp') as HTMLAnchorElement;
  waLink?.addEventListener('click', (e) => {
    const name = (callbackForm?.querySelector('[name="name"]') as HTMLInputElement)?.value?.trim();
    const phone = (callbackForm?.querySelector('[name="phone"]') as HTMLInputElement)?.value?.trim();
    if (name || phone) {
      e.preventDefault();
      const msg = `Hi, I'd like to request a callback. Name: ${name || 'not provided'}, Phone: ${phone || 'not provided'}`;
      window.open(`https://wa.me/447809887883?text=${encodeURIComponent(msg)}`, '_blank');
    }
  });
</script>
