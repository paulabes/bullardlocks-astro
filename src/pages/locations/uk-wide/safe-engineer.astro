---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GoogleReviews from '../../../components/GoogleReviews.astro';
import CTASection from '../../../components/CTASection.astro';

const heroImage = '/images/hero-safe-engineer.webp';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Safe Engineer UK-Wide',
    serviceType: ['Safe Opening', 'Safe Cracking', 'Safe Installation', 'Safe Repair', 'Combination Change'],
    provider: {
      '@type': ['LocalBusiness', 'LocksmithBusiness'],
      name: 'Bullard Locks',
      telephone: '+447809887883',
      url: 'https://www.bullardlocks.com',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '67 Weston Park',
        addressLocality: 'Crouch End',
        addressRegion: 'London',
        postalCode: 'N8 9TA',
        addressCountry: 'GB',
      },
    },
    areaServed: {'@type': 'Country', 'name': 'United Kingdom'},
    description: 'Professional safe engineer (safe cracker) UK-wide by appointment. Non-destructive safe opening, installation, combination changes & repair. All major brands. 30+ years experience. Call 07809 887 883.',
    url: 'https://www.bullardlocks.com/locations/uk-wide/safe-engineer',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Do you travel outside London for safe engineer work?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. William regularly travels anywhere in the UK for safe engineering work. This specialist service is available nationwide by appointment - from Edinburgh to Bristol, Cardiff to Belfast.' },
      },
      {
        '@type': 'Question',
        name: 'How far will you travel for a safe engineer appointment?',
        acceptedAnswer: { '@type': 'Answer', text: 'There is no fixed distance limit. William has travelled across England, Scotland, Wales and Northern Ireland for safe engineering work. Call to discuss your location and we will arrange a visit.' },
      },
      {
        '@type': 'Question',
        name: 'How does the appointment process work?',
        acceptedAnswer: { '@type': 'Answer', text: 'Contact us by phone or email, describe your safe and the issue. We will confirm availability, provide a fixed written quote including any travel, and agree a convenient date. William attends on the agreed day and resolves the problem on site in most cases.' },
      },
      {
        '@type': 'Question',
        name: 'Do you charge for travel to locations outside London?',
        acceptedAnswer: { '@type': 'Answer', text: 'Travel costs for UK-wide appointments are included in the written quote provided before work begins. There are no hidden charges - the price you are quoted is the price you pay.' },
      },
      {
        '@type': 'Question',
        name: 'What safe brands do you work with?',
        acceptedAnswer: { '@type': 'Answer', text: 'All major manufacturers including Chubb, Phoenix, Dudley, Yale, Burton, SentrySafe, Honeywell, Securikey, Fichet, De Raat, and many more. Call to confirm your specific safe make and model.' },
      },
      {
        '@type': 'Question',
        name: 'How long does a UK-wide safe engineer visit take?',
        acceptedAnswer: { '@type': 'Answer', text: 'Non-destructive opening typically takes 30 minutes to a few hours depending on the safe type and locking mechanism. A realistic time estimate is provided at the quoting stage. Work is completed on site in most cases during a single visit.' },
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.bullardlocks.com/' },
      { '@type': 'ListItem', position: 2, name: 'Locations', item: 'https://www.bullardlocks.com/locations' },
      { '@type': 'ListItem', position: 3, name: 'UK-Wide Safe Engineer', item: 'https://www.bullardlocks.com/locations/uk-wide/safe-engineer' },
    ],
  },
];
---

<BaseLayout
  title="Safe Engineer UK-Wide - Opening & Installation | Bullard Locks"
  description="Safe engineer near me - safe cracker UK-wide by appointment. Non-destructive safe opening, installation & combination changes. All brands. 30+ years. 07809 887 883."
  canonicalUrl="https://www.bullardlocks.com/locations/uk-wide/safe-engineer"
  ogImage="https://www.bullardlocks.com/images/hero-safe-engineer.webp"
  schema={schema}
  preloadImage={heroImage}
>

  <!-- HERO -->
  <section class="loc-hero bg-dark">
    <div class="loc-hero-bg" style={`background-image: url('${heroImage}')`} aria-hidden="true"></div>
    <div class="loc-hero-overlay" aria-hidden="true"></div>
    <div class="container-custom loc-hero-content">

      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/locations">Locations</a>
        <span aria-hidden="true">/</span>
        <span>UK-Wide</span>
        <span aria-hidden="true">/</span>
        <span>Safe Engineer</span>
      </nav>

      <div class="loc-hero-grid">
        <div class="loc-hero-left">
          <h1 class="loc-hero-title">
            <span class="loc-hero-service">Safe Engineer</span>
            <span class="loc-hero-location">UK-Wide</span>
          </h1>

          <p class="loc-hero-postcodes">
            <i class="fas fa-map-marker-alt"></i>
            All UK postcodes - nationwide service by appointment
          </p>

          <p class="loc-hero-lead">
            William Bullard is a professional safe engineer with over 30 years of experience, available anywhere in the UK by appointment. Non-destructive safe opening, installation, combination changes, and repair - for all major brands, from London to Edinburgh, Cardiff to Belfast.
          </p>

          <div class="loc-hero-ctas">
            <a href="tel:07809887883" class="btn-hero-primary">
              <i class="fas fa-phone"></i> 07809 887 883
            </a>
            <a href="https://wa.me/447809887883" class="btn-hero-whatsapp" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> WhatsApp
            </a>
          </div>

          <div class="loc-trust-bar">
            <div class="loc-trust-item">
              <i class="fas fa-star"></i>
              <span>5.0 Google</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-shield-alt"></i>
              <span>Met Police Approved</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-award"></i>
              <span>30+ Years Experience</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-tag"></i>
              <span>No Call-Out Fee</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-check"></i>
              <span>Fully Insured</span>
            </div>
          </div>
        </div>

        <!-- Sticky conversion panel -->
        <div class="loc-hero-panel">
          <div class="conv-panel">
            <div class="conv-panel-header">
              <i class="fas fa-phone"></i>
              <div>
                <p class="conv-panel-label">Call us now</p>
                <a href="tel:07809887883" class="conv-panel-number">07809 887 883</a>
              </div>
            </div>
            <p class="conv-panel-note">Or request a callback:</p>
            <form id="callback-form" class="conv-form">
              <input type="text" name="name" placeholder="Your name" class="conv-input" required />
              <input type="tel" name="phone" placeholder="Your phone number" class="conv-input" required />
              <input type="hidden" name="service" value="safe-engineer" />
              <input type="hidden" name="location" value="UK-Wide" />
              <input type="hidden" name="form_type" value="callback" />
              <input type="hidden" name="message" value="Callback request for Safe Engineer UK-Wide" />
              <button type="submit" class="conv-submit">
                <i class="fas fa-phone"></i> Request Callback
              </button>
              <div class="conv-form-status" style="display:none;"></div>
            </form>
            <a href="https://wa.me/447809887883" class="conv-whatsapp" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> Message on WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AREA CONTENT -->
  <section class="content-section bg-light">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">A Safe Engineer Who Travels to You</h2>
      </div>
      <div class="area-content-grid">
        <div class="area-content-image">
          <img src="/images/why-choose-bullard-locks.webp" alt="William Bullard, safe engineer with specialist tools" width="900" height="600" loading="lazy" />
          <a href="https://www.google.com/maps/place/?q=place_id:ChIJU7O3P5IbdkgRVm-wppoH9-4" target="_blank" rel="noopener noreferrer" class="area-star-card">
            <div class="area-star-icon"><i class="fas fa-star"></i></div>
            <div class="area-star-text">
              <span class="area-star-rating">5.0 on Google</span>
              <span class="area-star-source">Read our reviews</span>
            </div>
          </a>
        </div>
        <div class="area-content-text">
          <p class="area-paragraph">Most locksmiths won't travel far for safe work - and most who advertise "UK-wide" are call centres who send whoever is nearest. William Bullard travels personally to every safe engineering job, bringing over 30 years of specialist experience and a fully equipped vehicle to your door, wherever you are in the UK.</p>
          <p class="area-paragraph">William's approach is always non-destructive first. Using manipulation techniques and specialist tooling, he aims to open your safe without drilling or cutting - preserving it for continued use. When destructive entry is the only option, he's upfront about it before starting. Every job begins with a clear, written quote - no surprises.</p>
          <p class="area-paragraph">Based in Crouch End N8, North London, William provides priority response across London and the Home Counties, with nationwide appointments arranged at times that suit you. He handles all major brands including Chubb, Phoenix, Dudley, Yale, Burton and SentrySafe - from compact home fire safes to large commercial vault units.</p>
        </div>
      </div>
      <div class="area-content-ctas">
        <a href="tel:07809887883" class="btn-primary-lg">
          <i class="fas fa-phone"></i> 07809 887 883
        </a>
        <a href="https://wa.me/447809887883" class="btn-whatsapp-lg" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-whatsapp"></i> WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- SERVICES DETAIL -->
  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Safe Engineer Services - UK-Wide</h2>
        <p class="section-subtitle">Comprehensive safe engineering for homes and businesses across the whole of the UK. All major brands. By appointment.</p>
      </div>

      <div class="services-4-grid">
        <div class="service-detail-card">
          <div class="sdc-icon"><i class="fas fa-lock-open"></i></div>
          <h3 class="sdc-title">Non-Destructive Opening</h3>
          <p class="sdc-desc">Entry to safes with lost keys or forgotten combinations without damaging the safe. Specialist techniques preserve the safe's security features for continued use.</p>
        </div>
        <div class="service-detail-card">
          <div class="sdc-icon"><i class="fas fa-cubes"></i></div>
          <h3 class="sdc-title">Safe Installation</h3>
          <p class="sdc-desc">Professional installation and secure anchoring of all safe types and sizes for homes and commercial premises. Includes security assessment and positioning advice.</p>
        </div>
        <div class="service-detail-card">
          <div class="sdc-icon"><i class="fas fa-sync-alt"></i></div>
          <h3 class="sdc-title">Combination Changes</h3>
          <p class="sdc-desc">Change or reset the combination on dial and electronic safes. Essential after a change of ownership, forgotten code, or security concern.</p>
        </div>
        <div class="service-detail-card">
          <div class="sdc-icon"><i class="fas fa-wrench"></i></div>
          <h3 class="sdc-title">Repair &amp; Maintenance</h3>
          <p class="sdc-desc">Repair of safe locking mechanisms, handles, and hinges. Servicing of dial and electronic locks to keep your safe in reliable working order.</p>
        </div>
      </div>

      <div class="features-pill-row">
        <span class="feature-pill"><i class="fas fa-check"></i> Non-destructive first</span>
        <span class="feature-pill"><i class="fas fa-check"></i> All major safe brands</span>
        <span class="feature-pill"><i class="fas fa-check"></i> UK-wide by appointment</span>
        <span class="feature-pill"><i class="fas fa-check"></i> Written quote before work starts</span>
        <span class="feature-pill"><i class="fas fa-check"></i> Home &amp; commercial</span>
        <span class="feature-pill"><i class="fas fa-check"></i> Fire-rated safes</span>
        <span class="feature-pill"><i class="fas fa-check"></i> Gun cabinets</span>
        <span class="feature-pill"><i class="fas fa-check"></i> 30+ years experience</span>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="content-section bg-dark">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">How We Work</h2>
        <p class="section-subtitle">Three simple steps to get your safe issue resolved professionally, wherever you are in the UK.</p>
      </div>

      <div class="how-it-works-grid">
        <div class="hiw-step">
          <div class="hiw-number">01</div>
          <h3>Contact Us</h3>
          <p>Call <a href="tel:07809887883" style="color:var(--color-accent)">07809 887 883</a> or <a href="https://wa.me/447809887883" target="_blank" rel="noopener noreferrer" style="color:var(--color-accent)">WhatsApp</a>. Tell William about your safe - make, model, the problem, and your location anywhere in the UK.</p>
        </div>
        <div class="hiw-step">
          <div class="hiw-number">02</div>
          <h3>We Confirm Date &amp; Quote</h3>
          <p>We agree a convenient appointment date. A fixed written quote is provided before travel - no hidden charges. Travel costs are included in the quote.</p>
        </div>
        <div class="hiw-step">
          <div class="hiw-number">03</div>
          <h3>Engineer Attends &amp; Resolves</h3>
          <p>William travels to your location and resolves the safe issue on site. Non-destructive opening is always tried first. Your safe is left fully functional and secure.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- QUOTE FORM -->
  <section class="content-section bg-white" id="get-quote">
    <div class="container-custom">
      <div class="quote-cta-section">
        <h2 class="section-title">Get a Quote - Safe Engineer UK-Wide</h2>
        <p class="quote-cta-text">
          Get in touch with your safe details and location, and William will provide a clear, no-obligation quote including travel.
          Call <a href="tel:07809887883" style="color:var(--color-accent); font-weight:700;">07809 887 883</a> to discuss.
        </p>
        <a href="/contact" class="btn-primary-lg" style="justify-content:center; display:inline-flex;">
          <i class="fas fa-paper-plane"></i> Get a Quote
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ + RESPONSE TIME -->
  <section class="content-section bg-light" id="faq">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Safe Engineer UK-Wide - FAQ</h2>
        <p class="section-subtitle">Common questions about the UK-wide safe engineer service.</p>
      </div>

      <div class="faq-with-card">
        <div class="faq-grid">
          <details class="faq-item" open>
            <summary class="faq-question">
              <span>Do you travel outside London for safe engineer work?</span>
              <i class="fas fa-chevron-down faq-icon"></i>
            </summary>
            <div class="faq-answer">Yes. William regularly travels anywhere in the UK for safe engineering work. This specialist service is available nationwide by appointment - from Edinburgh to Bristol, Cardiff to Belfast.</div>
          </details>

          <details class="faq-item">
            <summary class="faq-question">
              <span>How far will you travel for a safe engineer appointment?</span>
              <i class="fas fa-chevron-down faq-icon"></i>
            </summary>
            <div class="faq-answer">There is no fixed distance limit. William has travelled across England, Scotland, Wales and Northern Ireland for safe engineering work. Call to discuss your location and we will arrange a visit.</div>
          </details>

          <details class="faq-item">
            <summary class="faq-question">
              <span>How does the appointment process work?</span>
              <i class="fas fa-chevron-down faq-icon"></i>
            </summary>
            <div class="faq-answer">Contact us by phone or email and describe your safe and the issue. We confirm availability, provide a fixed written quote including any travel costs, and agree a convenient date. William attends on the agreed day and resolves the problem on site in most cases.</div>
          </details>

          <details class="faq-item">
            <summary class="faq-question">
              <span>Do you charge for travel to locations outside London?</span>
              <i class="fas fa-chevron-down faq-icon"></i>
            </summary>
            <div class="faq-answer">Travel costs for UK-wide appointments are included in the written quote provided before work begins. There are no hidden charges - the price you are quoted is the price you pay.</div>
          </details>

          <details class="faq-item">
            <summary class="faq-question">
              <span>What safe brands do you work with?</span>
              <i class="fas fa-chevron-down faq-icon"></i>
            </summary>
            <div class="faq-answer">All major manufacturers including Chubb, Phoenix, Dudley, Yale, Burton, SentrySafe, Honeywell, Securikey, Fichet, De Raat, and many more. Call to confirm your specific safe make and model before booking.</div>
          </details>

          <details class="faq-item">
            <summary class="faq-question">
              <span>How long does a UK-wide safe engineer visit take?</span>
              <i class="fas fa-chevron-down faq-icon"></i>
            </summary>
            <div class="faq-answer">Non-destructive opening typically takes 30 minutes to a few hours depending on the safe type and locking mechanism. A realistic time estimate is provided at the quoting stage. Work is completed on site in most cases during a single visit.</div>
          </details>
        </div>
        <div class="faq-sidebar">
          <div class="response-time-card">
            <div class="rtc-header">
              <i class="fas fa-calendar-check"></i>
              <h3>How to Book</h3>
            </div>
            <div class="rtc-time">By Appt.</div>
            <p class="rtc-note">UK-wide - contact for availability</p>
            <div class="rtc-divider"></div>
            <div class="rtc-stat">
              <i class="fas fa-phone"></i>
              <span>Contact us by phone or email</span>
            </div>
            <div class="rtc-stat">
              <i class="fas fa-file-invoice"></i>
              <span>We confirm date &amp; provide fixed quote</span>
            </div>
            <div class="rtc-stat">
              <i class="fas fa-tools"></i>
              <span>Engineer attends &amp; resolves on site</span>
            </div>
            <a href="tel:07809887883" class="btn-primary-lg" style="width:100%; justify-content:center; margin-top:20px;">
              <i class="fas fa-phone"></i> Call Now
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RELATED: London Borough Pages + Main Service Page -->
  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Safe Engineer in London</h2>
        <p class="section-subtitle">Priority response for London boroughs - faster turnaround for clients in North and Central London.</p>
      </div>

      <div class="nearby-grid">
        <a href="/locations/haringey/safe-engineer" class="nearby-card">
          <div class="nearby-card-content">
            <h3 class="nearby-name">Haringey</h3>
            <p class="nearby-postcodes">N4, N8, N15, N17</p>
            <p class="nearby-time"><i class="fas fa-calendar-check"></i> By appointment</p>
          </div>
          <i class="fas fa-arrow-right nearby-arrow"></i>
        </a>
        <a href="/locations/barnet/safe-engineer" class="nearby-card">
          <div class="nearby-card-content">
            <h3 class="nearby-name">Barnet</h3>
            <p class="nearby-postcodes">N2, N3, N11, N20</p>
            <p class="nearby-time"><i class="fas fa-calendar-check"></i> By appointment</p>
          </div>
          <i class="fas fa-arrow-right nearby-arrow"></i>
        </a>
        <a href="/locations/camden/safe-engineer" class="nearby-card">
          <div class="nearby-card-content">
            <h3 class="nearby-name">Camden</h3>
            <p class="nearby-postcodes">NW1, NW3, NW5</p>
            <p class="nearby-time"><i class="fas fa-calendar-check"></i> By appointment</p>
          </div>
          <i class="fas fa-arrow-right nearby-arrow"></i>
        </a>
        <a href="/locations/islington/safe-engineer" class="nearby-card">
          <div class="nearby-card-content">
            <h3 class="nearby-name">Islington</h3>
            <p class="nearby-postcodes">N1, N5, N7</p>
            <p class="nearby-time"><i class="fas fa-calendar-check"></i> By appointment</p>
          </div>
          <i class="fas fa-arrow-right nearby-arrow"></i>
        </a>
        <a href="/services/safe-engineer" class="nearby-card nearby-all">
          <div class="nearby-card-content">
            <h3 class="nearby-name">Safe Engineer Service</h3>
            <p class="nearby-postcodes">View main safe engineer page</p>
          </div>
          <i class="fas fa-arrow-right nearby-arrow"></i>
        </a>
      </div>
    </div>
  </section>

  <GoogleReviews bg="light" />

  <CTASection
    title="Need a Safe Engineer Anywhere in the UK?"
    subtitle="UK-wide by appointment | Non-destructive opening | All major brands | 30+ years experience"
  />

</BaseLayout>

<style>
  .loc-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding-top: var(--header-height);
    overflow: hidden;
  }

  .loc-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: brightness(0.25) saturate(0.8);
  }

  .loc-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(14, 74, 77, 0.85) 0%, rgba(0, 0, 0, 0.6) 100%);
  }

  .loc-hero-content {
    position: relative;
    z-index: 1;
    padding-top: 60px;
    padding-bottom: 80px;
  }

  .loc-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .loc-breadcrumb a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.2s;
  }

  .loc-breadcrumb a:hover { color: white; }
  .loc-breadcrumb span:last-child { color: var(--color-accent); font-weight: 500; }

  .loc-hero-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 60px;
    align-items: start;
  }

  .loc-hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 16px;
    display: flex;
    flex-direction: column;
  }

  .loc-hero-service { color: var(--color-accent); }
  .loc-hero-location { color: white; }

  .loc-hero-postcodes { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.65); font-size: 0.9rem; margin: 0 0 16px; }
  .loc-hero-postcodes i { color: var(--color-accent); }

  .loc-hero-lead { color: rgba(255,255,255,0.8); font-size: 1.1rem; line-height: 1.6; margin: 0 0 32px; max-width: 560px; }

  .loc-hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }

  .btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
    background: var(--color-accent);
    color: white;
    border-radius: 100px;
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: 0 4px 20px rgba(31, 174, 155, 0.4);
  }

  .btn-hero-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(31, 174, 155, 0.5);
  }

  .btn-hero-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
