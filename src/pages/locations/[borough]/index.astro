---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GoogleReviews from '../../../components/GoogleReviews.astro';
import CTASection from '../../../components/CTASection.astro';
import { boroughs, servicesMeta } from '../../../data/locations';
import { getBoroughAreaContent } from '../../../data/area-content';
import ServiceCards from '../../../components/ServiceCards.astro';

const { borough: boroughSlug } = Astro.params;
const borough = boroughs.find((b) => b.slug === boroughSlug);
if (!borough) return new Response(null, { status: 404 });

const siteUrl = 'https://bullardlocks.com';
const pageUrl = `${siteUrl}/locations/${boroughSlug}`;

const pageTitle = `Locksmith ${borough.name} - ${borough.postcodes.slice(0, 3).join(', ')} | Bullard Locks`;
const metaDescription = `Professional locksmith in ${borough.name} - ${borough.postcodes.slice(0, 3).join(', ')}. Auto locksmith, emergency locksmith${borough.services.includes('safe-engineer') ? ' & safe engineer' : ''} services. No call-out fee. Call 07809 887 883.`;

// Borough-specific FAQ items
const faqItems = [
  {
    q: `How quickly can you reach ${borough.name}?`,
    a: `Our typical response time in ${borough.name} is ${borough.responseTime}. We're based in Crouch End N8 — one of the closest locksmith services to most of ${borough.name}. For emergencies, call us directly on 07809 887 883.`,
  },
  {
    q: `Do you charge a call-out fee in ${borough.name}?`,
    a: `No — there is no call-out fee for any of our services in ${borough.name}. You only pay for the work actually carried out. We always provide a clear fixed quote before starting any job.`,
  },
  {
    q: `What locksmith services do you offer in ${borough.name}?`,
    a: `In ${borough.name} we offer: ${borough.services.map(s => servicesMeta[s].name).join(', ')}. Each service is mobile — we come to you wherever you are in ${borough.name}.`,
  },
  {
    q: `Are you available 24/7 in ${borough.name}?`,
    a: borough.services.includes('emergency-locksmith')
      ? `Our emergency locksmith service in ${borough.name} is available 24 hours a day, 7 days a week, 365 days a year. Auto locksmith and safe engineer appointments are available 7 days a week during normal hours.`
      : `Our auto locksmith and safe engineer services in ${borough.name} operate 7 days a week. For urgent enquiries outside normal hours, please call 07809 887 883.`,
  },
  {
    q: `Do you cover all areas within ${borough.name}?`,
    a: `Yes — we cover every area within ${borough.name}, including ${borough.areas.slice(0, 4).join(', ')} and all ${borough.postcodes.join(', ')} postcodes. If you're unsure, just call us and we'll confirm coverage instantly.`,
  },
  {
    q: `Who is Bullard Locks?`,
    a: `Bullard Locks is run by William Bullard, a professional locksmith with 30+ years of experience based in Crouch End N8, North London. William is a Metropolitan Police approved contractor, fully insured, DBS checked, and holds a 5-star Google rating. He personally attends every job.`,
  },
];

const areaContent = getBoroughAreaContent(boroughSlug!);
const nearbyBoroughsList = boroughs.filter((b) => borough.nearbyBoroughs.includes(b.slug));

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'LocksmithBusiness',
    name: 'Bullard Locks',
    telephone: '07809887883',
    url: pageUrl,
    address: {
      '@type': 'PostalAddress',
      streetAddress: '67 Weston Park',
      addressLocality: 'Crouch End',
      addressRegion: 'London',
      postalCode: 'N8 9TA',
      addressCountry: 'GB',
    },
    areaServed: [
      ...borough.postcodes.map((pc) => ({ '@type': 'PostalAddress', postalCode: pc, addressCountry: 'GB' })),
      { '@type': 'City', name: borough.name, containedInPlace: { '@type': 'City', name: 'London' } }
    ],
    makesOffer: borough.services.map((s) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: servicesMeta[s].name },
    })),
    description: metaDescription,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Locations', item: `${siteUrl}/locations` },
      { '@type': 'ListItem', position: 3, name: borough.name, item: pageUrl },
    ],
  },
];


const heroImage = '/images/hero-emergency-locksmith.webp';
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonicalUrl={pageUrl}
  ogImage="https://bullardlocks.com/images/hero-emergency-locksmith.webp"
  schema={schema}
>

  <!-- HERO -->
  <section class="loc-hero bg-dark">
    <div class="loc-hero-bg" style={`background-image: url('${heroImage}')`} aria-hidden="true"></div>
    <div class="loc-hero-overlay" aria-hidden="true"></div>
    <div class="container-custom loc-hero-content">
      <!-- Breadcrumb -->
      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/locations">Locations</a>
        <span aria-hidden="true">/</span>
        <span>{borough.name}</span>
      </nav>

      <div class="loc-hero-grid">
        <div class="loc-hero-left">
          <h1 class="loc-hero-title">
            <span class="loc-hero-service">Locksmith</span>
            <span class="loc-hero-location">{borough.name}</span>
          </h1>

          <p class="loc-hero-postcodes">
            <i class="fas fa-map-marker-alt"></i>
            {borough.postcodes.join(' · ')}
          </p>

          <p class="loc-hero-lead">{borough.description}</p>

          <div class="loc-hero-ctas">
            <a href="tel:07809887883" class="btn-hero-primary">
              <i class="fas fa-phone"></i> 07809 887 883
            </a>
            <a href="https://wa.me/447809887883" class="btn-hero-whatsapp" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> WhatsApp
            </a>
          </div>

          <!-- Trust bar -->
          <div class="loc-trust-bar">
            <div class="loc-trust-item">
              <i class="fas fa-star"></i>
              <span>5.0 Google</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-shield-alt"></i>
              <span>Met Police Approved</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-award"></i>
              <span>30+ Years Experience</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-tag"></i>
              <span>No Call-Out Fee</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-check-circle"></i>
              <span>Fully Insured</span>
            </div>
          </div>
        </div>

        <!-- Sticky callback panel -->
        <div class="loc-hero-panel">
          <div class="conv-panel">
            <div class="conv-panel-header">
              <i class="fas fa-phone"></i>
              <div>
                <p class="conv-panel-label">Call us now</p>
                <a href="tel:07809887883" class="conv-panel-number">07809 887 883</a>
              </div>
            </div>
            <p class="conv-panel-note">Or request a callback:</p>
            <form id="callback-form" class="conv-form">
              <input type="text" name="name" placeholder="Your name" class="conv-input" required />
              <input type="tel" name="phone" placeholder="Your phone number" class="conv-input" required />
              <input type="hidden" name="location" value={borough.name} />
              <input type="hidden" name="service" value="general" />
              <input type="hidden" name="form_type" value="callback" />
              <input type="hidden" name="message" value={`Callback request for locksmith services in ${borough.name}`} />
              <button type="submit" class="conv-submit">
                <i class="fas fa-phone"></i> Request Callback
              </button>
              <div class="conv-form-status" style="display:none;"></div>
            </form>
            <a href="https://wa.me/447809887883" class="conv-whatsapp" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> Message on WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES IN THIS BOROUGH -->
  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Our Services in {borough.name}</h2>
        <p class="section-subtitle">
          Professional locksmith services covering {borough.postcodes.slice(0, 4).join(', ')} and all {borough.name} postcodes.
        </p>
      </div>
      <ServiceCards boroughSlug={boroughSlug} boroughName={borough.name} services={borough.services} />
    </div>
  </section>

  <!-- AREA CONTENT -->
  <section class="content-section bg-light">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">{areaContent.heading}</h2>
      </div>
      <div class="area-content-grid">
        <div class="area-content-image">
          <img src={areaContent.image} alt={areaContent.imageAlt} width="900" height="600" loading="lazy" />
          <a href="https://www.google.com/maps/place/?q=place_id:ChIJU7O3P5IbdkgRVm-wppoH9-4" target="_blank" rel="noopener noreferrer" class="area-star-card">
            <div class="area-star-icon"><i class="fas fa-star"></i></div>
            <div class="area-star-text">
              <span class="area-star-rating">5.0 on Google</span>
              <span class="area-star-source">Read our reviews</span>
            </div>
          </a>
        </div>
        <div class="area-content-text">
          {areaContent.paragraphs.map((p) => (
            <p class="area-paragraph">{p}</p>
          ))}
        </div>
      </div>
      <div class="area-content-ctas">
        <a href="tel:07809887883" class="btn-primary-lg">
          <i class="fas fa-phone"></i> 07809 887 883
        </a>
        <a href="https://wa.me/447809887883" class="btn-whatsapp-lg" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-whatsapp"></i> WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="content-section bg-dark">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">How We Work</h2>
        <p class="section-subtitle">Three simple steps to get the problem sorted.</p>
      </div>

      <div class="how-it-works-grid">
        <div class="hiw-step">
          <div class="hiw-number">01</div>
          <h3>Call or Message</h3>
          <p>Call <a href="tel:07809887883" style="color:var(--color-accent)">07809 887 883</a> or <a href="https://wa.me/447809887883" target="_blank" rel="noopener noreferrer" style="color:var(--color-accent)">WhatsApp</a>. Tell us your location in {borough.name} and the problem.</p>
        </div>
        <div class="hiw-step">
          <div class="hiw-number">02</div>
          <h3>We Come to You</h3>
          <p>William comes to you in {borough.name}. Typical arrival: {borough.responseTime}. You'll get a fixed quote before any work begins.</p>
        </div>
        <div class="hiw-step">
          <div class="hiw-number">03</div>
          <h3>Problem Solved</h3>
          <p>Work is completed on the spot in most cases. No call-out fee — you only pay for what's done.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- QUOTE FORM -->
  <section class="content-section bg-white" id="get-quote">
    <div class="container-custom">
      <div class="quote-form-layout">
        <div class="quote-form-card">
          <form id="borough-contact-form">
            <input type="hidden" name="form_type" value="borough-enquiry" />
            <input type="hidden" name="location_borough" value={borough.name} />

            <div class="form-group">
              <label for="bc-name" class="form-label">Your Name *</label>
              <input type="text" id="bc-name" name="name" class="form-control-modern" placeholder="John Smith" required />
            </div>
            <div class="form-group">
              <label for="bc-phone" class="form-label">Phone Number *</label>
              <input type="tel" id="bc-phone" name="phone" class="form-control-modern" placeholder="07700 900000" required />
            </div>
            <div class="form-group">
              <label for="bc-service" class="form-label">Service Needed</label>
              <select id="bc-service" name="service" class="form-control-modern">
                <option value="">Select service...</option>
                {borough.services.map(s => (
                  <option value={s}>{servicesMeta[s].name}</option>
                ))}
              </select>
            </div>
            <div class="form-group">
              <label for="bc-message" class="form-label">Describe Your Situation *</label>
              <textarea id="bc-message" name="message" class="form-control-modern" rows="4"
                placeholder={`e.g. "Lost car keys in ${borough.areas[0]}" or "Locked out of my flat" or "Safe won't open"`}
                required></textarea>
            </div>

            <div id="bc-form-status" class="form-status" style="display:none;"></div>

            <button type="submit" class="btn-primary-lg w-full" style="justify-content:center;" id="bc-submit">
              <i class="fas fa-paper-plane"></i>
              <span class="btn-text">Send Enquiry</span>
              <span class="btn-loading" style="display:none;"><i class="fas fa-spinner fa-spin"></i> Sending...</span>
            </button>

            <p class="form-privacy-note">
              <i class="fas fa-lock"></i> Your details are kept private and never shared.
            </p>
          </form>
        </div>

        <div class="quote-form-copy">
          <h2 class="section-title" style="text-align:left;">Get a Quote — {borough.name}</h2>
          <p style="color:var(--color-text-muted); line-height:1.7; margin-bottom: 24px;">
            Fill in the short form and William will get back to you promptly with a clear, no-obligation quote.
            For immediate help, call <a href="tel:07809887883" style="color:var(--color-accent); font-weight:700;">07809 887 883</a>.
          </p>
          <ul class="quote-trust-list">
            <li><i class="fas fa-check-circle"></i> No call-out fee</li>
            <li><i class="fas fa-check-circle"></i> Fixed price quoted before work starts</li>
            <li><i class="fas fa-check-circle"></i> No hidden charges</li>
            <li><i class="fas fa-check-circle"></i> Met Police approved contractor</li>
            <li><i class="fas fa-check-circle"></i> 30+ years experience</li>
          </ul>
          <div class="photo-upload-callout">
            <i class="fas fa-camera"></i>
            <div>
              <strong>Need to send a photo?</strong>
              <p>Use our <a href="/contact">contact form</a> to upload up to 5 images of your lock, key or safe.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ + RESPONSE TIME -->
  <section class="content-section bg-light" id="faq">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Locksmith {borough.name} — FAQ</h2>
        <p class="section-subtitle">Common questions about our locksmith services in {borough.name}.</p>
      </div>

      <div class="faq-with-card">
        <div class="faq-grid">
          {faqItems.map((item, i) => (
            <details class="faq-item" open={i === 0}>
              <summary class="faq-question">
                <span>{item.q}</span>
                <i class="fas fa-chevron-down faq-icon"></i>
              </summary>
              <div class="faq-answer">{item.a}</div>
            </details>
          ))}
        </div>
        <div class="faq-sidebar">
          <div class="response-time-card">
            <div class="rtc-header">
              <i class="fas fa-bolt"></i>
              <h3>Response Time</h3>
            </div>
            <div class="rtc-time">{borough.responseTime}</div>
            <p class="rtc-note">Typical arrival time in {borough.name}</p>
            <div class="rtc-divider"></div>
            <div class="rtc-stat">
              <i class="fas fa-map-marker-alt"></i>
              <span>Based in Crouch End N8</span>
            </div>
            <div class="rtc-stat">
              <i class="fas fa-car"></i>
              <span>Fully equipped mobile unit</span>
            </div>
            <div class="rtc-stat">
              <i class="fas fa-clock"></i>
              <span>
                {borough.services.includes('emergency-locksmith') ? '24/7 emergency availability' : 'Available 7 days a week'}
              </span>
            </div>
            <a href="tel:07809887883" class="btn-primary-lg" style="width:100%; justify-content:center; margin-top:20px;">
              <i class="fas fa-phone"></i> Call Now
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEARBY BOROUGHS -->
  {nearbyBoroughsList.length > 0 && (
    <section class="content-section bg-white">
      <div class="container-custom">
        <div class="section-header">
          <h2 class="section-title">Nearby Areas We Also Cover</h2>
          <p class="section-subtitle">We provide locksmith services across all these neighbouring boroughs too.</p>
        </div>

        <div class="nearby-grid">
          {nearbyBoroughsList.map((nb) => (
            <a href={`/locations/${nb.slug}`} class="nearby-card">
              <div class="nearby-card-content">
                <h3 class="nearby-name">{nb.name}</h3>
                <p class="nearby-postcodes">{nb.postcodes.slice(0, 3).join(', ')}</p>
                <p class="nearby-time"><i class="fas fa-clock"></i> {nb.responseTime}</p>
              </div>
              <i class="fas fa-arrow-right nearby-arrow"></i>
            </a>
          ))}
          <a href="/locations" class="nearby-card nearby-all">
            <div class="nearby-card-content">
              <h3 class="nearby-name">All Locations</h3>
              <p class="nearby-postcodes">View all areas we serve</p>
            </div>
            <i class="fas fa-arrow-right nearby-arrow"></i>
          </a>
        </div>
      </div>
    </section>
  )}

  <GoogleReviews bg="light" />

  <CTASection
    title={`Locksmith in ${borough.name}`}
    subtitle={`${borough.postcodes.join(' · ')} | Response ${borough.responseTime} | No call-out fee`}
  />
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .loc-hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding-top: var(--header-height);
    overflow: hidden;
  }

  .loc-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: brightness(0.25) saturate(0.8);
  }

  .loc-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(14, 74, 77, 0.85) 0%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  .loc-hero-content {
    position: relative;
    z-index: 1;
    padding-top: 60px;
    padding-bottom: 80px;
  }

  .loc-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .loc-breadcrumb a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.2s;
  }

  .loc-breadcrumb a:hover { color: white; }
  .loc-breadcrumb span:last-child { color: var(--color-accent); font-weight: 500; }

  .loc-hero-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 60px;
    align-items: start;
  }

  .loc-hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 16px;
    display: flex;
    flex-direction: column;
  }

  .loc-hero-service {
    color: var(--color-accent);
  }

  .loc-hero-location {
    color: white;
  }

  .loc-hero-postcodes {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.65);
    font-size: 0.9rem;
    margin: 0 0 16px;
    flex-wrap: wrap;
  }

  .loc-hero-postcodes i {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .loc-hero-lead {
    color: rgba(255,255,255,0.8);
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0 0 32px;
    max-width: 560px;
  }

  .loc-hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
    background: var(--color-accent);
    color: white;
    border-radius: 100px;
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: 0 4px 20px rgba(31, 174, 155, 0.4);
  }

  .btn-hero-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(31, 174, 155, 0.5);
  }

  .btn-hero-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
    background: #25D366;
    color: white;
    border: none;
    border-radius: 100px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(37,211,102,0.35);
    transition: all 0.2s ease;
  }

  .btn-hero-whatsapp:hover {
    background: #1DA851;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(37,211,102,0.45);
  }

  .loc-trust-bar {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
  }

  .loc-trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 16px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    font-weight: 500;
  }

  .loc-trust-item:first-child { padding-left: 0; }
  .loc-trust-item + .loc-trust-item { border-left: 1px solid rgba(255,255,255,0.28); }

  .loc-trust-item i {
    color: var(--color-accent);
    font-size: 0.9rem;
  }

  /* Conversion Panel */
  .conv-panel {
    background: white;
    border-radius: 20px;
    padding: 28px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    position: sticky;
    top: 100px;
  }

  .conv-panel-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }

  .conv-panel-header > i {
    width: 44px;
    height: 44px;
    background: rgba(31, 174, 155, 0.1);
    color: var(--color-accent);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .conv-panel-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin: 0;
    font-weight: 600;
  }

  .conv-panel-number {
    font-size: 1.4rem;
    font-weight: 800;
