---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GoogleReviews from '../../../components/GoogleReviews.astro';
import CTASection from '../../../components/CTASection.astro';
import TrustCredentials from '../../../components/TrustCredentials.astro';
import { boroughs, servicesMeta } from '../../../data/locations';
import { getBoroughAreaContent } from '../../../data/area-content';
import { boroughGeoData } from '../../../data/borough-geo';
import ServiceCards from '../../../components/ServiceCards.astro';

export const prerender = true;

export function getStaticPaths() {
  return boroughs.map((b) => ({ params: { borough: b.slug } }));
}

const { borough: boroughSlug } = Astro.params;
const borough = boroughs.find((b) => b.slug === boroughSlug);
if (!borough) return new Response(null, { status: 404 });

const siteUrl = 'https://www.bullardlocks.com';
const pageUrl = `${siteUrl}/locations/${boroughSlug}`;

const pageTitle = `Locksmith ${borough.name} - ${borough.postcodes.slice(0, 3).join(', ')} | Bullard Locks`;
const metaDescription = `Professional locksmith in ${borough.name} - ${borough.postcodes.slice(0, 3).join(', ')}. Auto locksmith, emergency locksmith${borough.services.includes('safe-engineer') ? ' & safe engineer' : ''} services. No call-out fee. Call 07809 887 883.`;

// Borough-specific FAQ items (AEO-optimised - each answer is a standalone, quotable response)
const faqItems = [
  {
    q: `How quickly can a locksmith reach ${borough.name}?`,
    a: `Bullard Locks typically arrives anywhere in ${borough.name} within ${borough.responseTime}. William Bullard operates from a fully equipped mobile unit based in Crouch End N8, which places him among the closest professional locksmiths to most of ${borough.name}. For emergencies, call 07809 887 883 - you speak directly to William, not a call centre, and he gives you an accurate arrival estimate immediately.`,
  },
  {
    q: `Is there a call-out fee for locksmith services in ${borough.name}?`,
    a: `No. Bullard Locks does not charge a call-out fee for any service in ${borough.name}, including emergency work at unsociable hours. Many locksmith services advertise low call-out fees then add surcharges for evenings, weekends or bank holidays. With Bullard Locks, you receive a single fixed-price quote before any work begins, and that is the only amount you pay - no hidden charges, no invoice surprises.`,
  },
  {
    q: `What locksmith services are available in ${borough.name}?`,
    a: `Bullard Locks provides ${borough.services.map(s => servicesMeta[s].name.toLowerCase()).join(', ')} services across all of ${borough.name}. Every service is fully mobile - William drives to your exact location with all tools, parts and diagnostic equipment. There is no need to visit a shop or wait for parts to be ordered. Most jobs are completed in a single visit.`,
  },
  {
    q: `Is the locksmith service available 24/7 in ${borough.name}?`,
    a: borough.services.includes('emergency-locksmith')
      ? `The emergency locksmith service in ${borough.name} operates 24 hours a day, 7 days a week, 365 days a year - including Christmas Day and bank holidays. This is a genuine around-the-clock service, not an answering machine that redirects to a daytime callback. Auto locksmith and safe engineer appointments are available 7 days a week during normal working hours.`
      : `Auto locksmith and safe engineer services in ${borough.name} are available 7 days a week during normal working hours. For urgent enquiries outside these hours, call 07809 887 883 - William will advise on availability and can often accommodate same-day requests.`,
  },
  {
    q: `Which areas and postcodes does Bullard Locks cover in ${borough.name}?`,
    a: `Bullard Locks covers every area within the London Borough of ${borough.name}, including ${borough.areas.slice(0, 5).join(', ')} and all surrounding neighbourhoods. All ${borough.postcodes.join(', ')} postcodes are within the standard coverage area. If you are unsure whether your specific location is covered, call 07809 887 883 for instant confirmation.`,
  },
  {
    q: `Who runs Bullard Locks and what are their credentials?`,
    a: `Bullard Locks is owned and operated by William Bullard, a professional locksmith with over 30 years of hands-on experience. William is based in Crouch End N8, North London. He is a Metropolitan Police approved contractor, a Master Locksmiths Association member, DBS (Disclosure and Barring Service) checked, and holds comprehensive public liability insurance. He maintains a perfect 5.0-star Google rating from verified customers and personally attends every job - no subcontractors are used.`,
  },
];

const areaContent = getBoroughAreaContent(boroughSlug!);
const nearbyBoroughsList = boroughs.filter((b) => borough.nearbyBoroughs.includes(b.slug));
const geoData = boroughGeoData[boroughSlug!];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': ['LocalBusiness', 'LocksmithBusiness'],
    name: 'Bullard Locks',
    telephone: '+447809887883',
    url: pageUrl,
    image: `${siteUrl}/images/william-bullard-trusted-london-locksmith.webp`,
    priceRange: '££',
    currenciesAccepted: 'GBP',
    paymentAccepted: 'Cash, Credit Card, Debit Card, Bank Transfer',
    openingHoursSpecification: [
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
        opens: '00:00',
        closes: '23:59',
        description: 'Emergency locksmith available 24/7',
      },
    ],
    address: {
      '@type': 'PostalAddress',
      streetAddress: '67 Weston Park',
      addressLocality: 'Crouch End',
      addressRegion: 'London',
      postalCode: 'N8 9TA',
      addressCountry: 'GB',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 51.5786,
      longitude: -0.1227,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      bestRating: '5',
      worstRating: '1',
      ratingCount: '23',
      reviewCount: '23',
    },
    sameAs: [
      'https://g.page/bullardlocks',
      'https://www.facebook.com/bullardlocks',
      'https://www.instagram.com/bullardlocks',
    ],
    areaServed: [
      ...borough.postcodes.map((pc) => ({ '@type': 'PostalAddress', postalCode: pc, addressCountry: 'GB' })),
      {
        '@type': 'City',
        name: borough.name,
        containedInPlace: { '@type': 'City', name: 'London' },
      },
      ...(geoData ? [{
        '@type': 'GeoShape',
        polygon: geoData.polygon,
      }] : []),
    ],
    makesOffer: borough.services.map((s) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: servicesMeta[s].name },
    })),
    description: metaDescription,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.a,
      },
    })),
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['.faq-answer'],
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Locations', item: `${siteUrl}/locations` },
      { '@type': 'ListItem', position: 3, name: borough.name, item: pageUrl },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Place',
    name: borough.name,
    description: borough.description,
    address: {
      '@type': 'PostalAddress',
      addressLocality: borough.name,
      addressRegion: 'London',
      addressCountry: 'GB',
    },
    containsPlace: borough.landmarks.map((lm) => ({
      '@type': 'Place',
      name: lm,
      address: {
        '@type': 'PostalAddress',
        addressLocality: borough.name,
        addressRegion: 'London',
        addressCountry: 'GB',
      },
    })),
  },
];


const heroImage = '/images/hero-emergency-locksmith.webp';
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonicalUrl={pageUrl}
  ogImage="https://www.bullardlocks.com/images/hero-emergency-locksmith.webp"
  schema={schema}
  preloadImage={heroImage}
>

  <!-- HERO -->
  <section class="loc-hero bg-dark">
    <div class="loc-hero-bg" style={`background-image: url('${heroImage}')`} aria-hidden="true"></div>
    <div class="loc-hero-overlay" aria-hidden="true"></div>
    <div class="container-custom loc-hero-content">
      <!-- Breadcrumb -->
      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/locations">Locations</a>
        <span aria-hidden="true">/</span>
        <span>{borough.name}</span>
      </nav>

      <div class="loc-hero-grid">
        <div class="loc-hero-left">
          <h1 class="loc-hero-title">
            <span class="loc-hero-service">Locksmith</span>
            <span class="loc-hero-location">{borough.name}</span>
          </h1>

          <p class="loc-hero-postcodes">
            <i class="fas fa-map-marker-alt"></i>
            {borough.postcodes.join(' · ')}
          </p>

          <p class="loc-hero-lead">{borough.description}</p>

          <div class="loc-hero-ctas">
            <a href="tel:07809887883" class="btn-hero-primary">
              <i class="fas fa-phone"></i> 07809 887 883
            </a>
            <a href="https://wa.me/447809887883" class="btn-hero-whatsapp" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> WhatsApp
            </a>
          </div>

          <!-- Trust bar -->
          <div class="loc-trust-bar">
            <div class="loc-trust-item">
              <i class="fas fa-star"></i>
              <span>5.0 Google</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-shield-alt"></i>
              <span>Met Police Approved</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-award"></i>
              <span>30+ Years Experience</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-tag"></i>
              <span>No Call-Out Fee</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-check"></i>
              <span>Fully Insured</span>
            </div>
          </div>
        </div>

        <!-- Sticky callback panel -->
        <div class="loc-hero-panel">
          <div class="conv-panel">
            <div class="conv-panel-header">
              <i class="fas fa-phone"></i>
              <div>
                <p class="conv-panel-label">Call us now</p>
                <a href="tel:07809887883" class="conv-panel-number">07809 887 883</a>
              </div>
            </div>
            <p class="conv-panel-note">Or request a callback:</p>
            <form id="callback-form" class="conv-form">
              <input type="text" name="name" placeholder="Your name" class="conv-input" required />
              <input type="tel" name="phone" placeholder="Your phone number" class="conv-input" required />
              <input type="hidden" name="location" value={borough.name} />
              <input type="hidden" name="service" value="general" />
              <input type="hidden" name="form_type" value="callback" />
              <input type="hidden" name="message" value={`Callback request for locksmith services in ${borough.name}`} />
              <button type="submit" class="conv-submit">
                <i class="fas fa-phone"></i> Request Callback
              </button>
              <div class="conv-form-status" style="display:none;"></div>
            </form>
            <a href="https://wa.me/447809887883" class="conv-whatsapp" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> Message on WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES IN THIS BOROUGH -->
  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Our Services in {borough.name}</h2>
        <p class="section-subtitle">
          Professional locksmith services covering {borough.postcodes.slice(0, 4).join(', ')} and all {borough.name} postcodes.
        </p>
      </div>
      <ServiceCards boroughSlug={boroughSlug} boroughName={borough.name} services={borough.services} />
    </div>
  </section>

  <!-- AREA CONTENT -->
  <section class="content-section bg-light">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">{areaContent.heading}</h2>
      </div>
      <div class="area-content-grid">
        <div class="area-content-image">
          <img src={areaContent.image} alt={areaContent.imageAlt} width="900" height="600" loading="lazy" />
          <a href="https://www.google.com/maps/place/?q=place_id:ChIJU7O3P5IbdkgRVm-wppoH9-4" target="_blank" rel="noopener noreferrer" class="area-star-card">
            <div class="area-star-icon"><i class="fas fa-star"></i></div>
            <div class="area-star-text">
              <span class="area-star-rating">5.0 on Google</span>
              <span class="area-star-source">Read our reviews</span>
            </div>
          </a>
        </div>
        <div class="area-content-text">
          {areaContent.paragraphs.map((p) => (
            <p class="area-paragraph">{p}</p>
          ))}
        </div>
      </div>
      <div class="area-content-ctas">
        <a href="tel:07809887883" class="btn-primary-lg">
          <i class="fas fa-phone"></i> 07809 887 883
        </a>
        <a href="https://wa.me/447809887883" class="btn-whatsapp-lg" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-whatsapp"></i> WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- LOCAL COVERAGE - unique borough data (areas, postcodes, landmarks) -->
  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Locksmith Coverage in {borough.name}</h2>
        <p class="section-subtitle">Neighbourhoods, postcodes and landmarks within our {borough.name} catchment - {borough.responseTime} typical response.</p>
      </div>

      <div class="coverage-grid">
        <div class="coverage-card">
          <div class="coverage-card-icon"><i class="fas fa-map-pin"></i></div>
          <h3 class="coverage-card-title">Neighbourhoods</h3>
          <ul class="coverage-list">
            {borough.areas.map((area) => <li>{area}</li>)}
          </ul>
        </div>

        <div class="coverage-card">
          <div class="coverage-card-icon"><i class="fas fa-mail-bulk"></i></div>
          <h3 class="coverage-card-title">Postcodes</h3>
          <ul class="coverage-list coverage-list-pills">
            {borough.postcodes.map((pc) => <li><span class="postcode-pill">{pc}</span></li>)}
          </ul>
        </div>

        <div class="coverage-card">
          <div class="coverage-card-icon"><i class="fas fa-landmark"></i></div>
          <h3 class="coverage-card-title">Local Landmarks</h3>
          <ul class="coverage-list">
            {borough.landmarks.map((lm) => <li>Near {lm}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="content-section bg-dark">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">How We Work</h2>
        <p class="section-subtitle">Three simple steps to get the problem sorted.</p>
      </div>

      <div class="how-it-works-grid">
        <div class="hiw-step">
          <div class="hiw-number">01</div>
          <h3>Call or Message</h3>
          <p>Call <a href="tel:07809887883" style="color:var(--color-accent)">07809 887 883</a> or <a href="https://wa.me/447809887883" target="_blank" rel="noopener noreferrer" style="color:var(--color-accent)">WhatsApp</a>. Tell us your location in {borough.name} and the problem.</p>
        </div>
        <div class="hiw-step">
          <div class="hiw-number">02</div>
          <h3>We Come to You</h3>
          <p>William comes to you in {borough.name}. Typical arrival: {borough.responseTime}. You'll get a fixed quote before any work begins.</p>
        </div>
        <div class="hiw-step">
          <div class="hiw-number">03</div>
          <h3>Problem Solved</h3>
          <p>Work is completed on the spot in most cases. No call-out fee - you only pay for what's done.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- QUOTE -->
  <section class="content-section bg-white" id="get-quote">
    <div class="container-custom">
      <div class="quote-cta-section">
        <h2 class="section-title">Get a Quote - {borough.name}</h2>
        <p class="quote-cta-text">
          Send William the details and he'll get back to you with a clear, no-obligation quote.
          For urgent help, call <a href="tel:07809887883" style="color:var(--color-accent); font-weight:700;">07809 887 883</a>.
        </p>
        <a href="/contact" class="btn-primary-lg" style="justify-content:center; display:inline-flex;">
          <i class="fas fa-paper-plane"></i> Get a Quote
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ + RESPONSE TIME -->
  <section class="content-section bg-light" id="faq">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Locksmith {borough.name} - FAQ</h2>
        <p class="section-subtitle">Common questions about our locksmith services in {borough.name}.</p>
      </div>

      <div class="faq-with-card">
        <div class="faq-grid">
          {faqItems.map((item, i) => (
            <details class="faq-item" open={i === 0}>
              <summary class="faq-question">
                <span>{item.q}</span>
                <i class="fas fa-chevron-down faq-icon"></i>
              </summary>
              <div class="faq-answer">{item.a}</div>
            </details>
          ))}
        </div>
        <div class="faq-sidebar">
          <div class="response-time-card">
            <div class="rtc-header">
              <i class="fas fa-bolt"></i>
              <h3>Response Time</h3>
            </div>
            <div class="rtc-time">{borough.responseTime}</div>
            <p class="rtc-note">Typical arrival time in {borough.name}</p>
            <div class="rtc-divider"></div>
            <div class="rtc-stat">
              <i class="fas fa-map-marker-alt"></i>
              <span>Based in Crouch End N8</span>
            </div>
            <div class="rtc-stat">
              <i class="fas fa-car"></i>
              <span>Fully equipped mobile unit</span>
            </div>
            <div class="rtc-stat">
              <i class="fas fa-clock"></i>
              <span>
                {borough.services.includes('emergency-locksmith') ? '24/7 emergency availability' : 'Available 7 days a week'}
              </span>
            </div>
            <a href="tel:07809887883" class="btn-primary-lg" style="width:100%; justify-content:center; margin-top:20px;">
              <i class="fas fa-phone"></i> Call Now
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEARBY BOROUGHS -->
  {nearbyBoroughsList.length > 0 && (
    <section class="content-section bg-white">
      <div class="container-custom">
        <div class="section-header">
          <h2 class="section-title">Nearby Areas We Also Cover</h2>
          <p class="section-subtitle">We provide locksmith services across all these neighbouring boroughs too.</p>
        </div>

        <div class="nearby-grid">
          {nearbyBoroughsList.map((nb) => (
            <a href={`/locations/${nb.slug}`} class="nearby-card">
              <div class="nearby-card-content">
                <h3 class="nearby-name">{nb.name}</h3>
                <p class="nearby-postcodes">{nb.postcodes.slice(0, 3).join(', ')}</p>
                <p class="nearby-time"><i class="fas fa-clock"></i> {nb.responseTime}</p>
              </div>
              <i class="fas fa-arrow-right nearby-arrow"></i>
            </a>
          ))}
          <a href="/locations" class="nearby-card nearby-all">
            <div class="nearby-card-content">
              <h3 class="nearby-name">All Locations</h3>
              <p class="nearby-postcodes">View all areas we serve</p>
            </div>
            <i class="fas fa-arrow-right nearby-arrow"></i>
          </a>
        </div>
      </div>
    </section>
  )}

  <TrustCredentials />

  <GoogleReviews bg="light" />

  <CTASection
    title={`Locksmith in ${borough.name}`}
    subtitle={`${borough.postcodes.join(' · ')} | Response ${borough.responseTime} | No call-out fee`}
  />
</BaseLayout>

<style>
  /* ===== COVERAGE GRID ===== */
  .coverage-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 980px;
    margin: 0 auto;
  }

  .coverage-card {
    background: var(--color-bg-light);
    border: 1.5px solid rgba(0,0,0,0.06);
    border-radius: 3px;
    padding: 28px 24px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .coverage-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .coverage-card-icon {
    width: 44px;
    height: 44px;
    border-radius: 3px;
    background: rgba(31, 174, 155, 0.12);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05rem;
    margin-bottom: 16px;
  }

  .coverage-card-title {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--color-text-main);
    margin: 0 0 14px;
  }

  .coverage-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .coverage-list li {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .coverage-list-pills {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 8px;
  }

  .postcode-pill {
    display: inline-block;
    padding: 6px 12px;
    background: white;
    border: 1.5px solid rgba(0,0,0,0.08);
    border-radius: 3px;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-main);
    letter-spacing: 0.02em;
  }

  @media (max-width: 768px) {
    .coverage-grid { grid-template-columns: 1fr; }
  }

  /* ===== HERO ===== */
  .loc-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding-top: var(--header-height);
    overflow: hidden;
  }

  .loc-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: brightness(0.25) saturate(0.8);
  }

  .loc-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(14, 74, 77, 0.85) 0%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  .loc-hero-content {
    position: relative;
    z-index: 1;
    padding-top: 60px;
    padding-bottom: 80px;
  }

  .loc-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .loc-breadcrumb a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.2s;
  }

  .loc-breadcrumb a:hover { color: white; }
  .loc-breadcrumb span:last-child { color: var(--color-accent); font-weight: 500; }

  .loc-hero-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 60px;
    align-items: start;
  }

  .loc-hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 16px;
    display: flex;
