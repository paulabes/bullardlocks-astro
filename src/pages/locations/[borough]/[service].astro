---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GoogleReviews from '../../../components/GoogleReviews.astro';
import CTASection from '../../../components/CTASection.astro';
import { boroughs, servicesMeta, getFAQItems } from '../../../data/locations';
import { getAreaContent } from '../../../data/area-content';
import type { ServiceSlug } from '../../../data/locations';
import ServiceCards from '../../../components/ServiceCards.astro';

const { borough: boroughSlug, service: serviceSlug } = Astro.params;

// Validate params
const borough = boroughs.find((b) => b.slug === boroughSlug);
if (!borough) return new Response(null, { status: 404 });

const validServices: ServiceSlug[] = ['auto-locksmith', 'emergency-locksmith', 'safe-engineer'];
if (!validServices.includes(serviceSlug as ServiceSlug)) return new Response(null, { status: 404 });

const service = servicesMeta[serviceSlug as ServiceSlug];
if (!borough.services.includes(serviceSlug as ServiceSlug)) return new Response(null, { status: 404 });

const nearby = boroughs.filter(
  (b) => borough.nearbyBoroughs.includes(b.slug) && b.services.includes(serviceSlug as ServiceSlug)
);

const faqItems = getFAQItems(serviceSlug as ServiceSlug, borough);
const areaContent = getAreaContent(boroughSlug!, serviceSlug as ServiceSlug);

// SEO
const postcodeString = borough.postcodes.join(', ');
const pageTitle = `${service.name} ${borough.name} | ${
  serviceSlug === 'auto-locksmith'
    ? `Car Key Replacement ${borough.postcodes[0]}`
    : serviceSlug === 'emergency-locksmith'
    ? '24/7 Lockout & Break-in Repair'
    : 'Safe Opening & Installation'
} | Bullard Locks`;

const metaDescription = `${service.name} in ${borough.name} (${borough.postcodes.slice(0, 3).join(', ')}). ${
  serviceSlug === 'auto-locksmith'
    ? 'Car key replacement, programming & vehicle lockout. All makes & models.'
    : serviceSlug === 'emergency-locksmith'
    ? '24/7 rapid response, 20–40 min arrival. Lockouts, break-in repair.'
    : 'Non-destructive safe opening, installation & combination changes.'
} No call-out fee. Call 07809 887 883.`;

// Hero images (local)
const heroImages: Record<ServiceSlug, string> = {
  'auto-locksmith': '/images/hero-auto-locksmith.webp',
  'emergency-locksmith': '/images/hero-emergency-locksmith.webp',
  'safe-engineer': '/images/hero-safe-engineer.webp',
};
const heroImage = heroImages[serviceSlug as ServiceSlug];

// Schema
const siteUrl = 'https://bullardlocks.com';
const pageUrl = `${siteUrl}/locations/${boroughSlug}/${serviceSlug}`;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: `${service.name} ${borough.name}`,
    provider: {
      '@type': 'LocksmithBusiness',
      name: 'Bullard Locks',
      telephone: '07809887883',
      url: 'https://bullardlocks.com',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '67 Weston Park',
        addressLocality: 'Crouch End',
        addressRegion: 'London',
        postalCode: 'N8 9TA',
        addressCountry: 'GB',
      },
    },
    areaServed: borough.postcodes.map((pc) => ({ '@type': 'PostalAddress', postalCode: pc, addressCountry: 'GB' })),
    description: metaDescription,
    url: pageUrl,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Locations', item: `${siteUrl}/locations` },
      { '@type': 'ListItem', position: 3, name: borough.name, item: `${siteUrl}/locations/${boroughSlug}` },
      { '@type': 'ListItem', position: 4, name: service.name, item: pageUrl },
    ],
  },
];
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonicalUrl={pageUrl}
  schema={schema}
>

  <!-- HERO -->
  <section class="loc-hero bg-dark">
    <div class="loc-hero-bg" style={`background-image: url('${heroImage}')`} aria-hidden="true"></div>
    <div class="loc-hero-overlay" aria-hidden="true"></div>
    <div class="container-custom loc-hero-content">
      <!-- Breadcrumb -->
      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/locations">Locations</a>
        <span aria-hidden="true">/</span>
        <a href={`/locations/${boroughSlug}`}>{borough.name}</a>
        <span aria-hidden="true">/</span>
        <span>{service.name}</span>
      </nav>

      <div class="loc-hero-grid">
        <div class="loc-hero-left">
          <h1 class="loc-hero-title">
            <span class="loc-hero-service">{service.name}</span>
            <span class="loc-hero-location">{borough.name}</span>
          </h1>

          <p class="loc-hero-postcodes">
            <i class="fas fa-map-marker-alt"></i>
            {postcodeString}
          </p>

          <p class="loc-hero-lead">{service.tagline}</p>

          <div class="loc-hero-ctas">
            <a href="tel:07809887883" class="btn-hero-primary">
              <i class="fas fa-phone"></i> 07809 887 883
            </a>
            <a href="https://wa.me/447809887883" class="btn-hero-whatsapp" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> WhatsApp
            </a>
          </div>

          <!-- Trust bar -->
          <div class="loc-trust-bar">
            <div class="loc-trust-item">
              <i class="fas fa-star"></i>
              <span>5.0 Google</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-shield-alt"></i>
              <span>Met Police Approved</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-award"></i>
              <span>30+ Years Experience</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-tag"></i>
              <span>No Call-Out Fee</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-check-circle"></i>
              <span>Fully Insured</span>
            </div>
          </div>
        </div>

        <!-- Sticky conversion panel (desktop) -->
        <div class="loc-hero-panel">
          <div class="conv-panel">
            <div class="conv-panel-header">
              <i class="fas fa-phone"></i>
              <div>
                <p class="conv-panel-label">Call us now</p>
                <a href="tel:07809887883" class="conv-panel-number">07809 887 883</a>
              </div>
            </div>
            <p class="conv-panel-note">Or request a callback:</p>
            <form id="callback-form" class="conv-form">
              <input type="text" name="name" placeholder="Your name" class="conv-input" required />
              <input type="tel" name="phone" placeholder="Your phone number" class="conv-input" required />
              <input type="hidden" name="service" value={serviceSlug} />
              <input type="hidden" name="location" value={borough.name} />
              <input type="hidden" name="form_type" value="callback" />
              <input type="hidden" name="message" value={`Callback request for ${service.name} in ${borough.name}`} />
              <button type="submit" class="conv-submit">
                <i class="fas fa-phone"></i> Request Callback
              </button>
              <div class="conv-form-status" style="display:none;"></div>
            </form>
            <a href="https://wa.me/447809887883" class="conv-whatsapp" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> Message on WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">{service.name} Services in {borough.name}</h2>
        <p class="section-subtitle">{borough.description}</p>
      </div>

      <div class="services-4-grid">
        {service.includedServices.map((item) => (
          <div class="service-detail-card">
            <div class="sdc-icon">
              <i class={item.icon}></i>
            </div>
            <h3 class="sdc-title">{item.title}</h3>
            <p class="sdc-desc">{item.description}</p>
          </div>
        ))}
      </div>

      <!-- Features list -->
      <div class="features-pill-row">
        {service.features.map((f) => (
          <span class="feature-pill">
            <i class="fas fa-check"></i> {f}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- AREA CONTENT -->
  <section class="content-section bg-light">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">{areaContent.heading}</h2>
      </div>
      <div class="area-content-grid">
        <div class="area-content-image">
          <img src={areaContent.image} alt={areaContent.imageAlt} width="900" height="600" loading="lazy" />
          <a href="https://www.google.com/maps/place/?q=place_id:ChIJU7O3P5IbdkgRVm-wppoH9-4" target="_blank" rel="noopener noreferrer" class="area-star-card">
            <div class="area-star-icon"><i class="fas fa-star"></i></div>
            <div class="area-star-text">
              <span class="area-star-rating">5.0 Rating</span>
              <span class="area-star-source">Google Reviews</span>
            </div>
          </a>
        </div>
        <div class="area-content-text">
          {areaContent.paragraphs.map((p) => (
            <p class="area-paragraph">{p}</p>
          ))}
        </div>
      </div>
      <div class="area-content-ctas">
        <a href="tel:07809887883" class="btn-primary-lg">
          <i class="fas fa-phone"></i> 07809 887 883
        </a>
        <a href="https://wa.me/447809887883" class="btn-whatsapp-lg" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-whatsapp"></i> WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Other Services in this Borough -->
  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Other Services in {borough.name}</h2>
      </div>
      <ServiceCards boroughSlug={boroughSlug} boroughName={borough.name} services={borough.services.filter(s => s !== serviceSlug)} />
    </div>
  </section>

  <!-- HOW WE WORK -->
  <section class="content-section bg-dark">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">How We Work</h2>
        <p class="section-subtitle">Three simple steps to get the problem sorted.</p>
      </div>

      <div class="how-it-works-grid">
        <div class="hiw-step">
          <div class="hiw-number">01</div>
          <h3>Call or Message</h3>
          <p>Call <a href="tel:07809887883" style="color:var(--color-accent)">07809 887 883</a> or <a href="https://wa.me/447809887883" target="_blank" rel="noopener noreferrer" style="color:var(--color-accent)">WhatsApp</a>. Tell us your location in {borough.name} and the problem.</p>
        </div>
        <div class="hiw-step">
          <div class="hiw-number">02</div>
          <h3>We Dispatch</h3>
          <p>William comes to you in {borough.name}. Typical arrival: {borough.responseTime}. You'll get a fixed quote before any work begins.</p>
        </div>
        <div class="hiw-step">
          <div class="hiw-number">03</div>
          <h3>Problem Solved</h3>
          <p>Work is completed on the spot in most cases. No call-out fee — you only pay for what's done.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FULL CONVERSION FORM -->
  <section class="content-section bg-white" id="get-quote">
    <div class="container-custom">
      <div class="quote-form-layout">
        <div class="quote-form-card">
          <form id="quote-form" enctype="multipart/form-data">
            <input type="hidden" name="form_type" value="location-quote" />
            <input type="hidden" name="service" value={serviceSlug} />
            <input type="hidden" name="location_borough" value={borough.name} />

            <div class="form-group">
              <label for="q-name" class="form-label">Your Name *</label>
              <input type="text" id="q-name" name="name" class="form-control-modern" placeholder="John Smith" required />
            </div>
            <div class="form-group">
              <label for="q-phone" class="form-label">Phone Number *</label>
              <input type="tel" id="q-phone" name="phone" class="form-control-modern" placeholder="07700 900000" required />
            </div>
            <div class="form-group">
              <label for="q-email" class="form-label">Email (optional)</label>
              <input type="email" id="q-email" name="email" class="form-control-modern" placeholder="john@example.com" />
            </div>
            <div class="form-group">
              <label for="q-message" class="form-label">Describe Your Situation *</label>
              <textarea
                id="q-message"
                name="message"
                class="form-control-modern"
                rows="4"
                placeholder={serviceSlug === 'auto-locksmith'
                  ? `e.g. "Lost all keys to my 2019 Ford Focus in ${borough.areas[0]}"`
                  : serviceSlug === 'emergency-locksmith'
                  ? `e.g. "Locked out of my flat in ${borough.areas[0]}, lock won't turn"`
                  : `e.g. "Chubb safe, forgotten combination, home in ${borough.areas[0]}"`}
                required
              ></textarea>
            </div>

            <div id="quote-form-status" class="form-status" style="display:none;"></div>

            <button type="submit" class="btn-primary-lg w-full" style="justify-content:center;" id="quote-submit">
              <i class="fas fa-paper-plane"></i>
              <span class="btn-text">Get My Quote</span>
              <span class="btn-loading" style="display:none;"><i class="fas fa-spinner fa-spin"></i> Sending...</span>
            </button>

            <p class="form-privacy-note">
              <i class="fas fa-lock"></i> Your details are kept private and never shared.
            </p>
          </form>
        </div>

        <div class="quote-form-copy">
          <h2 class="section-title" style="text-align:left;">Get a Quote for {service.name} in {borough.name}</h2>
          <p style="color:var(--color-text-muted); line-height:1.7; margin-bottom: 24px;">
            Fill in the short form and William will get back to you promptly with a clear, no-obligation quote.
            For immediate help, call <a href="tel:07809887883" style="color:var(--color-accent); font-weight:700;">07809 887 883</a>.
          </p>
          <ul class="quote-trust-list">
            <li><i class="fas fa-check-circle"></i> No call-out fee</li>
            <li><i class="fas fa-check-circle"></i> Fixed price quoted before work starts</li>
            <li><i class="fas fa-check-circle"></i> No hidden charges</li>
            <li><i class="fas fa-check-circle"></i> Met Police approved contractor</li>
            <li><i class="fas fa-check-circle"></i> 30+ years experience</li>
          </ul>
          <div class="photo-upload-callout">
            <i class="fas fa-camera"></i>
            <div>
              <strong>Need to send a photo?</strong>
              <p>Use our <a href="/contact">contact form</a> to upload up to 5 images of your lock, key or safe.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ + RESPONSE TIME -->
  <section class="content-section bg-light" id="faq">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">{service.name} {borough.name} — FAQ</h2>
        <p class="section-subtitle">Common questions about our {service.name.toLowerCase()} service in {borough.name}.</p>
      </div>

      <div class="faq-with-card">
        <div class="faq-grid">
          {faqItems.map((item, i) => (
            <details class="faq-item" open={i === 0}>
              <summary class="faq-question">
                <span>{item.q}</span>
                <i class="fas fa-chevron-down faq-icon"></i>
              </summary>
              <div class="faq-answer">{item.a}</div>
            </details>
          ))}
        </div>
        <div class="faq-sidebar">
          <div class="response-time-card">
            <div class="rtc-header">
              <i class="fas fa-bolt"></i>
              <h3>Response Time</h3>
            </div>
            <div class="rtc-time">{borough.responseTime}</div>
            <p class="rtc-note">Typical arrival time in {borough.name}</p>
            <div class="rtc-divider"></div>
            <div class="rtc-stat">
              <i class="fas fa-map-marker-alt"></i>
              <span>Based in Crouch End N8</span>
            </div>
            <div class="rtc-stat">
              <i class="fas fa-car"></i>
              <span>Fully equipped mobile unit</span>
            </div>
            <div class="rtc-stat">
              <i class="fas fa-clock"></i>
              <span>
                {serviceSlug === 'emergency-locksmith' ? '24/7 emergency availability' : 'Available 7 days a week'}
              </span>
            </div>
            <a href="tel:07809887883" class="btn-primary-lg" style="width:100%; justify-content:center; margin-top:20px;">
              <i class="fas fa-phone"></i> Call Now
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEARBY AREAS -->
  {nearby.length > 0 && (
    <section class="content-section bg-white">
      <div class="container-custom">
        <div class="section-header">
          <h2 class="section-title">Nearby Areas We Also Cover</h2>
          <p class="section-subtitle">We serve all these boroughs for {service.name.toLowerCase()} services.</p>
        </div>

        <div class="nearby-grid">
          {nearby.map((nb) => (
            <a href={`/locations/${nb.slug}/${serviceSlug}`} class="nearby-card">
              <div class="nearby-card-content">
                <h3 class="nearby-name">{nb.name}</h3>
                <p class="nearby-postcodes">{nb.postcodes.slice(0, 3).join(', ')}</p>
                <p class="nearby-time"><i class="fas fa-clock"></i> {nb.responseTime}</p>
              </div>
              <i class="fas fa-arrow-right nearby-arrow"></i>
            </a>
          ))}
          <a href="/locations" class="nearby-card nearby-all">
            <div class="nearby-card-content">
              <h3 class="nearby-name">All Locations</h3>
              <p class="nearby-postcodes">View all areas we serve</p>
            </div>
            <i class="fas fa-arrow-right nearby-arrow"></i>
          </a>
        </div>
      </div>
    </section>
  )}

  <GoogleReviews bg="light" />

  <CTASection
    title={`Need a ${service.name} in ${borough.name}?`}
    subtitle={`Call now for fast response across ${postcodeString} | No call-out fee | 30+ years experience`}
  />

</BaseLayout>

<style>
  /* ===== HERO ===== */
  .loc-hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding-top: var(--header-height);
    overflow: hidden;
  }

  .loc-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: brightness(0.25) saturate(0.8);
  }

  .loc-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(14, 74, 77, 0.85) 0%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  .loc-hero-content {
    position: relative;
    z-index: 1;
    padding-top: 60px;
    padding-bottom: 80px;
  }

  .loc-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .loc-breadcrumb a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.2s;
  }

  .loc-breadcrumb a:hover {
    color: white;
  }

  .loc-breadcrumb span:last-child {
    color: var(--color-accent);
    font-weight: 500;
  }

  .loc-hero-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 60px;
    align-items: start;
  }

  .loc-hero-title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 16px;
    display: flex;
    flex-direction: column;
  }

  .loc-hero-service {
    color: var(--color-accent);
  }

  .loc-hero-location {
    color: white;
  }

  .loc-hero-postcodes {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.65);
    font-size: 0.9rem;
    margin: 0 0 16px;
  }

  .loc-hero-postcodes i {
    color: var(--color-accent);
  }

  .loc-hero-lead {
    color: rgba(255,255,255,0.8);
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0 0 32px;
    max-width: 560px;
  }

  .loc-hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
    background: var(--color-accent);
    color: white;
    border-radius: 100px;
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: 0 4px 20px rgba(31, 174, 155, 0.4);
  }

  .btn-hero-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(31, 174, 155, 0.5);
  }

  .btn-hero-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
    background: #25D366;
    color: white;
    border: none;
    border-radius: 100px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(37,211,102,0.35);
    transition: all 0.2s ease;
  }

  .btn-hero-whatsapp:hover {
    background: #1DA851;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(37,211,102,0.45);
  }

  .loc-trust-bar {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
  }

  .loc-trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 16px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    font-weight: 500;
  }

  .loc-trust-item:first-child { padding-left: 0; }
  .loc-trust-item + .loc-trust-item { border-left: 1px solid rgba(255,255,255,0.28); }

  .loc-trust-item i {
    color: var(--color-accent);
    font-size: 0.9rem;
  }

  /* Conversion Panel */
  .conv-panel {
    background: white;
    border-radius: 20px;
    padding: 28px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    position: sticky;
    top: 100px;
  }

  .conv-panel-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }

