---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GoogleReviews from '../../../components/GoogleReviews.astro';
import HighlightsBar from '../../../components/HighlightsBar.astro';
import CTASection from '../../../components/CTASection.astro';
import TrustCredentials from '../../../components/TrustCredentials.astro';
import { boroughs, servicesMeta, getFAQItems } from '../../../data/locations';
import { getAreaContent } from '../../../data/area-content';
import { boroughGeoData } from '../../../data/borough-geo';
import type { ServiceSlug } from '../../../data/locations';
import ServiceCards from '../../../components/ServiceCards.astro';

export const prerender = true;

export function getStaticPaths() {
  return boroughs.flatMap((b) =>
    b.services.map((s) => ({ params: { borough: b.slug, service: s } }))
  );
}

const { borough: boroughSlug, service: serviceSlug } = Astro.params;

// Validate params
const borough = boroughs.find((b) => b.slug === boroughSlug);
if (!borough) return new Response(null, { status: 404 });

const validServices: ServiceSlug[] = ['auto-locksmith', 'emergency-locksmith', 'safe-engineer'];
if (!validServices.includes(serviceSlug as ServiceSlug)) return new Response(null, { status: 404 });

const service = servicesMeta[serviceSlug as ServiceSlug];
if (!borough.services.includes(serviceSlug as ServiceSlug)) return new Response(null, { status: 404 });

const nearby = boroughs.filter(
  (b) => borough.nearbyBoroughs.includes(b.slug) && b.services.includes(serviceSlug as ServiceSlug)
);

// Related services in this borough (sibling service pages)
const siblingServices = borough.services.filter(s => s !== serviceSlug);

const faqItems = getFAQItems(serviceSlug as ServiceSlug, borough);
const areaContent = getAreaContent(boroughSlug!, serviceSlug as ServiceSlug);

// SEO - unique per (borough × service) pairing using borough-specific signals
const postcodeString = borough.postcodes.join(', ');
const primaryPostcode = borough.postcodes[0];
const primaryArea = borough.areas[0];

const pageTitle = serviceSlug === 'auto-locksmith'
  ? `Auto Locksmith ${borough.name} - Car Key Replacement ${primaryPostcode} | Bullard Locks`
  : serviceSlug === 'emergency-locksmith'
  ? `Emergency Locksmith ${borough.name} - ${borough.responseTime} response ${primaryPostcode} | Bullard Locks`
  : `Safe Engineer ${borough.name} - Opening & Installation ${primaryPostcode} | Bullard Locks`;

const metaDescription = serviceSlug === 'auto-locksmith'
  ? `Mobile auto locksmith ${borough.name} (${borough.postcodes.slice(0, 3).join(', ')}) - car key replacement, transponder programming & vehicle lockout from ${primaryArea}. All makes. ${borough.responseTime} response. No call-out fee. 07809 887 883.`
  : serviceSlug === 'emergency-locksmith'
  ? `24/7 emergency locksmith ${borough.name} - ${borough.responseTime} arrival across ${borough.postcodes.slice(0, 3).join(', ')}. Lockouts, break-in repair, urgent lock changes from ${primaryArea} to all areas. No call-out fee. 07809 887 883.`
  : `Safe engineer ${borough.name} - non-destructive safe opening, installation & combination changes across ${borough.postcodes.slice(0, 3).join(', ')}. All major brands. From ${primaryArea} to wider ${borough.name}. By appointment. 07809 887 883.`;

// Hero images (local)
const heroImages: Record<ServiceSlug, string> = {
  'auto-locksmith': '/images/hero-auto-locksmith.webp',
  'emergency-locksmith': '/images/hero-emergency-locksmith.webp',
  'safe-engineer': '/images/hero-safe-engineer.webp',
};
const heroImage = heroImages[serviceSlug as ServiceSlug];

// Schema
const siteUrl = 'https://www.bullardlocks.com';
const pageUrl = `${siteUrl}/locations/${boroughSlug}/${serviceSlug}`;
// Safe engineering is a UK-wide specialist service - canonicalise the 10 borough×safe-engineer
// combos to the main service page so ranking equity consolidates rather than fragments across
// near-duplicate templated pages. The borough URLs remain crawlable for users who land on them.
const canonicalUrl = serviceSlug === 'safe-engineer'
  ? `${siteUrl}/services/safe-engineer`
  : pageUrl;
const geoData = boroughGeoData[boroughSlug!];

// HowTo schema - service-specific steps
const howToSchema = serviceSlug === 'auto-locksmith' ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `What to do when you're locked out of your car in ${borough.name}`,
  description: `Step-by-step guide for dealing with a vehicle lockout in ${borough.name}. Professional auto locksmith help is available within ${borough.responseTime}.`,
  totalTime: 'PT90M',
  estimatedCost: { '@type': 'MonetaryAmount', currency: 'GBP', value: '150' },
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Stay calm and check all doors', text: 'Before calling a locksmith, check all doors, the boot, and any windows that may be slightly open. If you have a spare key nearby, try to retrieve it. Do not attempt to force the door open - this can cause costly damage to the lock mechanism and door frame.' },
    { '@type': 'HowToStep', position: 2, name: 'Call a qualified auto locksmith', text: 'Call Bullard Locks on 07809 887 883. Provide your exact location, the vehicle make, model and year, and a description of the problem. You will receive an estimated arrival time and a fixed price quote before the locksmith dispatches.' },
    { '@type': 'HowToStep', position: 3, name: 'Wait in a safe location', text: 'Stay near the vehicle in a safe, well-lit area. If you are in a car park, inform the attendant. If on a public road, ensure the vehicle is not causing an obstruction. The locksmith will call when nearby.' },
    { '@type': 'HowToStep', position: 4, name: 'Locksmith opens the vehicle', text: 'The auto locksmith uses specialist non-destructive tools to gain entry to the vehicle without damaging the lock, paintwork or door seals. Most vehicle lockouts are resolved within 15-30 minutes of the locksmith arriving.' },
  ],
} : serviceSlug === 'emergency-locksmith' ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `What to do when locked out of your home in ${borough.name}`,
  description: `Step-by-step guide for dealing with a home lockout in ${borough.name}. Emergency locksmith help is available 24/7 within ${borough.responseTime}.`,
  totalTime: 'PT60M',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Check all entry points', text: 'Check all doors and accessible windows before calling a locksmith. If you live in a shared building, try the intercom or contact your landlord or managing agent for a spare key. Do not attempt to force any door or window - this may cause damage and could trigger an alarm.' },
    { '@type': 'HowToStep', position: 2, name: 'Call an emergency locksmith', text: 'Call Bullard Locks on 07809 887 883 (available 24/7, 365 days). Describe the lock type if you can (Yale nightlatch, Euro cylinder, multipoint UPVC) and your exact address. You will receive an arrival estimate and upfront price before the locksmith dispatches.' },
    { '@type': 'HowToStep', position: 3, name: 'Verify the locksmith\'s identity', text: 'When the locksmith arrives, ask to see photo identification and proof of professional registration. A legitimate locksmith will carry an ID card, trade association membership, and be happy to show you these documents before starting work.' },
    { '@type': 'HowToStep', position: 4, name: 'Locksmith gains entry and secures the property', text: 'The locksmith uses specialist non-destructive techniques to open the door. In most cases, the existing lock can be used again. If the lock needs replacing - for example, after a break-in - the locksmith fits a new British Standard lock on the same visit.' },
  ],
} : {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `What to do when your safe won't open`,
  description: `Step-by-step guide for dealing with a safe that won't open. Professional safe engineer services available in ${borough.name} by appointment.`,
  totalTime: 'PT180M',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Try the obvious solutions first', text: 'For electronic safes, replace the battery (usually a 9V or 4×AA behind the keypad). Try the combination slowly and deliberately - rushing is the most common cause of failed attempts. For key-operated safes, try lubricating the keyhole with graphite spray. Do not force the handle or attempt to drill the safe yourself.' },
    { '@type': 'HowToStep', position: 2, name: 'Note the safe details', text: 'Write down the safe make, model number, and the type of lock (electronic keypad, mechanical dial, key). This information is usually on a plate inside the door or on the base of the safe. Having these details ready helps the safe engineer prepare the correct tools.' },
    { '@type': 'HowToStep', position: 3, name: 'Contact a qualified safe engineer', text: 'Call Bullard Locks on 07809 887 883. Provide the safe details and describe the problem. You will receive an honest assessment of the likely method, time required and cost before any appointment is booked.' },
    { '@type': 'HowToStep', position: 4, name: 'Safe engineer opens and services the safe', text: 'The safe engineer attempts non-destructive opening first - this preserves the safe for continued use. If the safe must be drilled (a last resort), the engineer will discuss this with you before proceeding. After opening, the combination or key is reset so the safe can be used again.' },
  ],
};

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: `${service.name} ${borough.name}`,
    provider: {
      '@type': ['LocalBusiness', 'LocksmithBusiness'],
      name: 'Bullard Locks',
      telephone: '+447809887883',
      url: 'https://www.bullardlocks.com',
      image: `${siteUrl}/images/william-bullard-trusted-london-locksmith.webp`,
      priceRange: '££',
      openingHoursSpecification: [
        {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
          opens: '00:00',
          closes: '23:59',
        },
      ],
      address: {
        '@type': 'PostalAddress',
        streetAddress: '67 Weston Park',
        addressLocality: 'Crouch End',
        addressRegion: 'London',
        postalCode: 'N8 9TA',
        addressCountry: 'GB',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 51.5786,
        longitude: -0.1227,
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '5.0',
        bestRating: '5',
        worstRating: '1',
        ratingCount: '23',
        reviewCount: '23',
      },
      sameAs: [
        'https://g.page/bullardlocks',
        'https://www.facebook.com/bullardlocks',
        'https://www.instagram.com/bullardlocks',
      ],
    },
    areaServed: [
      ...borough.postcodes.map((pc) => ({ '@type': 'PostalAddress', postalCode: pc, addressCountry: 'GB' })),
      { '@type': 'City', name: borough.name, containedInPlace: { '@type': 'City', name: 'London' } },
      ...(geoData ? [{ '@type': 'GeoShape', polygon: geoData.polygon }] : []),
    ],
    serviceType: serviceSlug === 'auto-locksmith'
      ? ['Car Key Replacement', 'Car Key Programming', 'Vehicle Lockout', 'Transponder Programming', 'Key Fob Replacement']
      : serviceSlug === 'emergency-locksmith'
      ? ['Emergency Lockout', 'Break-in Repair', 'Lock Replacement', 'Key Extraction', 'Emergency Lock Change']
      : ['Safe Opening', 'Safe Cracking', 'Safe Installation', 'Safe Repair', 'Combination Change'],
    description: metaDescription,
    url: pageUrl,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.a,
      },
    })),
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['.faq-answer'],
    },
  },
  howToSchema,
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Locations', item: `${siteUrl}/locations` },
      { '@type': 'ListItem', position: 3, name: borough.name, item: `${siteUrl}/locations/${boroughSlug}` },
      { '@type': 'ListItem', position: 4, name: service.name, item: pageUrl },
    ],
  },
];
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonicalUrl={canonicalUrl}
  ogImage={`https://www.bullardlocks.com${heroImage}`}
  schema={schema}
  preloadImage={heroImage}
>

  <!-- HERO -->
  <section class="loc-hero bg-dark">
    <div class="loc-hero-bg" style={`background-image: url('${heroImage}')`} aria-hidden="true"></div>
    <div class="loc-hero-overlay" aria-hidden="true"></div>
    <div class="container-custom loc-hero-content">
      <!-- Breadcrumb -->
      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/locations">Locations</a>
        <span aria-hidden="true">/</span>
        <a href={`/locations/${boroughSlug}`}>{borough.name}</a>
        <span aria-hidden="true">/</span>
        <span>{service.name}</span>
      </nav>

      <div class="loc-hero-grid">
        <div class="loc-hero-left">
          <h1 class="loc-hero-title">
            <span class="loc-hero-service">{service.name}</span>
            <span class="loc-hero-location">{borough.name}</span>
          </h1>

          <p class="loc-hero-postcodes">
            <i class="fas fa-map-marker-alt"></i>
            {postcodeString}
          </p>

          <p class="loc-hero-lead">{service.tagline}</p>

          <div class="loc-hero-ctas">
            <a href="tel:07809887883" class="btn-hero-primary">
              <i class="fas fa-phone"></i> 07809 887 883
            </a>
            <a href="https://wa.me/447809887883" class="btn-hero-whatsapp" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> WhatsApp
            </a>
          </div>

          <!-- Trust bar -->
          <div class="loc-trust-bar">
            <div class="loc-trust-item">
              <i class="fas fa-star"></i>
              <span>5.0 Google</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-shield-alt"></i>
              <span>Met Police Approved</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-award"></i>
              <span>30+ Years Experience</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-tag"></i>
              <span>No Call-Out Fee</span>
            </div>
            <div class="loc-trust-item">
              <i class="fas fa-check"></i>
              <span>Fully Insured</span>
            </div>
          </div>
        </div>

        <!-- Sticky conversion panel (desktop) -->
        <div class="loc-hero-panel">
          <div class="conv-panel">
            <div class="conv-panel-header">
              <i class="fas fa-phone"></i>
              <div>
                <p class="conv-panel-label">Call us now</p>
                <a href="tel:07809887883" class="conv-panel-number">07809 887 883</a>
              </div>
            </div>
            <p class="conv-panel-note">Or request a callback:</p>
            <form id="callback-form" class="conv-form">
              <input type="text" name="name" placeholder="Your name" class="conv-input" required />
              <input type="tel" name="phone" placeholder="Your phone number" class="conv-input" required />
              <input type="hidden" name="service" value={serviceSlug} />
              <input type="hidden" name="location" value={borough.name} />
              <input type="hidden" name="form_type" value="callback" />
              <input type="hidden" name="message" value={`Callback request for ${service.name} in ${borough.name}`} />
              <button type="submit" class="conv-submit">
                <i class="fas fa-phone"></i> Request Callback
              </button>
              <div class="conv-form-status" style="display:none;"></div>
            </form>
            <a href="https://wa.me/447809887883" class="conv-whatsapp" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> Message on WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">{service.name} Services in {borough.name}</h2>
        <p class="section-subtitle">{borough.description}</p>
      </div>

      <div class="services-4-grid">
        {service.includedServices.map((item) => (
          <div class="service-detail-card">
            <div class="sdc-icon">
              <i class={item.icon}></i>
            </div>
            <h3 class="sdc-title">{item.title}</h3>
            <p class="sdc-desc">{item.description}</p>
          </div>
        ))}
      </div>

      <!-- Features list -->
      <div class="features-pill-row">
        {service.features.map((f) => (
          <span class="feature-pill">
            <i class="fas fa-check"></i> {f}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- AREA CONTENT -->
  <section class="content-section bg-light">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">{areaContent.heading}</h2>
      </div>
      <div class="area-content-grid">
        <div class="area-content-image">
          <img src={areaContent.image} alt={areaContent.imageAlt} width="900" height="600" loading="lazy" />
          <a href="https://www.google.com/maps/place/?q=place_id:ChIJU7O3P5IbdkgRVm-wppoH9-4" target="_blank" rel="noopener noreferrer" class="area-star-card">
            <div class="area-star-icon"><i class="fas fa-star"></i></div>
            <div class="area-star-text">
              <span class="area-star-rating">5.0 Rating</span>
              <span class="area-star-source">Google Reviews</span>
            </div>
          </a>
        </div>
        <div class="area-content-text">
          {areaContent.paragraphs.map((p) => (
            <p class="area-paragraph">{p}</p>
          ))}
        </div>
      </div>
      <div class="area-content-ctas">
        <a href="tel:07809887883" class="btn-primary-lg">
          <i class="fas fa-phone"></i> 07809 887 883
        </a>
        <a href="https://wa.me/447809887883" class="btn-whatsapp-lg" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-whatsapp"></i> WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- LOCAL COVERAGE - unique per borough (areas, postcodes, landmarks) -->
  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">{service.name} Coverage in {borough.name}</h2>
        <p class="section-subtitle">Neighbourhoods, postcodes and landmarks within our {borough.name} {service.name.toLowerCase()} catchment.</p>
      </div>

      <div class="coverage-grid">
        <div class="coverage-col">
          <h3 class="coverage-col-title">Neighbourhoods</h3>
          <ul class="coverage-list">
            {borough.areas.map((area) => <li>{area}</li>)}
          </ul>
        </div>

        <div class="coverage-col">
          <h3 class="coverage-col-title">Postcodes</h3>
          <ul class="coverage-list coverage-list-pills">
            {borough.postcodes.map((pc) => <li><span class="postcode-pill">{pc}</span></li>)}
          </ul>
        </div>

        <div class="coverage-col">
          <h3 class="coverage-col-title">Local Landmarks</h3>
          <ul class="coverage-list">
            {borough.landmarks.map((lm) => <li>Near {lm}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Services in this Borough -->
  {siblingServices.length > 0 && (
    <section class="content-section bg-light">
      <div class="container-custom">
        <div class="section-header">
          <h2 class="section-title">Related Services in {borough.name}</h2>
          <p class="section-subtitle">We also provide these locksmith services across all {borough.name} postcodes.</p>
        </div>
        <ServiceCards boroughSlug={boroughSlug} boroughName={borough.name} services={siblingServices} />
      </div>
    </section>
  )}

  <!-- HOW WE WORK -->
  <section class="content-section bg-dark">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">How We Work</h2>
        <p class="section-subtitle">Three simple steps to get the problem sorted.</p>
      </div>

      <div class="how-it-works-grid">
        <div class="hiw-step">
          <div class="hiw-number">01</div>
          <h3>Call or Message</h3>
          <p>Call <a href="tel:07809887883" style="color:var(--color-accent)">07809 887 883</a> or <a href="https://wa.me/447809887883" target="_blank" rel="noopener noreferrer" style="color:var(--color-accent)">WhatsApp</a>. Tell us your location in {borough.name} and the problem.</p>
        </div>
        <div class="hiw-step">
          <div class="hiw-number">02</div>
          <h3>We Dispatch</h3>
          <p>William comes to you in {borough.name}. Typical arrival: {borough.responseTime}. You'll get a fixed quote before any work begins.</p>
        </div>
        <div class="hiw-step">
          <div class="hiw-number">03</div>
          <h3>Problem Solved</h3>
          <p>Work is completed on the spot in most cases. No call-out fee - you only pay for what's done.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FULL CONVERSION FORM -->
  <section class="content-section bg-white" id="get-quote">
    <div class="container-custom">
      <div class="quote-cta-section">
        <h2 class="section-title">Get a Quote for {service.name} in {borough.name}</h2>
        <p class="quote-cta-text">
          Get in touch and William will get back to you promptly with a clear, no-obligation quote.
          For immediate help, call <a href="tel:07809887883" style="color:var(--color-accent); font-weight:700;">07809 887 883</a>.
        </p>
        <a href="/contact" class="btn-primary-lg" style="justify-content:center; display:inline-flex;">
          <i class="fas fa-paper-plane"></i> Get a Quote
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ + RESPONSE TIME -->
  <section class="content-section bg-light" id="faq">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">{service.name} {borough.name} - FAQ</h2>
        <p class="section-subtitle">Common questions about our {service.name.toLowerCase()} service in {borough.name}.</p>
      </div>

      <div class="faq-with-card">
        <div class="faq-grid">
          {faqItems.map((item, i) => (
            <details class="faq-item" open={i === 0}>
              <summary class="faq-question">
                <span>{item.q}</span>
                <i class="fas fa-chevron-down faq-icon"></i>
              </summary>
              <div class="faq-answer">{item.a}</div>
            </details>
          ))}
        </div>
        <div class="faq-sidebar">
          <div class="response-time-card">
            <div class="rtc-header">
              <i class="fas fa-bolt"></i>
              <h3>Response Time</h3>
            </div>
            <div class="rtc-time">{borough.responseTime}</div>
            <p class="rtc-note">Typical arrival time in {borough.name}</p>
            <div class="rtc-divider"></div>
            <div class="rtc-stat">
              <i class="fas fa-map-marker-alt"></i>
              <span>Based in Crouch End N8</span>
            </div>
            <div class="rtc-stat">
              <i class="fas fa-car"></i>
              <span>Fully equipped mobile unit</span>
            </div>
            <div class="rtc-stat">
              <i class="fas fa-clock"></i>
              <span>
                {serviceSlug === 'emergency-locksmith' ? '24/7 emergency availability' : 'Available 7 days a week'}
              </span>
            </div>
            <a href="tel:07809887883" class="btn-primary-lg" style="width:100%; justify-content:center; margin-top:20px;">
              <i class="fas fa-phone"></i> Call Now
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <TrustCredentials />

  <HighlightsBar items={[
    { icon: 'fa-stopwatch', text: borough.responseTime },
    { icon: 'fa-map-marker-alt', text: 'Local coverage' },
    { icon: 'fa-check-circle', text: 'Fixed price quoted' },
    { icon: 'fa-pound-sign', text: 'No call-out fee' },
  ]} />

  <GoogleReviews bg="light" />

  <!-- NEARBY AREAS -->
  {nearby.length > 0 && (
    <section class="content-section bg-white">
      <div class="container-custom">
        <div class="section-header">
          <h2 class="section-title">Nearby Areas We Also Cover</h2>
          <p class="section-subtitle">We serve all these boroughs for {service.name.toLowerCase()} services.</p>
        </div>

        <div class="nearby-grid">
          {nearby.map((nb) => (
