<script>
  // Callback form in hero panel
  const callbackForm = document.getElementById('callback-form') as HTMLFormElement;
  callbackForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const status = callbackForm.querySelector('.conv-form-status') as HTMLDivElement;
    const btn = callbackForm.querySelector('.conv-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const fd = new FormData(callbackForm);
      const res = await fetch('/api/send-email', { method: 'POST', body: fd });
      const data = await res.json();
      if (data.success) {
        status.className = 'conv-form-status success';
        status.textContent = '✓ Received! William will call you back shortly.';
        status.style.display = 'block';
        callbackForm.reset();
      } else throw new Error();
    } catch {
      status.className = 'conv-form-status error';
      status.textContent = 'Something went wrong. Please call us directly.';
      status.style.display = 'block';
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-phone"></i> Request Callback';
    }
  });

  // Quote form
  const quoteForm = document.getElementById('quote-form') as HTMLFormElement;
  quoteForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const status = document.getElementById('quote-form-status') as HTMLDivElement;
    const btn = document.getElementById('quote-submit') as HTMLButtonElement;
    const btnText = btn.querySelector('.btn-text') as HTMLSpanElement;
    const btnLoading = btn.querySelector('.btn-loading') as HTMLSpanElement;

    btn.disabled = true;
    btnText.style.display = 'none';
    btnLoading.style.display = 'inline-flex';
    status.style.display = 'none';

    try {
      const fd = new FormData(quoteForm);
      // Merge the hidden location into message
      const loc = fd.get('location_borough') as string;
      const msg = fd.get('message') as string;
      fd.set('message', `[${loc}] ${msg}`);

      const res = await fetch('/api/send-email', { method: 'POST', body: fd });
      const data = await res.json();
      if (data.success) {
        status.className = 'form-status success';
        status.innerHTML = '✓ Quote request sent! William will be in touch shortly. For urgent help, call <a href="tel:07809887883">07809 887 883</a>.';
        status.style.display = 'block';
        quoteForm.reset();
      } else throw new Error(data.error);
    } catch {
      status.className = 'form-status error';
      status.innerHTML = 'Something went wrong. Please call <a href="tel:07809887883">07809 887 883</a> directly.';
      status.style.display = 'block';
    } finally {
      btn.disabled = false;
      btnText.style.display = '';
      btnLoading.style.display = 'none';
    }
  });
</script>
