---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const siteUrl = 'https://www.bullardlocks.com';
const pageUrl = `${siteUrl}/reviews`;

// Verified Google reviews scraped from
// https://www.google.com/maps/place/Bullard+Locks (place_id: ChIJU7O3P5IbdkgRVm-wppoH9-4)
// Google's UI only exposes 20 of the 23 total in the side panel.
const reviews = [
  {
    name: 'Elisha Lewis',
    date: '10 months ago',
    rating: 5,
    text: "Locksmith arrived within 10 minutes on a sunny Sunday afternoon and got us back into the flat within an hour. He tried his best to get in without replacing the lock but had to replace it in the end. Very friendly and efficient service at a very good price.",
  },
  {
    name: 'Hayley Oconnell',
    date: '3 months ago',
    rating: 5,
    text: "Can't recommend enough! Fast service and extremely reasonable price. Thank you so much.",
  },
  {
    name: 'Cosmo',
    date: 'a year ago',
    rating: 5,
    text: "Real lifesaver, managed to lock ourselves out, turned up in 10 minutes in Crouch End and charged a reasonable fair for a Friday at 8:30pm! Door was opened without any damage. Great friendly guy too. I hope your chippy tea was still hot when you got home!",
  },
  {
    name: 'Lucy',
    date: '6 months ago',
    rating: 5,
    text: "Replaced the locks in my new home, super professional and friendly, also managed to resolve an issue with my door being difficult to close due to the original locking mechanism. Thank you!",
  },
  {
    name: 'Nigel Fung',
    date: 'a year ago',
    rating: 5,
    text: "William picked up the call first time and was round my house within 15 minutes - after the wife and I locked ourselves out during the morning school run. Quick, prompt, has a car full of equipment and got us indoors within 15 minutes. Great value, nice guy. Recommend.",
  },
  {
    name: 'Tareq Islam',
    date: 'a year ago',
    rating: 5,
    text: "Had broken a key which remained stuck in the lock. Will was flexible in coming when we were at home, fixed the problem in minutes and was extremely knowledgeable and very reasonably priced. Great job, would highly recommend for any lock problems. Would happily use him if we ever need anything again in the future. Anna",
  },
  {
    name: 'Pete',
    date: 'a year ago',
    rating: 5,
    text: "William was excellent. Came out promptly, clearly knows what he's doing. A really nice guy too! We'd called out another so called \"locksmith\" beforehand who turned out to be a right conman, tried to tell us it was impossible to unlock the door and he'd have to drill out the lock, which was utter BS. So when William turned up you immediately felt he was someone who could be trusted, and he managed to unlock the door without damaging anything. Highly recommend!",
  },
  {
    name: 'Caroline',
    date: 'a year ago',
    rating: 5,
    text: "Quick and efficient service. Called up about a non urgent job and it was all completed first thing the next morning. Fast, fairly priced and friendly service. I would happily use them again and recommend them.",
  },
  {
    name: 'Suki Singh',
    date: '2 years ago',
    rating: 5,
    text: "Very polite, professional, quick and efficient. I'm very pleased with the service he provided and very much recommend him to others as he'll now be my regular locksmith. Thanks Will!",
  },
  {
    name: 'Saleem Akbar',
    date: '2 years ago',
    rating: 5,
    text: "Very efficient and arrived when specified. Clean and tidy work, I had problem with my car door lock, William resolved the problem in quick time. Good job and thank you.",
  },
  {
    name: '2easy2rememba',
    date: 'a year ago',
    rating: 5,
    text: "Great locksmith. Was with me in 30 minutes, very fast and professional and a really fair price. Would definitely recommend.",
  },
  {
    name: 'Luke Griffiths',
    date: '2 years ago',
    rating: 5,
    text: "I was in a spot of bother. Locked my keys in the car with the engine running, while I was shopping. Lock Pros arrived super fast and had me in my car in a matter of minutes and saved me from a meltdown. Highly recommend.",
  },
  {
    name: 'Hannah Marshall',
    date: 'a year ago',
    rating: 5,
    text: "Great friendly service! Picked up the phone on the first call and came within 10 minutes. I would highly recommend.",
  },
  {
    name: 'Alex',
    date: 'a year ago',
    rating: 5,
    text: "Locked myself out, had me back in my flat within 15 minutes. Genuine, friendly guy, would highly recommend if you find yourself in a similar situation.",
  },
  {
    name: 'Laura Harold',
    date: 'a year ago',
    rating: 5,
    text: "Swiftly dealt with the situation. Obviously very skilled. Reasonable price and friendly. Would use again and recommend.",
  },
  {
    name: 'Gregory Cox',
    date: '2 years ago',
    rating: 5,
    text: "Great service. Lost my keys to car, locksmith came out very quick supplied keys and programmed to car very pleased with the price. I will recommend him.",
  },
  {
    name: 'M G',
    date: '2 years ago',
    rating: 5,
    text: "Professional, polite, and friendly. Will provided a good service for me in opening a door in a desperate time when keys were misplaced. Thanks!",
  },
  {
    name: 'chrisomorris',
    date: 'a year ago',
    rating: 5,
    text: "Lovely genuine chap - opened a jammed banham lock for us at a reasonable price and was with us at a Crouch End address rapidly.",
  },
  {
    name: 'Armin',
    date: 'a year ago',
    rating: 5,
    text: "Literal life savers came super quick did the job perfectly and reasonably priced! Definitely recommend!",
  },
  {
    name: 'Muhammed Khan',
    date: '2 years ago',
    rating: 5,
    text: "Quick, professional and amazing work. Super reliable. Good price. Thank you for all your help.",
  },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Reviews of Bullard Locks - 5.0 Star Locksmith London',
    description: '5.0 Google rating from 23 verified customer reviews. Read what North London customers say about William Bullard\'s auto locksmith, emergency locksmith and safe engineer services.',
    url: pageUrl,
    mainEntity: {
      '@id': `${siteUrl}/#business`,
    },
    publisher: { '@id': `${siteUrl}/#organization` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'AggregateRating',
    itemReviewed: { '@id': `${siteUrl}/#business` },
    ratingValue: '5.0',
    bestRating: '5',
    worstRating: '1',
    ratingCount: '23',
    reviewCount: '23',
  },
  ...reviews.map((r) => ({
    '@context': 'https://schema.org',
    '@type': 'Review',
    itemReviewed: { '@id': `${siteUrl}/#business` },
    reviewRating: {
      '@type': 'Rating',
      ratingValue: String(r.rating),
      bestRating: '5',
      worstRating: '1',
    },
    author: { '@type': 'Person', name: r.name },
    reviewBody: r.text,
    publisher: { '@type': 'Organization', name: 'Google' },
  })),
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Reviews', item: pageUrl },
    ],
  },
];
---

<BaseLayout
  title="Reviews of Bullard Locks - 5.0 Stars on Google | North London Locksmith"
  description="5.0 Google rating from 23 verified customers. Read what London customers say about William Bullard's auto, emergency and safe locksmith service across N4, N6, N8, N10 and beyond."
  canonicalUrl={pageUrl}
  schema={schema}
>
  <section class="reviews-hero bg-dark">
    <div class="reviews-hero-overlay" aria-hidden="true"></div>
    <div class="container-custom reviews-hero-content">
      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span>Reviews</span>
      </nav>

      <div class="reviews-hero-grid">
        <div>
          <h1 class="reviews-hero-title">
            <span class="reviews-hero-rating">5.0</span>
            <span class="reviews-hero-stars">★ ★ ★ ★ ★</span>
          </h1>
          <p class="reviews-hero-subtitle">on Google · 23 verified customer reviews</p>
          <p class="reviews-hero-lead">
            William Bullard has held a perfect 5.0-star Google rating since opening review collection.
            Below is a selection of recent reviews from customers across North and Central London.
            All reviews can be verified directly on the
            <a href="https://www.google.com/maps/place/?q=place_id:ChIJU7O3P5IbdkgRVm-wppoH9-4" target="_blank" rel="noopener noreferrer">Bullard Locks Google profile</a>.
          </p>
          <div class="reviews-hero-ctas">
            <a href="https://www.google.com/maps/place/?q=place_id:ChIJU7O3P5IbdkgRVm-wppoH9-4" target="_blank" rel="noopener noreferrer" class="btn-hero-primary">
              <i class="fab fa-google"></i> Read All on Google
            </a>
            <a href="tel:07809887883" class="btn-hero-whatsapp">
              <i class="fas fa-phone"></i> 07809 887 883
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Recent Customer Reviews</h2>
        <p class="section-subtitle">A selection of verified Google reviews from North London customers.</p>
      </div>

      <div class="reviews-grid">
        {reviews.map((r) => (
          <div class="review-card">
            <div class="review-header">
              <div class="review-avatar">{r.name.charAt(0)}</div>
              <div>
                <p class="review-name">{r.name}</p>
                <p class="review-date">{r.date}</p>
              </div>
            </div>
            <div class="review-stars">
              {Array.from({ length: r.rating }).map(() => (
                <i class="fas fa-star"></i>
              ))}
            </div>
            <p class="review-text">{r.text}</p>
          </div>
        ))}
      </div>

      <div class="reviews-cta-block">
        <p>
          Want to read more? All 23 reviews are visible on the
          <a href="https://www.google.com/maps/place/?q=place_id:ChIJU7O3P5IbdkgRVm-wppoH9-4" target="_blank" rel="noopener noreferrer">Bullard Locks Google profile</a>,
          where customers can also leave their own review after a service.
        </p>
      </div>
    </div>
  </section>

  <section class="content-section bg-light">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Why Customers Choose William</h2>
      </div>
      <div class="why-grid">
        <div class="why-card">
          <i class="fas fa-user-shield why-icon"></i>
          <h3>One person, every job</h3>
          <p>William personally answers the phone, drives to your location and does the work. No subcontractors, no call centre.</p>
        </div>
        <div class="why-card">
          <i class="fas fa-tag why-icon"></i>
          <h3>Fixed price up front</h3>
          <p>You get a written quote before any work begins. No call-out fee. The price quoted is the only price paid.</p>
        </div>
        <div class="why-card">
          <i class="fas fa-shield-alt why-icon"></i>
          <h3>Met Police &amp; British Gas approved</h3>
          <p>Independently vetted to the highest standards. DBS checked, fully insured, Master Locksmiths Association member.</p>
        </div>
        <div class="why-card">
          <i class="fas fa-tools why-icon"></i>
          <h3>30+ years on the road</h3>
          <p>Three decades handling lockouts, key replacements and safe work across North and Central London.</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Ready to Experience the Service?"
    subtitle="Available 24/7 | No call-out fee | 5.0 Google · 23 reviews"
  />
</BaseLayout>

<style>
  .reviews-hero {
    position: relative;
    min-height: 50vh;
    display: flex;
    align-items: center;
    padding-top: var(--header-height);
    background: linear-gradient(135deg, #0e4a4d 0%, #061e20 100%);
  }

  .reviews-hero-overlay {
    position: absolute; inset: 0;
    background: radial-gradient(circle at 70% 50%, rgba(31,174,155,0.18) 0%, transparent 60%);
  }

  .reviews-hero-content { position: relative; z-index: 1; padding: 64px 0 48px; }

  .reviews-hero-grid { max-width: 760px; }

  .reviews-hero-title {
    display: flex;
    align-items: baseline;
    gap: 18px;
    margin: 18px 0 8px;
    flex-wrap: wrap;
  }

  .reviews-hero-rating {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    color: white;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .reviews-hero-stars {
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: #FFD700;
    letter-spacing: 6px;
    font-weight: 400;
  }

  .reviews-hero-subtitle {
    font-size: 1rem;
    color: rgba(255,255,255,0.65);
    font-weight: 600;
    margin: 0 0 24px;
  }

  .reviews-hero-lead {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.78);
    line-height: 1.7;
    margin: 0 0 30px;
    max-width: 620px;
  }

  .reviews-hero-lead a { color: var(--color-accent); text-decoration: none; }
  .reviews-hero-lead a:hover { text-decoration: underline; }

  .reviews-hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: var(--color-accent);
    color: white;
    border-radius: 3px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-hero-primary:hover { background: var(--color-accent-hover); transform: translateY(-2px); }

  .btn-hero-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: rgba(255,255,255,0.1);
    color: white;
    border: 1.5px solid rgba(255,255,255,0.3);
    border-radius: 3px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-hero-whatsapp:hover { background: rgba(255,255,255,0.2); }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .review-card {
    background: var(--color-bg-light);
    border-radius: 3px;
    padding: 28px;
    border: none;
    transition: all 0.2s ease;
  }

  .review-card:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .review-name {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--color-text-main);
    margin: 0;
  }

  .review-date {
    font-size: 0.78rem;
    color: var(--color-text-muted-light);
    margin: 0;
  }

  .review-stars {
    display: flex;
    gap: 2px;
    color: #FBBC05;
    font-size: 0.8rem;
    margin-bottom: 12px;
  }

  .review-text {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .reviews-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 640px) {
    .reviews-grid { grid-template-columns: 1fr; }
  }

  .reviews-cta-block {
    margin-top: 32px;
    padding: 22px 26px;
    background: rgba(31,174,155,0.06);
    border: 1.5px dashed var(--color-accent);
    border-radius: 3px;
    text-align: center;
  }

  .reviews-cta-block p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .reviews-cta-block a {
    color: var(--color-accent);
    font-weight: 700;
    text-decoration: none;
  }

  .reviews-cta-block a:hover { text-decoration: underline; }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    max-width: 880px;
    margin: 0 auto;
  }

  .why-card {
    background: white;
    padding: 26px 28px;
    border-radius: 3px;
    border: 1.5px solid rgba(0,0,0,0.06);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .why-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }

  .why-icon {
    color: var(--color-accent);
    font-size: 1.4rem;
    margin-bottom: 12px;
  }

  .why-card h3 {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--color-text-main);
    margin: 0 0 8px;
  }

  .why-card p {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .why-grid { grid-template-columns: 1fr; }
    .full-review-header { flex-wrap: wrap; }
  }
</style>
