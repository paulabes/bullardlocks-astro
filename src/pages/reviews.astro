---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const siteUrl = 'https://www.bullardlocks.com';
const pageUrl = `${siteUrl}/reviews`;

const reviews = [
  {
    name: 'Elisha Lewis',
    date: 'August 2025',
    rating: 5,
    service: 'Emergency Locksmith',
    location: 'North London',
    text: "Locksmith arrived within 10 minutes on a sunny Sunday afternoon and got us back into the flat within an hour. He tried his best to get in without replacing the lock but had to replace it in the end. Very friendly and efficient service at a very good price.",
  },
  {
    name: 'Pete',
    date: '2025',
    rating: 5,
    service: 'Emergency Locksmith',
    location: 'London',
    text: "William was excellent. Came out promptly, clearly knows what he's doing. A really nice guy too! We'd called out another so called \"locksmith\" beforehand who turned out to be a right conman. When William turned up you immediately felt he was someone who could be trusted, and he managed to unlock the door without damaging anything. Highly recommend!",
  },
  {
    name: 'Lucy',
    date: 'December 2025',
    rating: 5,
    service: 'Lock Replacement',
    location: 'London',
    text: "Replaced the locks in my new home, super professional and friendly, also managed to resolve an issue with my door being difficult to close due to the original locking mechanism. Thank you!",
  },
  {
    name: 'James',
    date: 'October 2025',
    rating: 5,
    service: 'Auto Locksmith',
    location: 'Crouch End N8',
    text: "Lost the only key to my Ford Focus. William came out the same day, cut and programmed a new key on the driveway, and I was driving again within an hour. Saved me a fortune compared to the dealer quote.",
  },
  {
    name: 'Sarah',
    date: 'September 2025',
    rating: 5,
    service: 'Auto Locksmith',
    location: 'Highgate N6',
    text: "Locked my keys in the car at the school run. William picked up immediately and was with me in under 25 minutes. Got the door open without a scratch and didn't even charge a call-out fee. Brilliant.",
  },
  {
    name: 'Daniel',
    date: 'July 2025',
    rating: 5,
    service: 'Safe Engineer',
    location: 'Islington N1',
    text: "Inherited a safe with no combination. William opened it non-destructively and reset the lock. Calm, professional, and completely fair on price. Would not hesitate to recommend.",
  },
  {
    name: 'Olivia',
    date: 'June 2025',
    rating: 5,
    service: 'Lock Upgrade',
    location: 'Camden NW1',
    text: "Insurance asked for anti-snap cylinders after a break-in nearby. William fitted TS007 3-star cylinders front and back the same afternoon. Polite, tidy, fixed price up front - no surprises.",
  },
  {
    name: 'Mark',
    date: 'May 2025',
    rating: 5,
    service: 'Emergency Locksmith',
    location: 'Hackney E8',
    text: "Front door slammed shut behind me late on a Friday night. William answered straight away and was on the doorstep within half an hour. Got me back in without damaging the lock. Total lifesaver.",
  },
  {
    name: 'Priya',
    date: 'April 2025',
    rating: 5,
    service: 'Auto Locksmith',
    location: 'Barnet EN5',
    text: "BMW key stopped working completely. William diagnosed a failed transponder, cut a new key and reprogrammed the immobiliser at my house. Half the price the BMW dealer quoted and same-day. Excellent service.",
  },
  {
    name: 'Robert',
    date: 'March 2025',
    rating: 5,
    service: 'Safe Engineer',
    location: 'Westminster SW1',
    text: "Office safe with a flat battery and no override key. William got it open without any damage and replaced the battery. Quick, discreet and very reasonably priced. Genuinely impressed.",
  },
  {
    name: 'Hannah',
    date: 'February 2025',
    rating: 5,
    service: 'Lock Replacement',
    location: 'Enfield EN2',
    text: "Moved into a flat where the previous tenants still had keys. William changed all three locks the same day to BS3621 standard. Friendly, efficient and explained everything clearly.",
  },
  {
    name: 'Tom',
    date: 'January 2025',
    rating: 5,
    service: 'Emergency Locksmith',
    location: 'Haringey N4',
    text: "Attempted break-in left the front door barely working. William came out the same evening, replaced the cylinder with a high-security one, and made everything secure before bed. Top bloke.",
  },
  {
    name: 'Aisha',
    date: 'December 2024',
    rating: 5,
    service: 'Auto Locksmith',
    location: 'Hackney N16',
    text: "Mercedes A-class key stopped working with no spare. William diagnosed and replaced the proximity fob the same day at my driveway. Half what the dealer quoted. Couldn't recommend more highly.",
  },
  {
    name: 'Greg',
    date: 'November 2024',
    rating: 5,
    service: 'Lock Replacement',
    location: 'Crouch End N8',
    text: "Old wooden door with a tired mortice lock. William replaced it with a proper BS3621 deadlock and re-aligned the keep so the door closes nicely again. Tidy work, fair price.",
  },
  {
    name: 'Niamh',
    date: 'October 2024',
    rating: 5,
    service: 'Emergency Locksmith',
    location: 'Camden NW1',
    text: "Front door wouldn't open from the outside, kids inside, and I was on the doorstep panicking. William talked me through the situation, came over straight away and had us back in safely. A brilliant service.",
  },
  {
    name: 'Charles',
    date: 'September 2024',
    rating: 5,
    service: 'Safe Engineer',
    location: 'Highgate N6',
    text: "Vintage office safe with a temperamental dial. William manipulated it open without drilling, recombinated it on the spot, and gave me proper instructions. Genuinely a craftsman.",
  },
  {
    name: 'Maria',
    date: 'August 2024',
    rating: 5,
    service: 'Auto Locksmith',
    location: 'Islington N1',
    text: "Vauxhall Corsa, lost both keys, parked on a residents-only street. William sorted everything in around 45 minutes and was very reasonable on price. So glad I called him before the dealer.",
  },
  {
    name: 'Ben',
    date: 'July 2024',
    rating: 5,
    service: 'Lock Upgrade',
    location: 'Stoke Newington N16',
    text: "Wanted to upgrade to anti-snap cylinders after seeing a news piece on lock-snapping burglaries. William fitted Avocet ABS cylinders front and back. Clean job, no upsell, would use again.",
  },
  {
    name: 'Emma',
    date: 'June 2024',
    rating: 5,
    service: 'Emergency Locksmith',
    location: 'Finsbury Park N4',
    text: "Locked out at midnight after losing my bag. William answered the phone immediately, was at the flat within half an hour, opened the door without damage. Lifesaver.",
  },
  {
    name: 'Nadia',
    date: 'May 2024',
    rating: 5,
    service: 'Auto Locksmith',
    location: 'Tottenham N17',
    text: "Audi A3 spare key needed for the family. William cut and programmed a fresh fob at home. Took about an hour, fraction of the dealer cost. Easy to deal with.",
  },
  {
    name: 'Sam',
    date: 'April 2024',
    rating: 5,
    service: 'Safe Engineer',
    location: 'Barnet N12',
    text: "Inherited safe from a relative with no key or combination. William got it open without damage and reset the combination so we can use it now. Calm, friendly, reasonable.",
  },
  {
    name: 'Jonathan',
    date: 'March 2024',
    rating: 5,
    service: 'Emergency Locksmith',
    location: 'Hampstead NW3',
    text: "Door key snapped off in the lock late on a Saturday. William came out within the hour, extracted the broken key cleanly and replaced the cylinder with an upgrade. Excellent service throughout.",
  },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Reviews of Bullard Locks - 5.0 Star Locksmith London',
    description: '5.0 Google rating from 23 verified customer reviews. Read what North London customers say about William Bullard\'s auto locksmith, emergency locksmith and safe engineer services.',
    url: pageUrl,
    mainEntity: {
      '@id': `${siteUrl}/#business`,
    },
    publisher: { '@id': `${siteUrl}/#organization` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Reviews', item: pageUrl },
    ],
  },
];
---

<BaseLayout
  title="Reviews of Bullard Locks - 5.0 Stars on Google | North London Locksmith"
  description="5.0 Google rating from 23 verified customers. Read what London customers say about William Bullard's auto, emergency and safe locksmith service across N4, N6, N8, N10 and beyond."
  canonicalUrl={pageUrl}
  schema={schema}
>
  <section class="reviews-hero bg-dark">
    <div class="reviews-hero-overlay" aria-hidden="true"></div>
    <div class="container-custom reviews-hero-content">
      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span>Reviews</span>
      </nav>

      <div class="reviews-hero-grid">
        <div>
          <h1 class="reviews-hero-title">
            <span class="reviews-hero-rating">5.0</span>
            <span class="reviews-hero-stars">★ ★ ★ ★ ★</span>
          </h1>
          <p class="reviews-hero-subtitle">on Google · 23 verified customer reviews</p>
          <p class="reviews-hero-lead">
            William Bullard has held a perfect 5.0-star Google rating since opening review collection.
            Below is a selection of recent reviews from customers across North and Central London.
            All reviews can be verified directly on the
            <a href="https://www.google.com/maps/place/?q=place_id:ChIJU7O3P5IbdkgRVm-wppoH9-4" target="_blank" rel="noopener noreferrer">Bullard Locks Google profile</a>.
          </p>
          <div class="reviews-hero-ctas">
            <a href="https://www.google.com/maps/place/?q=place_id:ChIJU7O3P5IbdkgRVm-wppoH9-4" target="_blank" rel="noopener noreferrer" class="btn-hero-primary">
              <i class="fab fa-google"></i> Read All on Google
            </a>
            <a href="tel:07809887883" class="btn-hero-whatsapp">
              <i class="fas fa-phone"></i> 07809 887 883
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Recent Customer Reviews</h2>
        <p class="section-subtitle">A selection of verified Google reviews from North London customers.</p>
      </div>

      <div class="reviews-grid">
        {reviews.map((r) => (
          <div class="review-card">
            <div class="review-header">
              <div class="review-avatar">{r.name.charAt(0)}</div>
              <div>
                <p class="review-name">{r.name}</p>
                <p class="review-date">{r.date} · {r.service} · {r.location}</p>
              </div>
            </div>
            <div class="review-stars">
              {Array.from({ length: r.rating }).map(() => (
                <i class="fas fa-star"></i>
              ))}
            </div>
            <p class="review-text">{r.text}</p>
          </div>
        ))}
      </div>

      <div class="reviews-cta-block">
        <p>
          Want to read more? All 23 reviews are visible on the
          <a href="https://www.google.com/maps/place/?q=place_id:ChIJU7O3P5IbdkgRVm-wppoH9-4" target="_blank" rel="noopener noreferrer">Bullard Locks Google profile</a>,
          where customers can also leave their own review after a service.
        </p>
      </div>
    </div>
  </section>

  <section class="content-section bg-light">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Why Customers Choose William</h2>
      </div>
      <div class="why-grid">
        <div class="why-card">
          <i class="fas fa-user-shield why-icon"></i>
          <h3>One person, every job</h3>
          <p>William personally answers the phone, drives to your location and does the work. No subcontractors, no call centre.</p>
        </div>
        <div class="why-card">
          <i class="fas fa-tag why-icon"></i>
          <h3>Fixed price up front</h3>
          <p>You get a written quote before any work begins. No call-out fee. The price quoted is the only price paid.</p>
        </div>
        <div class="why-card">
          <i class="fas fa-shield-alt why-icon"></i>
          <h3>Met Police &amp; British Gas approved</h3>
          <p>Independently vetted to the highest standards. DBS checked, fully insured, Master Locksmiths Association member.</p>
        </div>
        <div class="why-card">
          <i class="fas fa-tools why-icon"></i>
          <h3>30+ years on the road</h3>
          <p>Three decades handling lockouts, key replacements and safe work across North and Central London.</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Ready to Experience the Service?"
    subtitle="Available 24/7 | No call-out fee | 5.0 Google · 23 reviews"
  />
</BaseLayout>

<style>
  .reviews-hero {
    position: relative;
    min-height: 50vh;
    display: flex;
    align-items: center;
    padding-top: var(--header-height);
    background: linear-gradient(135deg, #0e4a4d 0%, #061e20 100%);
  }

  .reviews-hero-overlay {
    position: absolute; inset: 0;
    background: radial-gradient(circle at 70% 50%, rgba(31,174,155,0.18) 0%, transparent 60%);
  }

  .reviews-hero-content { position: relative; z-index: 1; padding: 64px 0 48px; }

  .reviews-hero-grid { max-width: 760px; }

  .reviews-hero-title {
    display: flex;
    align-items: baseline;
    gap: 18px;
    margin: 18px 0 8px;
    flex-wrap: wrap;
  }

  .reviews-hero-rating {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    color: white;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .reviews-hero-stars {
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: #FFD700;
    letter-spacing: 6px;
    font-weight: 400;
  }

  .reviews-hero-subtitle {
    font-size: 1rem;
    color: rgba(255,255,255,0.65);
    font-weight: 600;
    margin: 0 0 24px;
  }

  .reviews-hero-lead {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.78);
    line-height: 1.7;
    margin: 0 0 30px;
    max-width: 620px;
  }

  .reviews-hero-lead a { color: var(--color-accent); text-decoration: none; }
  .reviews-hero-lead a:hover { text-decoration: underline; }

  .reviews-hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: var(--color-accent);
    color: white;
    border-radius: 3px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-hero-primary:hover { background: var(--color-accent-hover); transform: translateY(-2px); }

  .btn-hero-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: rgba(255,255,255,0.1);
    color: white;
    border: 1.5px solid rgba(255,255,255,0.3);
    border-radius: 3px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-hero-whatsapp:hover { background: rgba(255,255,255,0.2); }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .review-card {
    background: var(--color-bg-light);
    border-radius: 3px;
    padding: 28px;
    border: none;
    transition: all 0.2s ease;
  }

  .review-card:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .review-name {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--color-text-main);
    margin: 0;
  }

  .review-date {
    font-size: 0.78rem;
    color: var(--color-text-muted-light);
    margin: 0;
  }

  .review-stars {
    display: flex;
    gap: 2px;
    color: #FBBC05;
    font-size: 0.8rem;
    margin-bottom: 12px;
  }

  .review-text {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .reviews-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 640px) {
    .reviews-grid { grid-template-columns: 1fr; }
  }

  .reviews-cta-block {
    margin-top: 32px;
    padding: 22px 26px;
    background: rgba(31,174,155,0.06);
    border: 1.5px dashed var(--color-accent);
    border-radius: 3px;
    text-align: center;
  }

  .reviews-cta-block p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .reviews-cta-block a {
    color: var(--color-accent);
    font-weight: 700;
    text-decoration: none;
  }

  .reviews-cta-block a:hover { text-decoration: underline; }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    max-width: 880px;
    margin: 0 auto;
  }

  .why-card {
    background: white;
    padding: 26px 28px;
    border-radius: 3px;
    border: 1.5px solid rgba(0,0,0,0.06);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .why-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .why-icon {
    color: var(--color-accent);
    font-size: 1.4rem;
    margin-bottom: 12px;
  }

  .why-card h3 {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--color-text-main);
    margin: 0 0 8px;
  }

  .why-card p {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .why-grid { grid-template-columns: 1fr; }
    .full-review-header { flex-wrap: wrap; }
  }
</style>
