    line-height: 1.75;
    color: var(--color-text-muted);
    margin: 0 0 18px;
  }

  .article-body p a, .article-body li a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
  }

  .article-body p a:hover, .article-body li a:hover { text-decoration: underline; }

  .article-body ol, .article-body ul {
    margin: 0 0 22px;
    padding-left: 22px;
  }

  .article-body li {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }

  .article-body strong { color: var(--color-text-main); font-weight: 700; }

  .price-table-wrap { overflow-x: auto; margin: 24px -8px 12px; -webkit-overflow-scrolling: touch; }

  .price-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
  }

  .price-table th {
    text-align: left;
    padding: 14px 12px;
    background: rgba(31,174,155,0.08);
    color: var(--color-text-main);
    font-weight: 700;
    border-bottom: 2px solid var(--color-accent);
  }

  .price-table td {
    padding: 12px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
