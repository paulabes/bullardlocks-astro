  .article-category {
    display: inline-block;
    padding: 4px 12px;
    background: rgba(31,174,155,0.18);
    color: #5ee8d4;
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .article-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 800;
    color: white;
    line-height: 1.15;
    margin: 0 0 20px;
    letter-spacing: -0.02em;
  }

  .article-lead {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.78);
    line-height: 1.7;
    margin: 0 0 30px;
  }

  .article-byline {
    display: flex;
    gap: 12px;
    align-items: center;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.12);
  }

  .byline-name { color: white; font-weight: 700; font-size: 0.95rem; margin: 0; }
  .byline-name a { color: var(--color-accent); text-decoration: none; }
  .byline-name a:hover { text-decoration: underline; }
  .byline-meta { color: rgba(255,255,255,0.55); font-size: 0.82rem; margin: 4px 0 0; }

  .article-body { max-width: 760px; }

  .lead-paragraph {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-text-main);
    margin: 0 0 36px;
    font-weight: 500;
  }

  .article-body h2 {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--color-text-main);
    margin: 48px 0 18px;
    letter-spacing: -0.01em;
  }

  .article-body h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text-main);
    margin: 32px 0 12px;
  }

  .article-body p {
