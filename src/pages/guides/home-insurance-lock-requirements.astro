  .article-body p a:hover, .article-body li a:hover { text-decoration: underline; }
  .article-body ol, .article-body ul { margin: 0 0 22px; padding-left: 22px; }
  .article-body li { font-size: 1rem; line-height: 1.7; color: var(--color-text-muted); margin-bottom: 8px; }
  .article-body strong { color: var(--color-text-main); font-weight: 700; }
  .article-faq { border: 1.5px solid rgba(0,0,0,0.08); border-radius: 12px; margin-bottom: 12px; overflow: hidden; transition: border-color 0.2s ease; }
  .article-faq[open] { border-color: var(--color-accent); }
  .article-faq summary { cursor: pointer; list-style: none; padding: 18px 48px 18px 22px; font-size: 1rem; font-weight: 700; color: var(--color-text-main); position: relative; }
  .article-faq summary::-webkit-details-marker { display: none; }
  .article-faq summary::after { content: '+'; position: absolute; right: 22px; top: 50%; transform: translateY(-50%); color: var(--color-accent); font-size: 1.4rem; line-height: 1; }
  .article-faq[open] summary::after { content: '−'; }
  .article-faq .faq-answer { padding: 0 22px 18px; }
  .article-faq .faq-answer p { font-size: 0.95rem; margin: 0 0 12px; }
  .article-faq .faq-answer p:last-child { margin-bottom: 0; }
  .article-related { max-width: 980px; }
  .related-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 24px; }
  .related-card { display: block; padding: 22px 24px; background: white; border: 1.5px solid rgba(0,0,0,0.08); border-radius: 14px; text-decoration: none; color: inherit; transition: all 0.2s ease; }
  .related-card:hover { border-color: var(--color-accent); transform: translateY(-2px); }
  .related-card h3 { font-size: 1.05rem; font-weight: 800; margin: 0 0 8px; color: var(--color-text-main); }
  .related-card p { font-size: 0.9rem; line-height: 1.6; color: var(--color-text-muted); margin: 0; }
  @media (max-width: 768px) { .related-grid { grid-template-columns: 1fr; } }
</style>
