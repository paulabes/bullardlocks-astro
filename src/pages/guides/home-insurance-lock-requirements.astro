---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import PageHero from '../../components/PageHero.astro';

const siteUrl = 'https://www.bullardlocks.com';
const pageUrl = `${siteUrl}/guides/home-insurance-lock-requirements`;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: 'What Lock Does My Home Insurance Need? UK 2026 Guide',
    description: 'Plain-English guide to the lock requirements imposed by UK home insurance policies - BS3621, TS007, anti-snap, multipoint UPVC - and how to comply without overspending.',
    image: `${siteUrl}/images/hero-emergency-locksmith.webp`,
    datePublished: '2026-04-26',
    dateModified: '2026-04-26',
    author: { '@type': 'Person', name: 'William Bullard', url: `${siteUrl}/about`, '@id': `${siteUrl}/#william` },
    publisher: { '@id': `${siteUrl}/#organization` },
    mainEntityOfPage: pageUrl,
    inLanguage: 'en-GB',
    articleSection: 'Security',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What lock standard does UK home insurance usually require?',
        acceptedAnswer: { '@type': 'Answer', text: 'For wooden doors with mortice locks, UK insurers most commonly specify BS3621 - the British Standard for thief-resistant lockable mortice deadlocks with at least five levers and a 20 mm bolt throw. For UPVC and composite doors with Euro cylinder multipoint mechanisms, insurers increasingly specify TS007 3-star cylinders or a TS007 1-star cylinder paired with TS007 2-star security door furniture, sometimes with additional Sold Secure Diamond grade requirements for high-value contents.' },
      },
      {
        '@type': 'Question',
        name: 'How do I check if my existing lock meets BS3621?',
        acceptedAnswer: { '@type': 'Answer', text: 'BS3621 mortice deadlocks carry a small kitemark on the faceplate (visible on the edge of the door when the door is open) showing the BSI kitemark and "BS3621" embossed or laser-etched into the metal. If the faceplate is unmarked or shows only "BS3621:1980" without the kitemark, it does not meet the current standard. Replacement and refit on a standard wooden door takes a qualified locksmith approximately 60-90 minutes.' },
      },
      {
        '@type': 'Question',
        name: 'What is TS007 3-star and why does it matter?',
        acceptedAnswer: { '@type': 'Answer', text: 'TS007 is the UK standard for Euro cylinder anti-snap performance, tested by Sold Secure or the Door and Hardware Federation. Cylinders are rated 1-star (basic), 2-star (intermediate, paired with 2-star door furniture for full protection) or 3-star (full anti-snap protection in the cylinder alone). Lock-snapping is the most common burglary entry method on UPVC doors in the UK; a TS007 3-star cylinder reduces the success rate of this attack from seconds to minutes, by which point most burglars give up.' },
      },
      {
        '@type': 'Question',
        name: 'Will my insurance pay out if my lock did not meet the policy specification?',
        acceptedAnswer: { '@type': 'Answer', text: 'In practice, insurers can reduce or refuse a claim if the lock specification on the door breached at the time of a burglary did not meet the policy wording. This is one of the most common claim-disputes in UK home insurance. The amount you save by buying a £20 generic cylinder instead of a £50 TS007 3-star cylinder can easily be lost on a single declined claim. Read the security clause of your policy carefully and ask a qualified locksmith to confirm what is fitted matches what is required.' },
      },
      {
        '@type': 'Question',
        name: 'What about windows? Do insurers specify window locks too?',
        acceptedAnswer: { '@type': 'Answer', text: 'Most UK home insurance policies require key-operated locks on all accessible ground-floor and basement windows, and on first-floor windows that are reachable from a flat roof or extension. Standard sash and casement window locks are widely available and inexpensive. Insurers rarely specify a particular standard for window locks, but expect them to be functional and engaged when the property is left unattended.' },
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Guides', item: `${siteUrl}/guides` },
      { '@type': 'ListItem', position: 3, name: 'Insurance Lock Requirements', item: pageUrl },
    ],
  },
