  .byline-name a { color: var(--color-accent); text-decoration: none; }
  .byline-name a:hover { text-decoration: underline; }
  .byline-meta { color: rgba(255,255,255,0.55); font-size: 0.82rem; margin: 4px 0 0; }
  .article-body { max-width: 760px; }
  .lead-paragraph { font-size: 1.15rem; line-height: 1.7; color: var(--color-text-main); margin: 0 0 36px; font-weight: 500; }
  .article-body h2 { font-size: 1.6rem; font-weight: 800; color: var(--color-text-main); margin: 48px 0 18px; letter-spacing: -0.01em; }
