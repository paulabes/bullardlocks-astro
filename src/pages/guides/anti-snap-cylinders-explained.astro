  .article-body h3 { font-size: 1.2rem; font-weight: 700; color: var(--color-text-main); margin: 32px 0 12px; }
  .article-body p { font-size: 1rem; line-height: 1.75; color: var(--color-text-muted); margin: 0 0 18px; }
  .article-body p a, .article-body li a { color: var(--color-accent); text-decoration: none; font-weight: 600; }
  .article-body p a:hover, .article-body li a:hover { text-decoration: underline; }
  .article-body ol, .article-body ul { margin: 0 0 22px; padding-left: 22px; }
  .article-body li { font-size: 1rem; line-height: 1.7; color: var(--color-text-muted); margin-bottom: 8px; }
  .article-body strong { color: var(--color-text-main); font-weight: 700; }
  .article-related { max-width: 980px; }
  .related-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 24px; }
  .related-card { display: block; padding: 22px 24px; background: white; border: 1.5px solid rgba(0,0,0,0.08); border-radius: 3px; text-decoration: none; color: inherit; transition: all 0.2s ease; }
  .related-card:hover { border-color: var(--color-accent); transform: translateY(-2px); }
  .related-card h3 { font-size: 1.05rem; font-weight: 800; margin: 0 0 8px; color: var(--color-text-main); }
