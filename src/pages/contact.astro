---
import BaseLayout from '../layouts/BaseLayout.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import CTASection from '../components/CTASection.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact Bullard Locks — Auto Locksmith North London",
    "description": "Contact William Bullard for auto locksmith, emergency locksmith and safe engineer services in North London. Available 24/7. No call-out fee.",
    "url": "https://bullardlocks.com/contact",
    "mainEntity": {
      "@type": "LocksmithBusiness",
      "name": "Bullard Locks",
      "telephone": "+447809887883",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "67 Weston Park",
        "addressLocality": "Crouch End",
        "addressRegion": "London",
        "postalCode": "N8 9TA",
        "addressCountry": "GB"
      },
      "openingHoursSpecification": {"@type": "OpeningHoursSpecification","dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],"opens": "00:00","closes": "23:59"}
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://bullardlocks.com/"},
      {"@type": "ListItem", "position": 2, "name": "Contact", "item": "https://bullardlocks.com/contact"}
    ]
  }
];
---

<BaseLayout
  title="Contact Bullard Locks - Locksmith North London | 07809 887 883"
  description="Contact William Bullard - auto locksmith & emergency locksmith, North London. 24/7 emergency response. No call-out fee. Call 07809 887 883 or send a message."
  canonicalUrl="https://bullardlocks.com/contact"
  schema={schema}
>
  <!-- HERO -->
  <section class="policy-hero bg-dark">
    <div class="policy-hero-overlay" aria-hidden="true"></div>
    <div class="container-custom policy-hero-content">

      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span>Contact</span>
      </nav>

      <h1 class="policy-hero-title">Contact <span class="title-accent">Bullard Locks</span></h1>

      <p class="policy-hero-lead">
        Get in touch for professional auto locksmith and emergency locksmith services across North London. Available 24/7. <strong>No call-out fee.</strong>
      </p>

      <div class="loc-trust-bar">
        <div class="loc-trust-item">
          <i class="fas fa-star"></i>
          <span>5.0 Google</span>
        </div>
        <div class="loc-trust-item">
          <i class="fas fa-shield-alt"></i>
          <span>Met Police Approved</span>
        </div>
        <div class="loc-trust-item">
          <i class="fas fa-award"></i>
          <span>30+ Years Experience</span>
        </div>
        <div class="loc-trust-item">
          <i class="fas fa-tag"></i>
          <span>No Call-Out Fee</span>
        </div>
        <div class="loc-trust-item">
          <i class="fas fa-check"></i>
          <span>Fully Insured</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Methods -->
  <section class="content-section bg-white">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Get In Touch</h2>
        <p class="section-subtitle">
          For emergencies — locked out, car key lost, or break-in — please call directly for the fastest response.
        </p>
      </div>

      <div class="contact-methods-grid">
        <a href="tel:07809887883" class="contact-method-card contact-method-primary">
          <div class="contact-method-icon">
            <i class="fas fa-phone"></i>
          </div>
          <div class="contact-method-body">
            <h3>Call Direct</h3>
            <p>Fastest response — especially for emergencies and vehicle lockouts.</p>
            <span class="contact-method-value">07809 887 883</span>
          </div>
          <i class="fas fa-chevron-right contact-method-arrow"></i>
        </a>

        <a href="https://wa.me/447809887883" class="contact-method-card contact-method-whatsapp" target="_blank" rel="noopener noreferrer">
          <div class="contact-method-icon">
            <i class="fab fa-whatsapp"></i>
          </div>
          <div class="contact-method-body">
            <h3>WhatsApp</h3>
            <p>Send a message or photos of your lock, car key or safe situation.</p>
            <span class="contact-method-value">Message us now</span>
          </div>
          <i class="fas fa-chevron-right contact-method-arrow"></i>
        </a>

        <a href="/locations" class="contact-method-card contact-method-location">
          <div class="contact-method-icon">
            <i class="fas fa-map-marker-alt"></i>
          </div>
          <div class="contact-method-body">
            <h3>Location</h3>
            <p>Based in Crouch End — serving all of North and Central London.</p>
            <span class="contact-method-value">Crouch End, London N8</span>
          </div>
          <i class="fas fa-chevron-right contact-method-arrow"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Form with Photo Upload -->
  <section class="content-section bg-light">
    <div class="container-custom">
      <div class="contact-form-layout">
        <!-- Form -->
        <div class="contact-form-main">
          <div class="section-header" style="text-align: left; margin-bottom: 32px;">
            <h2 class="section-title" style="text-align: left;">Send a Message</h2>
            <p class="section-subtitle" style="text-align: left;">
              For non-urgent enquiries, fill out the form below. You can attach photos of your lock, key or vehicle situation to help us give you an accurate quote.
            </p>
          </div>

          <form id="contact-form" enctype="multipart/form-data">
            <input type="hidden" name="form_type" value="contact" />

            <div class="form-row">
              <div class="form-group">
                <label for="name" class="form-label">Your Name *</label>
                <input type="text" id="name" name="name" class="form-control-modern" placeholder="John Smith" required />
              </div>
              <div class="form-group">
                <label for="phone" class="form-label">Phone Number *</label>
                <input type="tel" id="phone" name="phone" class="form-control-modern" placeholder="07700 900000" required />
              </div>
            </div>

            <div class="form-group">
              <label for="email" class="form-label">Email Address</label>
              <input type="email" id="email" name="email" class="form-control-modern" placeholder="john@example.com" />
            </div>

            <div class="form-group">
              <label for="service" class="form-label">Service Required</label>
              <select id="service" name="service" class="form-control-modern">
                <option value="">Select a service...</option>
                <option value="auto">Auto Locksmith (car keys, lockout)</option>
                <option value="emergency">Emergency Locksmith (lockout, break-in)</option>
                <option value="safe">Safe Engineer (opening, installation)</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message" class="form-label">Your Message *</label>
              <textarea id="message" name="message" class="form-control-modern" rows="4" placeholder="Describe your situation — e.g. 'Lost keys to my Ford Focus, it's parked in Crouch End'" required></textarea>
            </div>

            <!-- Photo Upload -->
            <div class="form-group">
              <label class="form-label">
                <i class="fas fa-camera"></i> Attach Photos (optional)
              </label>
              <div class="upload-zone" id="upload-zone">
                <input
                  type="file"
                  id="photos"
                  name="photos"
                  accept="image/*"
                  multiple
                  class="upload-input"
                  aria-label="Upload photos"
                />
                <div class="upload-zone-content" id="upload-prompt">
                  <div class="upload-icon">
                    <i class="fas fa-cloud-upload-alt"></i>
                  </div>
                  <p class="upload-text">
                    <strong>Click to upload</strong> or drag & drop photos here
                  </p>
                  <p class="upload-hint">JPG, PNG, HEIC up to 10MB each. Max 5 photos.</p>
                </div>
                <div class="upload-preview" id="upload-preview" style="display:none;"></div>
              </div>
            </div>

            <div id="form-status" class="form-status" style="display:none;"></div>

            <button type="submit" class="btn-primary-lg w-full submit-btn" style="justify-content: center;">
              <i class="fas fa-paper-plane"></i>
              <span class="btn-text">Send Message</span>
              <span class="btn-loading" style="display:none;">
                <i class="fas fa-spinner fa-spin"></i> Sending...
              </span>
            </button>
          </form>
        </div>

        <!-- Sidebar -->
        <aside class="contact-sidebar">
          <div class="contact-sidebar-card">
            <h3><i class="fas fa-bolt"></i> Need it now?</h3>
            <p>For emergencies, locked out situations or lost car keys — call directly for the fastest response.</p>
            <a href="tel:07809887883" class="btn-primary-lg" style="width: 100%; justify-content: center; margin-top: 16px;">
              <i class="fas fa-phone"></i> 07809 887 883
            </a>
            <a href="https://wa.me/447809887883" class="btn-whatsapp" style="width: 100%; justify-content: center; margin-top: 12px;" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-whatsapp"></i> WhatsApp
            </a>
          </div>

          <div class="contact-sidebar-card">
            <h3><i class="fas fa-clock"></i> Response Times</h3>
            <ul class="response-times-list">
              <li><span class="location-tag">Crouch End N8</span><span class="time-tag">~20 min</span></li>
              <li><span class="location-tag">Haringey</span><span class="time-tag">20–30 min</span></li>
              <li><span class="location-tag">Islington</span><span class="time-tag">20–30 min</span></li>
              <li><span class="location-tag">Camden</span><span class="time-tag">25–35 min</span></li>
              <li><span class="location-tag">Barnet</span><span class="time-tag">25–40 min</span></li>
              <li><span class="location-tag">Enfield</span><span class="time-tag">30–45 min</span></li>
              <li><span class="location-tag">Central London</span><span class="time-tag">30–45 min</span></li>
            </ul>
          </div>

          <div class="contact-sidebar-card trust-card">
            <div class="trust-badge-row">
              <div class="trust-badge-item">
                <i class="fas fa-shield-alt"></i>
                <span>Met Police Approved</span>
              </div>
              <div class="trust-badge-item">
                <i class="fas fa-certificate"></i>
                <span>Fully Insured</span>
              </div>
              <div class="trust-badge-item">
                <i class="fas fa-tag"></i>
                <span>No Call-Out Fee</span>
              </div>
              <div class="trust-badge-item">
                <i class="fas fa-star"></i>
                <span>5.0 Google Rating</span>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Business Hours -->
  <section class="content-section bg-dark">
    <div class="container-custom">
      <div class="section-header">
        <h2 class="section-title">Availability</h2>
        <p class="section-subtitle">
          Emergency locksmith and auto locksmith services available around the clock.
        </p>
      </div>

      <div class="services-icon-grid">
        <div class="service-icon-card">
          <div class="icon-circle">
            <i class="fas fa-bolt"></i>
          </div>
          <h3>Emergency Locksmith</h3>
          <p>24/7/365 — always available for lockouts, break-ins and urgent security.</p>
        </div>

        <div class="service-icon-card">
          <div class="icon-circle">
            <i class="fas fa-car-side"></i>
          </div>
          <h3>Auto Locksmith</h3>
          <p>7 days a week across North and Central London for car keys and vehicle lockouts.</p>
        </div>

        <div class="service-icon-card">
          <div class="icon-circle">
            <i class="fas fa-shield-alt"></i>
          </div>
          <h3>Safe Engineer</h3>
          <p>By appointment — UK-wide service with flexible scheduling to suit you.</p>
        </div>
      </div>
    </div>
  </section>

  <GoogleReviews bg="white" />

  <CTASection
    title="Prefer to Call?"
    subtitle="Direct line to William | No call-out fee | 24/7 emergency service"
  />
</BaseLayout>

<style>
  /* Hero */
  .policy-hero {
    position: relative;
    background: var(--color-bg-dark);
    padding: calc(var(--header-height) + 60px) 0 60px;
  }

  .policy-hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 50%, rgba(31,174,155,0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .policy-hero-content {
    position: relative;
    z-index: 1;
  }

  .loc-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    font-size: 0.85rem;
  }

  .loc-breadcrumb a { color: rgba(255,255,255,0.5); text-decoration: none; }
  .loc-breadcrumb a:hover { color: white; }
  .loc-breadcrumb span { color: rgba(255,255,255,0.35); }
  .loc-breadcrumb span:last-child { color: rgba(255,255,255,0.75); }

  .policy-hero-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    color: white;
    margin-bottom: 16px;
    line-height: 1.1;
  }

  .title-accent { color: var(--color-accent); }

  .policy-hero-lead {
    color: rgba(255,255,255,0.7);
    font-size: 1.05rem;
    margin-bottom: 32px;
    line-height: 1.7;
    max-width: 620px;
  }

  .loc-trust-bar {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
  }

  .loc-trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 16px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    font-weight: 500;
  }

  .loc-trust-item:first-child { padding-left: 0; }
  .loc-trust-item + .loc-trust-item { border-left: 1px solid rgba(255,255,255,0.28); }
  .loc-trust-item i { color: var(--color-accent); font-size: 0.8rem; }

  /* Contact Methods */
  .contact-methods-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 40px;
  }

  .contact-method-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 24px;
    border-radius: 16px;
    border: 2px solid rgba(0,0,0,0.06);
    background: white;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
    position: relative;
  }

  .contact-method-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .contact-method-primary {
    border-color: var(--color-accent);
  }

  .contact-method-whatsapp {
    border-color: #25d366;
  }

  .contact-method-icon {
    width: 48px;
    height: 48px;
    border-radius: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .contact-method-primary .contact-method-icon {
    background: rgba(31, 174, 155, 0.1);
    color: var(--color-accent);
  }

  .contact-method-whatsapp .contact-method-icon {
    background: rgba(37, 211, 102, 0.1);
    color: #25d366;
  }

  .contact-method-location .contact-method-icon {
    background: rgba(14, 74, 77, 0.1);
    color: var(--color-text-main);
  }

  .contact-method-body h3 {
    margin: 0 0 4px;
    font-size: 1rem;
    font-weight: 700;
  }

  .contact-method-body p {
    margin: 0 0 8px;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .contact-method-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-main);
  }

  .contact-method-arrow {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted-light);
    font-size: 0.875rem;
  }

  /* Form Layout */
  .contact-form-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 48px;
    align-items: start;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-control-modern {
    width: 100%;
    padding: 14px 16px;
    border: 2px solid rgba(0, 0, 0, 0.1);
    border-radius: 100px;
    font-size: 1rem;
    font-family: var(--font-body);
    transition: var(--transition-fast);
    background: white;
    color: var(--color-text-main);
  }

  .form-control-modern:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(31, 174, 155, 0.1);
  }

  textarea.form-control-modern {
    border-radius: 20px;
  }

  select.form-control-modern {
    cursor: pointer;
  }

  /* Photo Upload Zone */
  .upload-zone {
    position: relative;
    border: 2px dashed rgba(0, 0, 0, 0.15);
    border-radius: 20px;
    background: white;
    transition: all 0.2s ease;
    cursor: pointer;
    overflow: hidden;
    min-height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .upload-zone:hover,
  .upload-zone.dragover {
    border-color: var(--color-accent);
    background: rgba(31, 174, 155, 0.03);
  }

  .upload-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .upload-zone-content {
    text-align: center;
    padding: 24px;
    pointer-events: none;
  }

  .upload-icon {
    font-size: 2rem;
    color: var(--color-text-muted-light);
    margin-bottom: 8px;
  }

  .upload-text {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin: 0 0 4px;
  }

  .upload-text strong {
    color: var(--color-accent);
  }

  .upload-hint {
    font-size: 0.8rem;
    color: var(--color-text-muted-light);
    margin: 0;
  }

  .upload-preview {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding: 16px;
    width: 100%;
  }

  .preview-item {
    position: relative;
    width: 80px;
    height: 80px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .preview-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .preview-item button {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(0,0,0,0.6);
    border: none;
    color: white;
    font-size: 10px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Form Status */
  .form-status {
    padding: 16px;
    border-radius: 16px;
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 16px;
  }

  .form-status.success {
    background: rgba(31, 174, 155, 0.1);
    color: #0e6b5e;
    border: 1px solid rgba(31, 174, 155, 0.3);
  }

  .form-status.error {
    background: rgba(220, 38, 38, 0.05);
    color: #dc2626;
    border: 1px solid rgba(220, 38, 38, 0.2);
  }

  /* Sidebar */
  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: sticky;
    top: 100px;
  }

  .contact-sidebar-card {
    background: white;
    border-radius: 16px;
    padding: 24px;
    border: 1px solid rgba(0,0,0,0.06);
  }

  .contact-sidebar-card h3 {
    margin: 0 0 12px;
    font-size: 1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .contact-sidebar-card h3 i {
    color: var(--color-accent);
  }

  .contact-sidebar-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }

  .response-times-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .response-times-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.875rem;
  }

  .location-tag {
    color: var(--color-text-muted);
  }

  .time-tag {
    font-weight: 600;
    color: var(--color-accent);
    font-size: 0.8rem;
  }

  .trust-card {
    background: var(--color-bg-dark);
    border-color: transparent;
  }

  .trust-badge-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .trust-badge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 6px;
    padding: 12px 8px;
    border-radius: 10px;
    background: rgba(255,255,255,0.07);
  }

  .trust-badge-item i {
    color: var(--color-accent);
    font-size: 1.1rem;
  }

  .trust-badge-item span {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.8);
    font-weight: 500;
    line-height: 1.3;
  }

  @media (max-width: 768px) {
    .loc-trust-bar { gap: 10px; }
    .loc-trust-item { padding: 0; border-left: none; }
  }

  @media (max-width: 992px) {
    .contact-methods-grid {
      grid-template-columns: 1fr;
    }

    .contact-form-layout {
      grid-template-columns: 1fr;
    }

    .contact-sidebar {
      position: static;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const uploadZone = document.getElementById('upload-zone')!;
  const uploadInput = document.getElementById('photos') as HTMLInputElement;
  const uploadPrompt = document.getElementById('upload-prompt')!;
  const uploadPreview = document.getElementById('upload-preview')!;
  const formStatus = document.getElementById('form-status')!;
  const submitBtn = form?.querySelector('.submit-btn') as HTMLButtonElement;
  const btnText = form?.querySelector('.btn-text') as HTMLSpanElement;
  const btnLoading = form?.querySelector('.btn-loading') as HTMLSpanElement;

  let selectedFiles: File[] = [];

  // Drag & Drop
  uploadZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadZone.classList.add('dragover');
  });

  uploadZone.addEventListener('dragleave', () => {
    uploadZone.classList.remove('dragover');
  });

  uploadZone.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('dragover');
    const files = Array.from(e.dataTransfer?.files || []).filter(f => f.type.startsWith('image/'));
    addFiles(files);
  });

  uploadInput.addEventListener('change', () => {
    const files = Array.from(uploadInput.files || []);
    addFiles(files);
    uploadInput.value = ''; // reset so same file can be re-added
  });

  function addFiles(files: File[]) {
    const remaining = 5 - selectedFiles.length;
    const toAdd = files.slice(0, remaining);
    selectedFiles = [...selectedFiles, ...toAdd];
    renderPreviews();
  }

  function removeFile(index: number) {
    selectedFiles.splice(index, 1);
    renderPreviews();
  }

  function renderPreviews() {
    if (selectedFiles.length === 0) {
      uploadPrompt.style.display = '';
      uploadPreview.style.display = 'none';
      return;
    }
    uploadPrompt.style.display = 'none';
    uploadPreview.style.display = 'flex';
    uploadPreview.innerHTML = selectedFiles.map((file, i) => {
      const url = URL.createObjectURL(file);
      return `
        <div class="preview-item">
          <img src="${url}" alt="Uploaded reference photo ${i + 1} of lock, key or safe issue" />
          <button type="button" onclick="removeFileByIndex(${i})" aria-label="Remove photo ${i + 1}">
            <i class="fas fa-times"></i>
          </button>
        </div>
      `;
    }).join('');
  }

  (window as any).removeFileByIndex = removeFile;

  // --- Client-side validation ---
  function validateForm(formData: FormData): string | null {
    const name = (formData.get('name') as string || '').trim();
    const phone = (formData.get('phone') as string || '').trim();
    const email = (formData.get('email') as string || '').trim();
    const message = (formData.get('message') as string || '').trim();

    // Name
    if (!name || name.length < 2) return 'Please enter your full name.';
    if (!/^[a-zA-Z\s\-']+$/.test(name)) return 'Name contains invalid characters.';

    // Phone
    if (!phone) return 'Please enter your phone number.';
    const phoneClean = phone.replace(/[\s\-\(\)\.]/g, '');
    if (!/^(\+?44|0)?[1-9]\d{9,10}$/.test(phoneClean)) return 'Please enter a valid UK phone number.';

    // Email (if provided)
    if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) return 'Please enter a valid email address.';

    // Message
    if (!message || message.length < 5) return 'Please provide some details about your enquiry.';

    return null; // Valid
  }

  function showError(msg: string) {
    formStatus.className = 'form-status error';
    formStatus.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${msg}`;
    formStatus.style.display = 'block';
  }

  // Resize image to max dimension and compress as JPEG
  function resizeImage(file: File, maxSize: number, quality: number): Promise<string> {
    return new Promise((resolve) => {
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        let { width, height } = img;
        if (width > maxSize || height > maxSize) {
          if (width > height) {
            height = Math.round((height * maxSize) / width);
            width = maxSize;
          } else {
            width = Math.round((width * maxSize) / height);
            height = maxSize;
          }
        }
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext('2d')!;
        ctx.drawImage(img, 0, 0, width, height);
        const dataUrl = canvas.toDataURL('image/jpeg', quality);
        // Strip the data:image/jpeg;base64, prefix
        resolve(dataUrl.split(',')[1]);
      };
      img.src = URL.createObjectURL(file);
    });
  }

  // Form Submit
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    formStatus.style.display = 'none';

    const formData = new FormData(form);

    // Client-side validation first
    const validationError = validateForm(formData);
    if (validationError) {
      showError(validationError);
      return;
    }

    submitBtn.disabled = true;
    btnText.style.display = 'none';
    btnLoading.style.display = 'inline-flex';

    try {
      // Build JSON payload with base64 photos
      const payload: Record<string, unknown> = {
        name: formData.get('name'),
        phone: formData.get('phone'),
        email: formData.get('email') || 'Not provided',
        service: formData.get('service'),
        message: formData.get('message'),
        type: formData.get('form_type') || 'contact',
        photos: [] as { filename: string; content: string }[],
      };

      // Resize and convert photos to base64 (max 800px, JPEG 0.7 quality)
      for (const file of selectedFiles) {
        const base64 = await resizeImage(file, 800, 0.7);
        (payload.photos as { filename: string; content: string }[]).push({
          filename: file.name.replace(/\.[^.]+$/, '.jpg'),
          content: base64,
        });
      }

      const response = await fetch('/api/send-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await response.json();

      if (data.success) {
        formStatus.className = 'form-status success';
        formStatus.innerHTML = '<i class="fas fa-check"></i> Message sent! William will be in touch shortly. For urgent matters, please call <a href="tel:07809887883">07809 887 883</a>.';
        formStatus.style.display = 'block';
        form.reset();
        selectedFiles = [];
        renderPreviews();
      } else {
        showError(data.error || 'Failed to send. Please call 07809 887 883 directly.');
      }
    } catch {
      showError('Sorry, something went wrong. Please call <a href="tel:07809887883">07809 887 883</a> directly.');
    } finally {
      submitBtn.disabled = false;
      btnText.style.display = '';
      btnLoading.style.display = 'none';
    }
  });
</script>
