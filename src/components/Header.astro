<!-- Schema.org Site Navigation -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SiteNavigationElement",
  "name": [
    "Home",
    "About",
    "Services",
    "Emergency Locksmith",
    "Auto Locksmith",
    "Safe Engineer",
    "Locations",
    "Contact"
  ],
  "url": [
    "https://bullardlocks.com/",
    "https://bullardlocks.com/about",
    "https://bullardlocks.com/services",
    "https://bullardlocks.com/services/emergency-locksmith",
    "https://bullardlocks.com/services/auto-locksmith",
    "https://bullardlocks.com/services/safe-engineer",
    "https://bullardlocks.com/locations",
    "https://bullardlocks.com/contact"
  ]
}
</script>

<style>
  .navbar-floating {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0,0,0,0.05);
    padding: 0;
    z-index: 1000;
    height: var(--header-height);
    transition: all 0.3s ease;
  }

  .nav-container {
    max-width: 100%;
    margin: 0;
    padding: 0 40px;
    height: 100%;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  .nav-brand {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.5rem;
    color: var(--color-text-main);
    letter-spacing: -0.02em;
    z-index: 1001;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .brand-icon {
    color: var(--color-accent);
    font-size: 0.85em;
    margin-right: 2px;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
    min-width: 0;
    flex-shrink: 1;
  }

  .nav-link {
    color: var(--color-text-muted);
    font-weight: 500;
    font-size: 0.95rem;
    padding: 8px 0;
    position: relative;
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }

  .nav-link:hover, .nav-link:focus {
    color: var(--color-text-main);
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .mobile-nav-links a:focus-visible,
  .mobile-sub-links a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .text-xs { font-size: 0.75rem; opacity: 0.7; }

  /* Dropdown Menu */
  .dropdown-parent {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: var(--color-bg-dark);
    min-width: 240px;
    padding: 8px;
    border-radius: 12px;
    box-shadow: var(--shadow-xl);
    border: 1px solid rgba(255,255,255,0.08);
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    list-style: none;
    margin: 0;
  }

  .dropdown-parent:hover .dropdown-menu,
  .dropdown-parent:focus-within .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown-menu li a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    color: rgba(255,255,255,0.75);
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .dropdown-menu i {
    width: 20px;
    text-align: center;
    color: rgba(255,255,255,0.45);
    transition: color 0.2s ease;
  }

  /* Services dropdown — single column */
  .services-dropdown {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 220px;
  }

  /* Per-service hover colours */
  .svc-auto a:hover       { background: rgba(245,158,11,0.2);  color: #fcd34d; }
  .svc-auto a:hover i     { color: #fcd34d; }

  .svc-emergency a:hover  { background: rgba(239,68,68,0.2);   color: #fca5a5; }
  .svc-emergency a:hover i{ color: #fca5a5; }

  .svc-safe a:hover       { background: rgba(59,130,246,0.2);  color: #93c5fd; }
  .svc-safe a:hover i     { color: #93c5fd; }

  /* Locations dropdown — 2 explicit columns */
  .locations-dropdown {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-width: 380px;
    gap: 0;
    padding: 12px 8px 8px;
  }

  .loc-col {
    display: flex;
    flex-direction: column;
    padding: 0 4px;
  }

  .loc-col .dropdown-section-label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.35);
    font-weight: 700;
    padding: 0 12px 6px;
    white-space: nowrap;
  }

  .loc-col a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    color: rgba(255,255,255,0.75);
    font-weight: 500;
    border-radius: 8px;
    font-size: 0.9rem;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .loc-col a i {
    width: 16px;
    text-align: center;
    color: rgba(255,255,255,0.35);
    font-size: 0.75rem;
    transition: color 0.2s ease;
  }

  .loc-col a:hover {
    background: rgba(255,255,255,0.08);
    color: var(--color-accent);
  }

  .loc-col a:hover i { color: var(--color-accent); }

  .dropdown-all-row {
    grid-column: 1 / -1;
  }

  .dropdown-all-row:first-of-type {
    border-top: 1px solid rgba(255,255,255,0.08);
    margin-top: 4px;
    padding-top: 4px;
  }

  .dropdown-uk-link {
    font-weight: 600 !important;
    color: rgba(255,255,255,0.75) !important;
  }

  .dropdown-uk-link i {
    color: var(--color-accent) !important;
  }

  .dropdown-uk-link:hover {
    color: var(--color-accent) !important;
  }

  /* Locations dropdown extras */
  .locations-dropdown {
    min-width: 220px;
  }

  .dropdown-section-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.35);
    font-weight: 700;
    padding: 8px 16px 4px;
  }

  .dropdown-divider {
    height: 1px;
    background: rgba(255,255,255,0.08);
    margin: 4px 8px;
  }

  .dropdown-all-link {
    font-weight: 600 !important;
    color: var(--color-accent) !important;
  }

  .dropdown-all-link i {
    color: var(--color-accent) !important;
  }

  /* Actions */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    justify-content: flex-end;
  }

  .btn-nav-call {
    background-color: var(--color-accent);
    color: white;
    padding: 10px 20px;
    border-radius: 100px;
    font-weight: 700;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: var(--transition-normal);
    box-shadow: 0 4px 12px rgba(31, 174, 155, 0.3);
  }

  .btn-nav-call:hover {
    background-color: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(31, 174, 155, 0.4);
  }

  .btn-nav-whatsapp {
    background-color: #25D366;
    color: white;
    padding: 10px 20px;
    border-radius: 100px;
    font-weight: 700;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: var(--transition-normal);
    box-shadow: 0 4px 12px rgba(37, 211, 102, 0.3);
  }

  .btn-nav-whatsapp:hover {
    background-color: #1DA851;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(37, 211, 102, 0.4);
  }

  /* Mobile Menu */
  .mobile-menu-toggle {
    display: none;
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--color-text-main);
    cursor: pointer;
    padding: 4px;
    width: 38px;
    height: 38px;
    align-items: center;
    justify-content: center;
  }

  .mobile-menu-overlay {
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px);
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-menu-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 24px 24px 40px;
    max-width: 100%;
    margin: 0;
    overflow-y: auto;
  }

  .mobile-brand {
    display: none;
  }

  .mobile-menu-close {
    display: none;
  }

  .mobile-nav-links {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    flex-grow: 1;
  }

  .mobile-nav-links > li {
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }

  .mobile-nav-links a {
    color: var(--color-text-main);
    font-size: 1.1rem;
    font-weight: 600;
    display: block;
    padding: 10px 0;
  }

  .mobile-accordion-btn {
    background: none;
    border: none;
    color: var(--color-text-main);
    font-size: 1.1rem;
    font-weight: 600;
    padding: 10px 0;
    width: 100%;
    text-align: left;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .mobile-chevron {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    transition: transform 0.2s ease;
  }

  .mobile-accordion-btn[aria-expanded="true"] .mobile-chevron {
    transform: rotate(180deg);
  }

  .mobile-sub-links {
    list-style: none;
    padding: 0 0 8px 16px;
    margin: 0;
    display: none;
  }

  .mobile-sub-links.open {
    display: block;
  }

  .mobile-sub-links a {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-muted);
    padding: 8px 0;
  }

  .mobile-view-all {
    color: var(--color-accent) !important;
    font-weight: 600 !important;
  }

  /* Tablet — hide button text, keep icons */
  @media (max-width: 1200px) {
    .call-text {
      display: none;
    }

    .btn-nav-call,
    .btn-nav-whatsapp {
      padding: 10px;
      width: 42px;
      height: 42px;
      justify-content: center;
      gap: 0;
    }

    .btn-nav-whatsapp {
      font-size: 1.25rem;
    }

    .nav-links {
      gap: 20px;
    }
  }

  /* Mobile — hide nav links, show hamburger */
  @media (max-width: 992px) {
    .nav-links {
      display: none;
    }

    .btn-nav-call,
    .btn-nav-whatsapp {
      display: none;
    }

    .mobile-menu-toggle {
      display: flex;
    }

    .nav-container {
      grid-template-columns: auto 1fr;
      padding: 0 16px;
    }

    .nav-actions {
      justify-self: end;
    }
  }
</style>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');

  function toggleMenu(show?: boolean) {
    const isOpen = mobileMenu?.classList.contains('active');
    const shouldShow = show ?? !isOpen;
    if (shouldShow) {
      mobileMenu?.classList.add('active');
      document.body.style.overflow = 'hidden';
      // Swap hamburger icon to X
      const icon = menuBtn?.querySelector('i');
      if (icon) { icon.className = 'fas fa-times'; }
    } else {
      mobileMenu?.classList.remove('active');
      document.body.style.overflow = '';
      // Swap X icon back to hamburger
      const icon = menuBtn?.querySelector('i');
      if (icon) { icon.className = 'fas fa-bars'; }
    }
  }

  menuBtn?.addEventListener('click', () => toggleMenu());
  closeBtn?.addEventListener('click', () => toggleMenu(false));

  // Close menu when clicking a link
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => toggleMenu(false));
  });

  // Accordion toggles
  document.querySelectorAll('.mobile-accordion-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const sub = btn.nextElementSibling as HTMLElement;
      sub?.classList.toggle('open');
    });
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu?.classList.contains('active')) {
      toggleMenu(false);
    }
  });

  // Trap focus inside mobile menu when open
  mobileMenu?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab') return;
    const focusable = mobileMenu.querySelectorAll<HTMLElement>('a, button, [tabindex]:not([tabindex="-1"])');
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });
</script>
