---
// Floating bottom CTA bar - mobile only
---

<nav class="mobile-bottom-cta" aria-label="Quick contact">
  <a href="/contact" class="m-cta-btn m-cta-quote" aria-label="Request a quote">
    <i class="fas fa-file-invoice"></i>
    <span>Quote</span>
  </a>
  <a href="tel:07809887883" class="m-cta-btn m-cta-call" aria-label="Call 07809 887 883">
    <i class="fas fa-phone"></i>
    <span>Call</span>
  </a>
  <a
    href="https://wa.me/447809887883"
    class="m-cta-btn m-cta-whatsapp"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="WhatsApp"
  >
    <i class="fab fa-whatsapp"></i>
    <span>WhatsApp</span>
  </a>
  <button
    type="button"
    class="m-cta-btn m-cta-chat"
    id="m-cta-chat-trigger"
    aria-label="Open chat"
  >
    <i class="fas fa-robot"></i>
    <span>Chat</span>
  </button>
</nav>

<style is:global>
  .mobile-bottom-cta {
    display: none;
  }

  @media (max-width: 992px) {
    .mobile-bottom-cta {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      background: var(--color-bg-dark);
      box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.25);
      z-index: 998;
      padding-bottom: env(safe-area-inset-bottom);
    }

    .m-cta-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      padding: 11px 6px 10px;
      color: white;
      text-decoration: none;
      font-size: 0.72rem;
      font-weight: 700;
      text-align: center;
      transition: background 0.15s ease;
      background: transparent;
      border: none;
      cursor: pointer;
      font-family: var(--font-body);
    }

    .m-cta-btn i {
      font-size: 1.2rem;
    }

    .m-cta-quote i { color: #f1f3f2; }
    .m-cta-call i { color: var(--color-accent); }
    .m-cta-whatsapp i { color: #25D366; }
    .m-cta-chat i { color: #93c5fd; }

    .m-cta-btn:active {
      background: rgba(255, 255, 255, 0.08);
    }

    /* Hide the floating chat widget button, chat is now in the bottom bar */
    .chat-btn {
      display: none !important;
    }

    /* Lift content above the bottom CTA bar */
    body {
      padding-bottom: calc(64px + env(safe-area-inset-bottom));
    }

    /* Lift cookie banner above the bottom bar */
    .cookie-banner,
    .cookie-consent,
    [class*="cookie"] {
      bottom: calc(64px + env(safe-area-inset-bottom)) !important;
    }
  }
</style>

<script>
  const chatTrigger = document.getElementById('m-cta-chat-trigger');
  chatTrigger?.addEventListener('click', () => {
    const chatToggle = document.getElementById('chat-toggle') as HTMLButtonElement | null;
    chatToggle?.click();
  });
</script>
