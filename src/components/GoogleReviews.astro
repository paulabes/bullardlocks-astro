---
interface Props {
  bg?: 'white' | 'light';
}

const { bg = 'light' } = Astro.props;

// Latest 6 verified Google reviews (most recent first).
// Source of truth: src/pages/reviews.astro (full list of 20).
const reviews = [
  {
    name: 'Hayley Oconnell',
    date: '3 months ago',
    rating: 5,
    text: "Can't recommend enough! Fast service and extremely reasonable price. Thank you so much.",
  },
  {
    name: 'Lucy',
    date: '6 months ago',
    rating: 5,
    text: "Replaced the locks in my new home, super professional and friendly, also managed to resolve an issue with my door being difficult to close due to the original locking mechanism. Thank you!",
  },
  {
    name: 'Elisha Lewis',
    date: '10 months ago',
    rating: 5,
    text: "Locksmith arrived within 10 minutes on a sunny Sunday afternoon and got us back into the flat within an hour. He tried his best to get in without replacing the lock but had to replace it in the end. Very friendly and efficient service at a very good price.",
  },
  {
    name: 'Cosmo',
    date: 'a year ago',
    rating: 5,
    text: "Real lifesaver, managed to lock ourselves out, turned up in 10 minutes in Crouch End and charged a reasonable fair for a Friday at 8:30pm! Door was opened without any damage. Great friendly guy too. I hope your chippy tea was still hot when you got home!",
  },
  {
    name: 'Pete',
    date: 'a year ago',
    rating: 5,
    text: "William was excellent. Came out promptly, clearly knows what he's doing. A really nice guy too! We'd called out another so called \"locksmith\" beforehand who turned out to be a right conman. When William turned up you immediately felt he was someone who could be trusted, and he managed to unlock the door without damaging anything. Highly recommend!",
  },
  {
    name: 'Nigel Fung',
    date: 'a year ago',
    rating: 5,
    text: "William picked up the call first time and was round my house within 15 minutes - after the wife and I locked ourselves out during the morning school run. Quick, prompt, has a car full of equipment and got us indoors within 15 minutes. Great value, nice guy. Recommend.",
  },
];

// Marquee duplicates the list for a seamless infinite loop.
const track = [...reviews, ...reviews];
---

<section class={`reviews-section bg-${bg}`} id="reviews">
  <div class="container-custom">
    <div class="section-header">
      <h2 class="section-title">What Our Customers Say</h2>
      <p class="section-subtitle">5.0 stars on Google · 23 verified reviews</p>
    </div>

    <div class="reviews-marquee" aria-label="Customer reviews, slowly auto-scrolling">
      <div class="reviews-track">
        {track.map((review, idx) => (
          <article class="review-card" aria-hidden={idx >= reviews.length ? 'true' : undefined}>
            <div class="review-header">
              <div class="review-avatar">{review.name.charAt(0)}</div>
              <div class="review-meta">
                <p class="review-name">{review.name}</p>
                <p class="review-date">{review.date}</p>
              </div>
              <svg class="review-google-icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            </div>
            <div class="review-stars" aria-label={`${review.rating} out of 5 stars`}>
              {Array.from({ length: review.rating }).map(() => (
                <i class="fas fa-star" aria-hidden="true"></i>
              ))}
            </div>
            <p class="review-text">{review.text}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="reviews-cta">
      <a href="/reviews" class="btn-reviews-page">
        <i class="fas fa-star"></i> Read All Reviews
      </a>
      <a
        href="https://www.google.com/maps/place/?q=place_id:ChIJU7O3P5IbdkgRVm-wppoH9-4"
        class="btn-google-reviews"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        View on Google
      </a>
    </div>
  </div>
</section>

<style>
  .reviews-section {
    padding: 80px 0;
  }

  .reviews-marquee {
    overflow: hidden;
    padding: 8px 0;
    -webkit-mask-image: linear-gradient(to right, transparent 0, black 5%, black 95%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0, black 5%, black 95%, transparent 100%);
  }

  .reviews-track {
    display: flex;
    gap: 24px;
    width: max-content;
    animation: reviews-scroll 50s linear infinite;
  }

  .reviews-marquee:hover .reviews-track,
  .reviews-marquee:focus-within .reviews-track {
    animation-play-state: paused;
  }

  /* Translate exactly one set of 6 cards + 6 gaps so the duplicated
     second half lines up with where the first half started.
     Track is 12 cards wide (6 reviews × 2). -50% covers half the track
     (excluding the trailing gap between halves), so -12px (half-gap)
     compensates for the extra gap. */
  @keyframes reviews-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(calc(-50% - 12px)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .reviews-track {
      animation: none;
    }
  }

  .review-card {
    flex: 0 0 360px;
    background: white;
    border-radius: 3px;
    padding: 28px;
    border: 1px solid rgba(0,0,0,0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .review-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .review-meta { min-width: 0; }

  .review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .review-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-main);
    margin: 0;
  }

  .review-date {
    font-size: 0.78rem;
    color: var(--color-text-muted-light);
    margin: 0;
  }

  .review-google-icon {
    margin-left: auto;
    flex-shrink: 0;
  }

  .review-stars {
    display: flex;
    gap: 2px;
    color: #FBBC05;
    font-size: 0.8rem;
    margin-bottom: 12px;
  }

  .review-text {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  .reviews-cta {
    text-align: center;
    margin-top: 36px;
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .btn-reviews-page {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: var(--color-accent);
    color: white;
    border-radius: 3px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    box-shadow: 0 4px 14px rgba(31,174,155,0.3);
    transition: all 0.2s ease;
  }

  .btn-reviews-page:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(31,174,155,0.4);
  }

  .btn-google-reviews {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: white;
    color: var(--color-text-main);
    border: 2px solid rgba(0,0,0,0.1);
    border-radius: 3px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-google-reviews:hover {
    color: #4285F4;
    box-shadow: 0 4px 16px rgba(66,133,244,0.15);
    transform: translateY(-2px);
  }

  .bg-white .review-card {
    background: var(--color-bg-light);
  }

  .bg-white .btn-google-reviews {
    background: var(--color-bg-light);
  }

  @media (max-width: 768px) {
    .review-card {
      flex: 0 0 300px;
      padding: 22px;
    }
  }

  @media (max-width: 480px) {
    .review-card {
      flex: 0 0 calc(100vw - 64px);
    }
    .reviews-track {
      animation-duration: 120s;
    }
  }
</style>
